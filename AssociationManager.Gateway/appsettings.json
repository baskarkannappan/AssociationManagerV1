{
  "KeyVaultName": "kv-assocmgr-dev-unique",
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug"
    }
  },
  "AllowedOrigins": "https://happy-tree-0a717950f.7.azurestaticapps.net,https://lemon-coast-03635380f.7.azurestaticapps.net",
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "corporate-api-route": {
        "ClusterId": "corporate-api-cluster",
        "RateLimiterPolicy": "fixed",
        "CorsPolicy": "DefaultPolicy",
        "Match": {
          "Path": "/api/corporate/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/corporate" },
          { "PathPrefix": "/api" }
        ]
      },
      "api-route": {
        "ClusterId": "api-cluster",
        "RateLimiterPolicy": "fixed",
        "CorsPolicy": "DefaultPolicy",
        "Match": {
          "Path": "/api/{**remainder}"
        }
      },
      "realtime-route": {
        "ClusterId": "realtime-cluster",
        "RateLimiterPolicy": "fixed",
        "CorsPolicy": "DefaultPolicy",
        "Match": {
          "Path": "/hubs/{**remainder}"
        }
      }
    },
    "Clusters": {
      "corporate-api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://assocmgr-dev-corp-api.yellowmoss-1aeb0444.centralindia.azurecontainerapps.io"
          }
        }
      },
      "api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://assocmgr-dev-api.yellowmoss-1aeb0444.centralindia.azurecontainerapps.io"
          }
        }
      },
      "realtime-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://assocmgr-dev-api.yellowmoss-1aeb0444.centralindia.azurecontainerapps.io"
          }
        }
      }
    }
  }
}
