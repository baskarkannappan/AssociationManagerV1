{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "corporate-api-route": {
        "ClusterId": "corporate-api-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/corporate/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/corporate" },
          { "PathPrefix": "/api" }
        ]
      },
      "api-route": {
        "ClusterId": "api-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/{**remainder}"
        }
      },
      "realtime-route": {
        "ClusterId": "realtime-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/hubs/{**remainder}"
        }
      }
    },
    "Clusters": {
      "corporate-api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7010"
          }
        }
      },
      "api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5001"
          }
        }
      },
      "realtime-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5001"
          }
        }
      }
    }
  }
}
