@implements IDisposable
@inherits LayoutComponentBase

<div class="vscode-shell">
    <!-- Top Header Bar -->
    <header class="vscode-top-header">
        <div class="header-left">
            <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                <i class="bi bi-list"></i>
            </button>
            <svg viewBox="0 14 170 66" xmlns="http://www.w3.org/2000/svg" class="app-logo me-2">
                <g transform="translate(0,0)">
                    <rect x="0" y="20" width="35" height="60" fill="var(--vscode-text)"></rect>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="var(--vscode-text)"></ellipse>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"></ellipse>
                </g>
                <g transform="translate(45,0)">
                    <rect x="0" y="20" width="35" height="60" fill="var(--vscode-accent)"></rect>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="var(--vscode-accent)"></ellipse>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"></ellipse>
                </g>
                <g transform="translate(90,0)">
                    <rect x="0" y="20" width="35" height="60" fill="var(--vscode-text)"></rect>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="var(--vscode-text)"></ellipse>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"></ellipse>
                </g>
                <g transform="translate(135,0)">
                    <rect x="0" y="20" width="35" height="60" fill="var(--vscode-accent)"></rect>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="var(--vscode-accent)"></ellipse>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"></ellipse>
                </g>
            </svg>
            <span class="app-title fw-semibold">Association Manager</span>
            <span class="ms-2 opacity-50" style="font-size: 11px;">(v1.0.4)</span>
        </div>
        <div class="header-right">
            <AuthorizeView Context="authContext">
                <Authorized>
                    @if (_userTenants != null && _userTenants.Any())
                    {
                        <div class="tenant-switcher-container">
                            <i class="bi bi-diagram-3" style="font-size: 14px;"></i>
                            <select @onchange="HandleTenantChange" class="tenant-select" value="@_currentAssociationId">
                                @foreach (var assoc in _userTenants)
                                {
                                    <option value="@assoc.AssociationId">@assoc.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="user-identity ms-3 me-2">
                        <div class="d-flex flex-column align-items-end me-1">
                            <span class="user-email">@(authContext.User.FindFirst("email")?.Value ?? authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)</span>
                            <span class="user-role badge bg-primary-subtle text-primary border-primary-subtle" style="font-size: 9px; padding: 1px 4px;">@_currentRole</span>
                        </div>
                        <i class="bi bi-person-circle fs-5 opacity-75"></i>
                    </div>
                    <button class="logout-btn" @onclick="HandleLogout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>

    <div class="vscode-main">
        <!-- Sidebar Explorer -->
        @if (_currentAssociationId != 0)
        {
            <div class="sidebar-wrapper @(_isMobileMenuOpen ? "mobile-active" : "")">
                <Explorer />
            </div>
        }

        @if (_isMobileMenuOpen)
        {
            <div class="mobile-backdrop" @onclick="ToggleMobileMenu"></div>
        }

        <!-- Content Area -->
        <div class="vscode-editor-pane">
            <Toasts class="p-3" AutoHide="true" Delay="10000" Placement="ToastsPlacement.TopRight" />
            <main class="vscode-content">
                @Body
            </main>
        </div>
    </div>

    <!-- Status Bar
    <footer class="vscode-statusbar">
        <div class="section">
            <i class="bi bi-check2-all"></i>
            <span>Connected</span>
            <span>UTF-8</span>
        </div>
        <div class="section">
            <span>AssociationManager Project</span>
            <i class="bi bi-bell"></i>
        </div>
    </footer>
    -->
</div>

<link href="css/vscode.css" rel="stylesheet" />

<style>
    .app-logo { height: 18px; width: auto; vertical-align: middle; }
    .max-width-dashboard { max-width: 1200px; }
    .custom-scrollbar::-webkit-scrollbar { width: 10px; height: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cccccc; border: 3px solid transparent; background-clip: content-box; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #aaaaaa; border: 3px solid transparent; background-clip: content-box; }
    
    .tenant-switcher-container { font-size: 11px; display: flex; align-items: center; gap: 6px; color: #666; }
    .tenant-select { background: #ffffff; color: #333; border: 1px solid #ddd; font-size: 11px; padding: 1px 4px; border-radius: 2px; }
    .tenant-select:focus { outline: 1px solid var(--vscode-accent); border-color: transparent; }
    
    .user-identity { font-size: 11px; display: flex; align-items: center; gap: 8px; border-left: 1px solid #eee; padding-left: 10px; color: #333; }
    .user-email { font-weight: 500; line-height: 1; margin-bottom: 2px; }
    .user-role { text-transform: uppercase; font-weight: 700; letter-spacing: 0.5px; }
    .logout-btn { background: transparent; border: none; color: #666; padding: 0 5px; opacity: 0.8; transition: all 0.2s; }
    .logout-btn:hover { opacity: 1; color: var(--vscode-accent); transform: scale(1.1); }

    .mobile-backdrop {
        position: fixed;
        top: 40px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 998;
    }
</style>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private ApiService ApiService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ITenantContext TenantContext { get; set; } = default!;
    [Inject] private ToastService _toastService { get; set; } = default!;

    private IEnumerable<Association>? _userTenants;
    private int _currentTenantId;
    private int _currentAssociationId;
    private string? _currentRole;
    private string _currentAssociationStatus = "Active";
    private bool _isMobileMenuOpen;
    private bool _isLoadingTenants;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        await LoadTenants();
    }

    private void ToggleMobileMenu() => _isMobileMenuOpen = !_isMobileMenuOpen;

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isMobileMenuOpen = false;
        
        // Re-verify deactivation status on every navigation - UNIVERSAL REDIRECT
        if (_currentAssociationStatus == "Deactivated")
        {
            if (!Navigation.Uri.Contains("/deactivated") && !Navigation.Uri.Contains("/login"))
            {
                Navigation.NavigateTo("/deactivated");
            }
        }
        
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        await InvokeAsync(async () => {
            await LoadTenants(authState);
            StateHasChanged();
        });
    }

    private async Task LoadTenants(AuthenticationState? authState = null)
    {
        if (_isLoadingTenants) return;
        _isLoadingTenants = true;

        try 
        {
            if (authState == null)
            {
                authState = await AuthStateProvider.GetAuthenticationStateAsync();
            }
            
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                _currentTenantId = TenantContext.TenantId;
                _currentAssociationId = TenantContext.AssociationId;

                var contextRole = user.FindFirst(c => c.Type.Equals("ContextRole", StringComparison.OrdinalIgnoreCase))?.Value;
                var displayRole = !string.IsNullOrEmpty(contextRole) ? contextRole : AppRole.GetHighestRole(user.Claims);
                
                if (_currentRole != displayRole && displayRole != "Guest")
                {
                    _currentRole = displayRole;
                    ShowRoleCapabilities(displayRole);
                }
                
                _userTenants = await ApiService.GetAsync<IEnumerable<Association>>("api/associations/my-tenants");
                
                var currentAssoc = _userTenants?.FirstOrDefault(a => a.AssociationId == _currentAssociationId);
                _currentAssociationStatus = currentAssoc?.Status ?? "Active";

                if (_currentAssociationStatus == "Deactivated")
                {
                    if (!Navigation.Uri.Contains("/deactivated") && !Navigation.Uri.Contains("/login"))
                    {
                        Navigation.NavigateTo("/deactivated");
                    }
                }
                
                Console.WriteLine($"[Layout] Loaded {_userTenants?.Count() ?? 0} tenants for User. Status: {_currentAssociationStatus}");
                
                // Auto-select first association if none selected AND we aren't currently switching
                if (_currentAssociationId == 0 && _userTenants != null && _userTenants.Any())
                {
                    var firstAssoc = _userTenants.First();
                    Console.WriteLine($"[Layout] No AssociationId in session. Auto-selecting First: {firstAssoc.Name} (ID: {firstAssoc.AssociationId})");
                    
                    // Trigger automatic switch to set session context
                    var response = await AuthService.SwitchTenant(firstAssoc.TenantId, firstAssoc.AssociationId);
                    if (response?.Success == true)
                    {
                        Console.WriteLine($"[Layout] SwitchTenant successful. Forcing reload to apply context...");
                        // Update local State immediately to stop loop
                        _currentAssociationId = firstAssoc.AssociationId;
                        _currentTenantId = firstAssoc.TenantId;
                        
                        // Force load once to refresh all components with new context
                        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
                    }
                }
                else if (_currentAssociationId != 0)
                {
                    Console.WriteLine($"[Layout] Active AssociationId: {_currentAssociationId}. No auto-select needed.");
                }
            }
            else
            {
                _userTenants = null;
                _currentRole = null;
                _currentAssociationId = 0;
                _currentTenantId = 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading tenants: {ex.Message}");
            _userTenants = Enumerable.Empty<Association>();
        }
        finally
        {
            _isLoadingTenants = false;
        }
    }

    private void ShowRoleCapabilities(string role)
    {
        _toastService.Notify(new(
            ToastType.Info,
            iconName: IconName.ShieldCheck,
            title: "Access Granted",
            message: $"You have signed in with {role} privileges."));
    }

    private async Task HandleTenantChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newAssocId))
        {
            var assoc = _userTenants?.FirstOrDefault(a => a.AssociationId == newAssocId);
            if (assoc != null)
            {
                var response = await AuthService.SwitchTenant(assoc.TenantId, assoc.AssociationId);
                if (response?.Success == true)
                {
                    Navigation.NavigateTo("/", forceLoad: true);
                }
            }
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
