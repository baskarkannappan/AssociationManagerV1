@implements IDisposable
@inherits LayoutComponentBase

<div class="vscode-shell">
    <!-- Top Header Bar -->
    <header class="vscode-top-header">
        <div class="header-left">
            <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                <i class="bi bi-list"></i>
            </button>
            <span class="app-title fw-semibold">Association Manager</span>
            <span class="ms-2 opacity-50" style="font-size: 11px;">(v1.0.4)</span>
        </div>
        <div class="header-right">
            <AuthorizeView Context="authContext">
                <Authorized>
                    <div class="tenant-switcher-container">
                        <i class="bi bi-diagram-3" style="font-size: 14px;"></i>
                        @if (_userTenants == null)
                        {
                            <span>Loading...</span>
                        }
                        else
                        {
                            <select @onchange="HandleTenantChange" class="tenant-select" value="@_currentTenantId">
                                @foreach (var tenant in _userTenants)
                                {
                                    <option value="@tenant.TenantId">@tenant.Name</option>
                                }
                            </select>
                        }
                    </div>
                    <div class="user-identity ms-3 me-2" title="@authContext.User.Identity?.Name">
                        <i class="bi bi-person me-1"></i>
                        <span>@authContext.User.FindFirst("email")?.Value</span>
                    </div>
                    <button class="logout-btn" @onclick="HandleLogout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>

    <div class="vscode-main">
        <!-- Sidebar Explorer -->
        <div class="sidebar-wrapper @(_isMobileMenuOpen ? "mobile-active" : "")">
            <Explorer />
        </div>

        @if (_isMobileMenuOpen)
        {
            <div class="mobile-backdrop" @onclick="ToggleMobileMenu"></div>
        }

        <!-- Content Area -->
        <div class="vscode-editor-pane">
            @if (_showRoleToast && !string.IsNullOrEmpty(_currentRole))
            {
                <div class="role-toast-wrapper">
                    <div class="role-toast">
                        <div class="toast-header">
                            <i class="bi bi-shield-check"></i>
                            <span>Current Role: <strong>@_currentRole</strong></span>
                            <button class="ms-auto btn-close-toast" @onclick="() => _showRoleToast = false"><i class="bi bi-x"></i></button>
                        </div>
                        <div class="toast-body">
                            <div class="small-title">You can perform:</div>
                            <ul class="capability-list">
                                @foreach (var cap in AppRole.GetCapabilities(_currentRole))
                                {
                                    <li><i class="bi bi-check-circle-fill"></i> @cap</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
            <main class="vscode-content">
                @Body
            </main>
        </div>
    </div>

    <!-- Status Bar -->
    <footer class="vscode-statusbar">
        <div class="section">
            <i class="bi bi-check2-all"></i>
            <span>Connected</span>
            <span>UTF-8</span>
        </div>
        <div class="section">
            <span>AssociationManager Project</span>
            <i class="bi bi-bell"></i>
        </div>
    </footer>
</div>

<link href="css/vscode.css" rel="stylesheet" />

<style>
    .max-width-dashboard { max-width: 1200px; }
    .custom-scrollbar::-webkit-scrollbar { width: 10px; height: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cccccc; border: 3px solid transparent; background-clip: content-box; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #aaaaaa; border: 3px solid transparent; background-clip: content-box; }
    
    .tenant-switcher-container { font-size: 11px; display: flex; align-items: center; gap: 6px; }
    .tenant-select { background: #3c3c3c; color: #ccc; border: 1px solid #444; font-size: 11px; padding: 1px 4px; border-radius: 2px; }
    .tenant-select:focus { outline: 1px solid var(--vscode-accent); border-color: transparent; }
    
    .user-identity { font-size: 11px; opacity: 0.7; display: flex; align-items: center; gap: 4px; border-left: 1px solid rgba(255,255,255,0.1); padding-left: 10px; }
    .logout-btn { background: transparent; border: none; color: #ccc; padding: 0 5px; opacity: 0.6; }
    .logout-btn:hover { opacity: 1; color: #fff; }

    .role-toast-wrapper {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 2000;
        animation: toastIn 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
    }
    .role-toast {
        background: #ffffff;
        color: #333;
        border: 1px solid var(--vscode-border);
        border-top: 3px solid var(--vscode-accent);
        border-radius: 4px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        width: 280px;
        padding: 0;
        overflow: hidden;
    }
    .role-toast .toast-header {
        background: #f8f9fa;
        padding: 8px 12px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 1px solid #eee;
        font-size: 11px;
    }
    .role-toast .toast-header i { color: var(--vscode-accent); }
    .role-toast .toast-body { padding: 12px; }
    .role-toast .small-title { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #666; margin-bottom: 8px; }
    .role-toast .capability-list { list-style: none; padding: 0; margin: 0; }
    .role-toast .capability-list li { font-size: 11px; padding: 2px 0; display: flex; align-items: flex-start; gap: 8px; }
    .role-toast .capability-list li i { color: #28a745; font-size: 10px; margin-top: 2px; }
    .btn-close-toast { background: transparent; border: none; color: #999; padding: 0; font-size: 14px; line-height: 1; transition: color 0.2s; }
    .btn-close-toast:hover { color: #333; }

    @@keyframes toastIn {
        from { opacity: 0; transform: translateY(-20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .mobile-backdrop {
        position: fixed;
        top: 40px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 998;
    }
</style>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private ApiService ApiService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;

    private IEnumerable<Association>? _userTenants;
    private int _currentTenantId;
    private string? _currentRole;
    private bool _showRoleToast;
    private bool _isMobileMenuOpen;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        await LoadTenants();
    }

    private void ToggleMobileMenu() => _isMobileMenuOpen = !_isMobileMenuOpen;

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isMobileMenuOpen = false;
        StateHasChanged();
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await InvokeAsync(async () => {
            await LoadTenants();
            StateHasChanged();
        });
    }

    private async Task LoadTenants()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var tenantClaim = user.FindFirst("TenantId")?.Value;
            if (int.TryParse(tenantClaim, out int tid))
            {
                _currentTenantId = tid;
            }

            var roleClaim = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value 
                        ?? user.FindFirst("Role")?.Value 
                        ?? user.FindFirst("http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;
            
            if (_currentRole != roleClaim)
            {
                _currentRole = roleClaim;
                _showRoleToast = true;
                // Auto hide after 10 seconds
                _ = Task.Delay(10000).ContinueWith(_ => { _showRoleToast = false; InvokeAsync(StateHasChanged); });
            }
            
            try 
            {
                _userTenants = await ApiService.GetAsync<IEnumerable<Association>>("api/associations/my-tenants");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading tenants: {ex.Message}");
                _userTenants = Enumerable.Empty<Association>();
            }
        }
        else
        {
            _userTenants = null;
            _currentRole = null;
            _showRoleToast = false;
        }
    }

    private async Task HandleTenantChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int newTenantId))
        {
            var response = await AuthService.SwitchTenant(newTenantId);
            if (response?.Success == true)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
