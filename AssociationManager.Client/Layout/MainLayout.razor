@inherits LayoutComponentBase
@inject LayoutStateService LayoutState
@inject EventBusService EventBus
@inject AnalyticsService Analytics

<div class="vscode-shell">
    <!-- Top Header Bar -->
    <header class="vscode-top-header">
        <div class="header-left">
            <button class="mobile-menu-btn desktop-only" @onclick="ToggleMobileMenu">
                <i class="bi bi-list"></i>
            </button>
            <div class="d-flex align-items-center gap-2">
                <svg viewBox="0 14 170 66" xmlns="http://www.w3.org/2000/svg" class="app-logo">
                    <g transform="translate(0,0)">
                        <rect x="0" y="20" width="35" height="60" fill="var(--vscode-text)"></rect>
                        <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="var(--vscode-text)"></ellipse>
                        <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"></ellipse>
                    </g>
                    <g transform="translate(45,0)">
                        <rect x="0" y="20" width="35" height="60" fill="var(--vscode-accent)"></rect>
                        <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="var(--vscode-accent)"></ellipse>
                        <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"></ellipse>
                    </g>
                </svg>
                <span class="app-title fw-semibold desktop-only">Association Manager</span>
                <span class="app-title fw-semibold mobile-only" style="font-size: 11px;">AssocMgr</span>
            </div>
        </div>
        <div class="header-right">
            <LanguageSelector />
            <AuthorizeView Context="authContext">
                <Authorized>
                    @if (_userTenants != null && _userTenants.Any())
                    {
                        <div class="tenant-switcher-container">
                            <i class="bi bi-diagram-3 desktop-only" style="font-size: 14px;"></i>
                            <select @onchange="HandleTenantChange" class="tenant-select" value="@_currentAssociationId">
                                @foreach (var assoc in _userTenants)
                                {
                                    <option value="@assoc.AssociationId">@assoc.Name</option>
                                }
                            </select>
                        </div>
                    }
                    <div class="user-identity ms-2 desktop-only">
                        <div class="d-flex flex-column align-items-end me-1">
                            <span class="user-email">@(authContext.User.FindFirst("email")?.Value ?? authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)</span>
                            <span class="user-role badge bg-primary-subtle text-primary" style="font-size: 8px;">@_currentRole</span>
                        </div>
                        <i class="bi bi-person-circle fs-6 opacity-75"></i>
                    </div>
                    <button class="logout-btn" @onclick="HandleLogout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>

    <div class="vscode-main">
        <!-- Sidebar Explorer -->
        @if (_currentAssociationId != 0)
        {
            <div class="sidebar-wrapper @(_isMobileMenuOpen ? "mobile-active" : "")">
                <Explorer />
            </div>
        }

        @if (_isMobileMenuOpen)
        {
            <div class="mobile-backdrop" @onclick="ToggleMobileMenu"></div>
        }

        <!-- Content Area -->
        <div class="vscode-editor-pane">
            <Toasts class="p-3" AutoHide="true" Delay="10000" Placement="ToastsPlacement.TopRight" />
            <main class="vscode-content">
                
                @if (LayoutState.IsLoading)
                {
                    <div class="global-loader">
                        <div class="loader-bar"></div>
                    </div>
                }
                
                @Body
            </main>
        </div>
    </div>

    <!-- Mobile Bottom Navigation Bar -->
    <nav class="vscode-mobile-nav mobile-only">
        <NavLink href="/" class="mobile-nav-item" Match="NavLinkMatch.All">
            <i class="bi bi-house-door"></i>
            <span>Home</span>
        </NavLink>
        <NavLink href="/billing?scope=association" class="mobile-nav-item">
            <i class="bi bi-cash-stack"></i>
            <span>Finance</span>
        </NavLink>
        <NavLink href="/contact-us" class="mobile-nav-item">
            <i class="bi bi-question-circle"></i>
            <span>Help</span>
        </NavLink>
        <button class="mobile-nav-item btn btn-link p-0 border-0" @onclick="ToggleMobileMenu">
            <i class="bi bi-grid-3x3-gap"></i>
            <span>Menu</span>
        </button>
    </nav>
</div>

<link href="css/vscode.css" rel="stylesheet" />

<style>
    .app-logo { height: 18px; width: auto; vertical-align: middle; }
    .max-width-dashboard { max-width: 1200px; }
    .custom-scrollbar::-webkit-scrollbar { width: 10px; height: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cccccc; border: 3px solid transparent; background-clip: content-box; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #aaaaaa; border: 3px solid transparent; background-clip: content-box; }
    
    .tenant-switcher-container { font-size: 11px; display: flex; align-items: center; gap: 6px; color: #666; }
    .tenant-select { background: #ffffff; color: #333; border: 1px solid #ddd; font-size: 11px; padding: 1px 4px; border-radius: 2px; }

    .user-identity { display: flex; align-items: center; gap: 8px; cursor: default; }
    .user-email { font-size: 11px; font-weight: 500; color: #333; line-height: 1; }
    .user-role { padding: 1px 4px !important; border-radius: 2px !important; font-weight: 600 !important; }

    .global-loader { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 9999; background: rgba(0,122,204,0.1); }
    .loader-bar { height: 100%; background: var(--vscode-accent); transition: width 0.3s ease; width: 0%; animation: loader-pulse 2s infinite ease-in-out; }
    
    @@keyframes loader-pulse {
        0% { width: 0%; left: 0; }
        50% { width: 30%; left: 35%; }
        100% { width: 0%; left: 100%; }
    }

    .mobile-backdrop {
        position: fixed;
        top: 48px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 998;
    }
</style>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private ApiService ApiService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ITenantContext TenantContext { get; set; } = default!;
    [Inject] private ToastService _toastService { get; set; } = default!;
    [Inject] private RealtimeService _realtime { get; set; } = default!;

    private IEnumerable<Association>? _userTenants;
    private int _currentTenantId;
    private int _currentAssociationId;
    private string? _currentRole;
    private string _currentAssociationStatus = "Active";
    private bool _isMobileMenuOpen;
    private bool _isLoadingTenants;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        LayoutState.OnChange += StateHasChanged;
        await LoadTenants();
    }

    private void ToggleMobileMenu() => _isMobileMenuOpen = !_isMobileMenuOpen;

    private async void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isMobileMenuOpen = false;
        if (_currentAssociationStatus == "Deactivated")
        {
            if (!Navigation.Uri.Contains("/deactivated") && !Navigation.Uri.Contains("/login"))
            {
                Navigation.NavigateTo("/deactivated");
            }
        }
        
        // Track page view in Google Analytics
        await Analytics.TrackPageView("Main Client", Navigation.Uri);
        
        await InvokeAsync(StateHasChanged);
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        var authState = await task;
        await InvokeAsync(async () => {
            await LoadTenants(authState);
            StateHasChanged();
        });
    }

    private async Task LoadTenants(AuthenticationState? authState = null)
    {
        if (_isLoadingTenants) return;
        _isLoadingTenants = true;

        try 
        {
            if (authState == null) authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                _userTenants = await ApiService.GetAsync<IEnumerable<Association>>("api/associations/my-tenants");
                
                var aid = user.FindFirst("AssociationId")?.Value;
                if (int.TryParse(aid, out int associationId)) _currentAssociationId = associationId;

                var tid = user.FindFirst("TenantId")?.Value;
                if (int.TryParse(tid, out int tenantId)) _currentTenantId = tenantId;

                _currentRole = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? user.FindFirst("role")?.Value;
                _currentAssociationStatus = user.FindFirst("AssociationStatus")?.Value ?? "Active";

                if (_currentAssociationId == 0 && _userTenants != null && _userTenants.Any())
                {
                    _currentAssociationId = _userTenants.First().AssociationId;
                }

                // Initialize SignalR and join group
                try
                {
                    await _realtime.StartAsync();
                    await _realtime.JoinTenantGroupAsync(_currentTenantId);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[Realtime] Failed to start SignalR: {ex.Message}");
                    // Don't crash the app if real-time features fail
                }
            }
        }
        finally { _isLoadingTenants = false; }
    }

    private async Task HandleTenantChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int associationId))
        {
            var target = _userTenants?.FirstOrDefault(t => t.AssociationId == associationId);
            if (target != null)
            {
                var response = await AuthService.SwitchTenant(target.TenantId, target.AssociationId);
                if (response?.Success == true)
                {
                    await _realtime.LeaveTenantGroupAsync(_currentTenantId);
                    Navigation.NavigateTo("/", true);
                }
            }
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
        LayoutState.OnChange -= StateHasChanged;
    }
}
