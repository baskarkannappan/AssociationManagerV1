<div class="nav-scrollable h-100" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="vscode-activitybar">
            <NavLink class="nav-icon" href="" Match="NavLinkMatch.All" title="Explorer">
                <i class="bi bi-files"></i>
            </NavLink>

            <NavLink class="nav-icon" href="search" title="Search">
                <i class="bi bi-search"></i>
            </NavLink>

            <NavLink class="nav-icon" href="tariffs" title="Tariff Management">
                <i class="bi bi-wallet2"></i>
            </NavLink>

            <AuthorizeView Roles="@($"{AppRole.AssociationAdmin},{AppRole.SystemAdmin}")">
                <NavLink class="nav-icon" href="users" title="Users & Roles">
                    <i class="bi bi-people-fill"></i>
                </NavLink>
            </AuthorizeView>

            <div class="nav-icon" title="Source Control">
                <i class="bi bi-git"></i>
            </div>

            <div class="nav-icon" title="Run and Debug">
                <i class="bi bi-play-circle"></i>
            </div>

            <div class="nav-icon mt-auto" title="Settings">
                <i class="bi bi-gear-fill"></i>
            </div>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
