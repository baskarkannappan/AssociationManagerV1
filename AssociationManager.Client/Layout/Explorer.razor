@using Microsoft.AspNetCore.Components.Routing
@using AssociationManager.Client.Services
@inject IAppAuthorizationService AuthService

<AuthorizeView Context="rootAuthContext">
    <div class="vscode-explorer">
        <div class="vscode-explorer-header">Navigation</div>
        
        @if (_hasAccess)
        {
            <div class="vscode-tree-group mt-3">
                <div class="vscode-tree-item py-1 text-muted" style="font-family: var(--font-heading); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary) !important;">
                    Association Level
                </div>
                
                <NavLink href="/" Match="NavLinkMatch.All" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-grid-1x2-fill text-primary"></i>
                    <span>Dashboard</span>
                </NavLink>
                
                @if (_showAssetsMenu)
                {
                    <AuthorizeView Policy="ShowMenu_Assets" Context="assetMenuContext">
                        <NavLink href="assets" class="vscode-tree-item text-decoration-none">
                            <i class="bi bi-layers text-secondary"></i>
                            <span>Assets</span>
                        </NavLink>
                    </AuthorizeView>
                }
                
                <AuthorizeView Policy="ShowMenu_Users" Context="userMenuContext">
                    <NavLink href="users?scope=association" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-person-gear text-info"></i>
                        <span>User & Roles</span>
                    </NavLink>
                </AuthorizeView>

                @if (_showTariffMenu)
                {
                    <AuthorizeView Policy="ShowMenu_Tariffs" Context="tariffMenuContext">
                        <NavLink href="tariffs?scope=association" class="vscode-tree-item text-decoration-none">
                            <i class="bi bi-tag text-success"></i>
                            <span>Tariff Management</span>
                        </NavLink>
                    </AuthorizeView>
                }

                @if (_showFinanceMenu)
                {
                    <AuthorizeView Policy="ShowMenu_Finance" Context="financeMenuContext">
                        <NavLink href="billing?scope=association" class="vscode-tree-item text-decoration-none">
                            <i class="bi bi-cash-stack text-success"></i>
                            <span>Finance</span>
                        </NavLink>
                        
                        @if (_showAdvancesSubMenu)
                        {
                            <NavLink href="finance/advances" class="vscode-tree-item ms-3 text-decoration-none">
                                <i class="bi bi-wallet2 text-success"></i>
                                <span class="small">Advance Ledgers</span>
                            </NavLink>
                        }
    
                        @if (_showReportsSubMenu)
                        {
                            <AuthorizeView Policy="RequireFinanceManager">
                                <NavLink href="finance/reports" class="vscode-tree-item ms-3 text-decoration-none">
                                    <i class="bi bi-graph-up-arrow text-success"></i>
                                    <span class="small">Reports</span>
                                </NavLink>
                            </AuthorizeView>
                        }
                    </AuthorizeView>
                }

                @if (_showWalletMenu)
                {
                    <AuthorizeView Policy="RequireResident" Context="residentWalletContext">
                         @if (!_isAdmin)
                         {
                             <NavLink href="my-wallet" class="vscode-tree-item text-decoration-none">
                                <i class="bi bi-wallet2 text-info"></i>
                                <span>My Wallet</span>
                            </NavLink>
                         }
                    </AuthorizeView>
                }

                @* Removed as requested: ShowMenu_Operations *@

                <AuthorizeView Policy="ShowMenu_Broadcasts" Context="broadcastMenuContext">
                    <NavLink href="broadcasts?scope=association" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-chat-left-dots text-warning"></i>
                        <span>Communication</span>
                    </NavLink>
                    <AuthorizeView Policy="RequireAssociationAdmin" Context="commQueueContext">
                        <NavLink href="communication/queue" class="vscode-tree-item ms-3 text-decoration-none">
                            <i class="bi bi-envelope-paper text-warning"></i>
                            <span class="small">Email Queue</span>
                        </NavLink>
                    </AuthorizeView>
                </AuthorizeView>

                <AuthorizeView Policy="ShowMenu_Community" Context="communityMenuContext">
                    <NavLink href="people?scope=association" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-person-lines-fill text-danger"></i>
                        <span>Community</span>
                    </NavLink>
                </AuthorizeView>

                <AuthorizeView Policy="ShowMenu_Settings" Context="settingsMenuContext">
                    <NavLink href="settings" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-gear text-secondary"></i>
                        <span>Settings</span>
                    </NavLink>
                </AuthorizeView>

                <AuthorizeView Policy="ShowMenu_Governance" Context="govMenuContext">
                    <div class="vscode-tree-item py-1 text-muted mt-3" style="font-family: var(--font-heading); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary) !important;">
                        Governance
                    </div>
                    <NavLink href="governance/profile" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-building text-primary"></i>
                        <span>Association Profile</span>
                    </NavLink>
                    <NavLink href="governance/bank-details" class="vscode-tree-item ms-3 text-decoration-none">
                        <i class="bi bi-bank text-success"></i>
                        <span class="small">Bank Details</span>
                    </NavLink>
                    <NavLink href="governance/committee" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-people text-info"></i>
                        <span>Committee</span>
                    </NavLink>
                    <NavLink href="governance/byelaws" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-file-earmark-text text-secondary"></i>
                        <span>Bye-laws</span>
                    </NavLink>
                    <NavLink href="governance/meetings" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-calendar-check text-warning"></i>
                        <span>Meetings</span>
                    </NavLink>
                    <NavLink href="governance/elections" class="vscode-tree-item text-decoration-none">
                        <i class="bi bi-box-seam text-danger"></i>
                        <span>Elections</span>
                    </NavLink>
                    <div class="vscode-tree-item py-1 text-muted mt-3" style="font-family: var(--font-heading); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-tertiary) !important;">
                        System
                    </div>
                    <AuthorizeView Policy="RequireAssociationAdmin" Context="platformBillingContext">
                        <NavLink href="platform/billing" class="vscode-tree-item text-decoration-none">
                            <i class="bi bi-credit-card text-success"></i>
                            <span>Platform Subscription</span>
                        </NavLink>
                    </AuthorizeView>
                </AuthorizeView>
            </div>
        }
        else
        {
            <div class="p-3 text-muted small italic">
                <i class="bi bi-lock"></i> Pending Activation
            </div>
        }
    </div>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    private bool _isAdmin;
    private bool _hasAccess;
    private bool _showFinanceMenu;
    private bool _showWalletMenu;
    private bool _showAdvancesSubMenu;
    private bool _showReportsSubMenu;
    private bool _showAssetsMenu;
    private bool _showTariffMenu;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated == true)
        {
            _isAdmin = await AuthService.HasLevelAsync(user, 90);
            var assocId = user.FindFirst("AssociationId")?.Value;
            _hasAccess = _isAdmin || (!string.IsNullOrEmpty(assocId) && assocId != "0");

            _showFinanceMenu = await AuthService.EvaluateRuleAsync(user, "ShowMenu_Finance");
            _showWalletMenu = await AuthService.EvaluateRuleAsync(user, "ShowMenu_Wallet");
            _showAdvancesSubMenu = await AuthService.EvaluateRuleAsync(user, "ShowMenu_Advances");
            _showReportsSubMenu = await AuthService.EvaluateRuleAsync(user, "ShowMenu_Reports");
            _showAssetsMenu = await AuthService.EvaluateRuleAsync(user, "ShowMenu_Assets");
            _showTariffMenu = await AuthService.EvaluateRuleAsync(user, "ShowMenu_Tariffs");
        }
        else
        {
            _isAdmin = false;
            _hasAccess = false;
            _showFinanceMenu = false;
            _showWalletMenu = false;
            _showAdvancesSubMenu = false;
            _showReportsSubMenu = false;
            _showAssetsMenu = false;
            _showTariffMenu = false;
        }
    }
}
