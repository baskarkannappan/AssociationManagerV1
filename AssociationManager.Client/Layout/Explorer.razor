@using Microsoft.AspNetCore.Components.Routing

<div class="vscode-explorer">
    <div class="vscode-explorer-header">Navigation</div>
    
    <div class="vscode-tree-group">
        <NavLink href="" Match="NavLinkMatch.All" class="vscode-tree-item text-decoration-none">
            <i class="bi bi-house-door"></i>
            <span>Overview</span>
        </NavLink>
        
        <AuthorizeView Roles="@($"{AppRole.SystemAdmin},{AppRole.AssociationAdmin}")">
            <NavLink href="associations" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-diagram-3"></i>
                <span>Associations</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@($"{AppRole.SystemAdmin},{AppRole.AssociationAdmin},{AppRole.AssetManager}")">
            <NavLink href="assets" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-layers"></i>
                <span>Assets</span>
            </NavLink>
            
            <NavLink href="maintenance" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-tools"></i>
                <span>Operations</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@($"{AppRole.SystemAdmin},{AppRole.AssociationAdmin}")">
            <NavLink href="users" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-people-fill"></i>
                <span>Users & Roles</span>
            </NavLink>
        </AuthorizeView>
        
        <AuthorizeView Roles="@($"{AppRole.SystemAdmin},{AppRole.AssociationAdmin},{AppRole.FinanceManager}")">
            <NavLink href="billing" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-wallet2"></i>
                <span>Finance</span>
            </NavLink>
            <NavLink href="tariffs" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-layers-half"></i>
                <span>Tariff Management</span>
            </NavLink>
        </AuthorizeView>

        <AuthorizeView Roles="@($"{AppRole.SystemAdmin},{AppRole.AssociationAdmin}")">
            <NavLink href="broadcasts" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-megaphone"></i>
                <span>Communications</span>
            </NavLink>
        </AuthorizeView>
        
        <AuthorizeView Roles="@($"{AppRole.SystemAdmin},{AppRole.AssociationAdmin},{AppRole.UserManager}")">
            <NavLink href="people" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-people"></i>
                <span>Community</span>
            </NavLink>
        </AuthorizeView>
    </div>

    <div class="mt-auto pb-3">
        <div class="vscode-tree-item py-1 text-muted" style="font-size: 11px; font-weight: 600; border-top: 1px solid var(--vscode-border);">
            Configuration
        </div>
        <div class="vscode-tree-item text-decoration-none opacity-80">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </div>
    </div>
</div>
