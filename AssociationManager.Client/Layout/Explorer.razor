@using Microsoft.AspNetCore.Components.Routing

<div class="vscode-explorer">
    <div class="vscode-explorer-header">Navigation</div>
    
    <div class="vscode-tree-group">
        <NavLink href="" Match="NavLinkMatch.All" class="vscode-tree-item text-decoration-none">
            <i class="bi bi-house-door"></i>
            <span>Overview</span>
        </NavLink>
        
        <AuthorizeView>
            <Authorized>
                <NavLink href="associations" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-diagram-3"></i>
                    <span>Associations</span>
                </NavLink>

                <NavLink href="assets" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-layers"></i>
                    <span>Assets</span>
                </NavLink>
                
                <NavLink href="people" class="vscode-tree-item text-decoration-none opacity-50">
                    <i class="bi bi-people"></i>
                    <span>Community</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="mt-auto pb-3">
        <div class="vscode-tree-item py-1 text-muted" style="font-size: 11px; font-weight: 600; border-top: 1px solid var(--vscode-border);">
            Configuration
        </div>
        <div class="vscode-tree-item text-decoration-none opacity-50">
            <i class="bi bi-gear"></i>
            <span>Settings</span>
        </div>
    </div>
</div>
