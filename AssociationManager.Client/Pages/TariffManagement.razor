@page "/tariffs"
@attribute [Authorize(Policy = "RequireFinanceManager")]
@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums
@using AssociationManager.Client.Services
@using AssociationManager.Client.Components.Tariff
@using AssociationManager.Client.Components.Base
@inherits StatefulComponentBase
@inject LayoutStateService LayoutState
@inject TariffStateService TariffState
@inject AuthenticationStateProvider AuthStateProvider
@inject IAppAuthorizationService AuthService

<AuthorizeView Policy="RequireFinanceManager">
    <Authorized>
        <div class="h-100 d-flex flex-column bg-white forced-text-dark">
            <div class="flex-grow-1 d-flex overflow-hidden @(TariffState.ShowWorkbenchOnMobile ? "mobile-workbench-active" : "")">
                <TariffGroupSidebar />
                <TariffLayerWorkbench />
            </div>
        </div>
    </Authorized>
</AuthorizeView>

@if (TariffState.ShowGroupModal)
{
    <TariffGroupModal />
}

@if (TariffState.ShowLayerModal)
{
    <TariffLayerModal />
}

@if (TariffState.ShowBulkAssignModal && TariffState.Layers != null)
{
    <BulkAssignLayerModal LayerId="TariffState.SelectedLayerId" OnSuccess='() => TariffState.LoadAssignedAssetsAsync(TariffState.SelectedLayerId)' />
}

<style>
    .small-pills .nav-link { padding: 4px 12px; font-size: 11px; border-radius: 4px; border: 1px solid transparent; margin-left: 5px; color: #64748b; }
    .small-pills .nav-link.active { background: #007acc; color: white; border-color: #007acc; }
    .hover-bg-slate:hover { background: #f8fafc; }
    .cursor-pointer { cursor: pointer; }
    .compact-form .form-control, .compact-form .form-select { border-radius: 2px; border: 1px solid #e2e8f0; font-size: 13px; }
</style>

@code {
    protected override async Task OnInitializedAsync()
    {
        RegisterStateService(TariffState);
        
        LayoutState.SetPageMetadata("Tariff Management", "bi-tag", new List<AppBreadcrumbItem> {
            new AppBreadcrumbItem { Text = "Association" },
            new AppBreadcrumbItem { Text = "Tariffs", IsActive = true }
        });
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var canAccess = await AuthService.EvaluateRuleAsync(authState.User, "ShowMenu_Tariffs");
        if (!canAccess)
        {
            Navigation.NavigateTo("/");
            return;
        }

        // Parse once at the start to set Initial Scope
        TariffState.ParseQueryParameters();
        await TariffState.LoadGroupsAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (TariffState.ParseQueryParameters())
        {
            await TariffState.LoadGroupsAsync();
        }
    }
}
