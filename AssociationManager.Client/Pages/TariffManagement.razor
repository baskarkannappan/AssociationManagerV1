@page "/tariffs"
@attribute [Authorize(Policy = "RequireFinanceManager")]
@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums
@using AssociationManager.Client.Services
@inject ApiService ApiService
@inject ToastService _toastService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="premium-page-header border-bottom px-4 py-3 mb-0">
    <div class="d-flex align-items-center gap-2">
        <h1 class="premium-page-title mb-0">
            <i class="bi bi-wallet2 me-2 opacity-50"></i>
            @(_scope == "tenant" ? "Corporate Tariff Management" : "Association Tariff Management")
        </h1>
    </div>
</div>

<div class="row g-0 flex-grow-1" style="height: calc(100vh - 41px); overflow: hidden;">
    <!-- Groups Sidebar -->
    <div class="col-md-3 border-end bg-light d-flex flex-column" style="height: 100%;">
        <div class="p-2 border-bottom d-flex justify-content-between align-items-center bg-white">
            <span class="small fw-bold text-uppercase text-muted">Billing Groups</span>
            <button class="btn btn-sm btn-link p-0 text-vscode" @onclick="ShowCreateGroupForm">
                <i class="bi bi-plus-circle"></i>
            </button>
        </div>
        
        <div class="flex-grow-1 overflow-auto p-2">
            @if (_groups == null)
            {
                <div class="text-center py-4 opacity-50"><div class="spinner-border spinner-border-sm"></div></div>
            }
            else if (!_groups.Any())
            {
                <div class="text-center py-4 small text-muted">No groups defined.</div>
            }
            else
            {
                @foreach (var group in _groups)
                {
                    <div class="p-2 mb-1 rounded cursor-pointer @(SelectedGroup?.TariffGroupId == group.TariffGroupId ? "bg-primary text-white" : "hover-bg-slate text-dark")"
                         @onclick="() => SelectGroup(group)">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small fw-medium">@group.Name</span>
                            @if (SelectedGroup?.TariffGroupId == group.TariffGroupId)
                            {
                                <i class="bi bi-chevron-right small"></i>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Layers Workbench -->
    <div class="col-md-9 bg-white d-flex flex-column" style="height: 100%;">
        @if (SelectedGroup == null)
        {
            <div class="flex-grow-1 d-flex flex-column align-items-center justify-content-center text-muted opacity-50">
                <i class="bi bi-layers display-1 mb-3"></i>
                <p>Select a billing group to manage its tariffs.</p>
            </div>
        }
        else
        {
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-0">@SelectedGroup.Name</h5>
                    <small class="text-muted">@SelectedGroup.Description</small>
                </div>
                <div class="nav nav-pills small-pills">
                    <button class="nav-link @(_activeTab == "layers" ? "active" : "")" @onclick='() => _activeTab = "layers"'>Layers</button>
                    <button class="nav-link @(_activeTab == "assignments" ? "active" : "")" @onclick='() => _activeTab = "assignments"'>Assignments</button>
                </div>
            </div>

            <div class="flex-grow-1 overflow-auto p-3">
                @if (_activeTab == "layers")
                {
                    <div class="mb-3 d-flex justify-content-end">
                        <button class="btn btn-sm btn-vscode" @onclick="ShowCreateLayerForm">
                            <i class="bi bi-plus me-1"></i> New Layer
                        </button>
                    </div>
                    @if (_layers == null)
                    {
                        <div class="text-center py-5 opacity-50"><div class="spinner-border"></div></div>
                    }
                    else if (!_layers.Any())
                    {
                        <div class="p-5 text-center bg-light rounded border border-dashed text-muted">
                            <i class="bi bi-info-circle mb-2 d-block"></i>
                            No tariff layers defined in this group.
                        </div>
                    }
                    else
                    {
                        <TariffLayerList Layers="_layers" OnDelete="DeleteLayer" />
                    }
                }
                else
                {
                    <p class="small text-muted mb-3">Select a layer to manage asset assignments.</p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <select class="form-select form-select-sm" @bind="_selectedLayerIdForAssignment">
                                <option value="0">-- Select Layer --</option>
                                @foreach (var layer in _layers ?? new())
                                {
                                    <option value="@layer.TariffLayerId">@layer.Name (₹@layer.BaseRate)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8">
                            @if (_selectedLayerIdForAssignment > 0)
                            {
                                <div class="p-3 border rounded bg-light">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="small fw-bold">Assigned Assets</span>
                                        <button class="btn btn-sm btn-vscode" @onclick="ShowBulkAssignModal">
                                            <i class="bi bi-plus-circle me-1"></i> Bulk Assign
                                        </button>
                                    </div>
                                    
                                    @if (_assignedAssets == null)
                                    {
                                        <div class="text-center py-2 opacity-50 small">Loading mappings...</div>
                                    }
                                    else if (!_assignedAssets.Any())
                                    {
                                        <div class="text-center py-3 border border-dashed rounded bg-white small text-muted">
                                            No assets assigned to this layer yet.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var asset in _assignedAssets)
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary border d-flex align-items-center gap-2" style="font-size: 11px;">
                                                    @asset.AssetName
                                                    @if (!asset.IsRecurring)
                                                    {
                                                        <span class="ms-1 px-1 rounded-pill bg-warning text-dark" style="font-size: 8px;">ONE-TIME</span>
                                                    }
                                                    <i class="bi bi-x cursor-pointer" @onclick="() => RemoveAssignment(asset)"></i>
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Bulk Assign Modal -->
@if (_showBulkAssignModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-0 bg-light py-2">
                    <h6 class="modal-title fw-bold">Bulk Assign Layer</h6>
                    <button type="button" class="btn-close small" @onclick="() => _showBulkAssignModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="p-3 bg-white sticky-top border-bottom">
                         <div class="input-group input-group-sm mb-2">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control border-start-0" placeholder="Filter assets..." @bind="_assetFilter" @bind:event="oninput" />
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked="@_allSelected" @onchange="ToggleSelectAll" id="selectAllAssets">
                                <label class="form-check-label small fw-semibold" for="selectAllAssets">Select All Billable Assets</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" @bind="_isRecurringForAssignment" id="recurringCharge">
                                <label class="form-check-label small fw-semibold text-primary" for="recurringCharge">Recurring Charge</label>
                            </div>
                            <span class="small text-muted">@_selectedAssetIds.Count selected</span>
                        </div>
                    </div>
                    <div class="list-group list-group-flush" style="max-height: 400px;">
                        @foreach (var asset in GetFilteredAssets())
                        {
                            <label class="list-group-item d-flex align-items-center py-2 hover-bg-slate cursor-pointer">
                                <input class="form-check-input me-3" type="checkbox" 
                                       checked="@_selectedAssetIds.Contains(asset.AssetId)" 
                                       @onchange='(e) => ToggleAssetSelection(asset.AssetId, (bool)e.Value!)'>
                                <div>
                                    <div class="fw-medium small">@asset.Name</div>
                                    <div class="text-muted" style="font-size: 10px;">@asset.AssetType | @asset.Description</div>
                                </div>
                            </label>
                        }
                    </div>
                </div>
                <div class="modal-footer border-0 bg-light py-2">
                    <button class="btn btn-sm btn-secondary" @onclick="() => _showBulkAssignModal = false">Cancel</button>
                    <button class="btn btn-sm btn-vscode px-4" @onclick="ExecuteBulkAssign" disabled="@(!_selectedAssetIds.Any() || _isProcessing)">
                        @if (_isProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirm Assignment
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .small-pills .nav-link { padding: 4px 12px; font-size: 11px; border-radius: 4px; border: 1px solid transparent; margin-left: 5px; color: #64748b; }
    .small-pills .nav-link.active { background: #007acc; color: white; border-color: #007acc; }
    .small-pills .nav-link:not(.active):hover { background: #f1f5f9; }
</style>

<!-- Modals (Simplified for now using simple flags) -->
@if (_showGroupModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-sm">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">New Billing Group</h6>
                    <button type="button" class="btn-close small" @onclick="() => _showGroupModal = false"></button>
                </div>
                <div class="modal-body compact-form">
                    <div class="mb-3">
                        <label>Group Name</label>
                        <input @bind="_newGroup.Name" class="form-control" placeholder="e.g. Maintenance Fees" />
                    </div>
                    <div class="mb-3">
                        <label>Description</label>
                        <textarea @bind="_newGroup.Description" class="form-control" placeholder="Optional details..."></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-sm btn-secondary" @onclick="() => _showGroupModal = false">Cancel</button>
                    <button class="btn btn-sm btn-vscode px-3" @onclick="CreateGroup">Create Group</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showLayerModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-sm">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Add Layer to @SelectedGroup?.Name</h6>
                    <button type="button" class="btn-close small" @onclick="() => _showLayerModal = false"></button>
                </div>
                <div class="modal-body compact-form">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label>Layer Name</label>
                            <input @bind="_newLayer.Name" class="form-control" placeholder="e.g. Waste Management" />
                        </div>
                        <div class="col-md-6">
                            <label>Accounting Category</label>
                            <input @bind="_newLayer.AccountingCategory" class="form-control" placeholder="e.g. Operational" />
                        </div>
                        <div class="col-md-4">
                            <label>Base Rate (₹)</label>
                            <input type="number" @bind="_newLayer.BaseRate" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label>Frequency</label>
                            <select @bind="_newLayer.Frequency" class="form-select">
                                @foreach (var f in Enum.GetValues<BillingFrequency>())
                                {
                                    <option value="@f">@f</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label>Calc Type</label>
                            <select @bind="_newLayer.CalculationType" class="form-select">
                                @foreach (var c in Enum.GetValues<CalculationType>())
                                {
                                    <option value="@c">@c</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-sm btn-secondary" @onclick="() => _showLayerModal = false">Cancel</button>
                    <button class="btn btn-sm btn-vscode px-3" @onclick="CreateLayer">Add Layer</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .hover-bg-slate:hover { background: #f8fafc; }
    .cursor-pointer { cursor: pointer; }
    .compact-form label { font-size: 11px; font-weight: 600; color: #64748b; display: block; margin-bottom: 2px; }
    .compact-form .form-control, .compact-form .form-select { border-radius: 2px; border: 1px solid #e2e8f0; font-size: 13px; }
</style>

@code {
    private string _activeTab = "layers";
    private int _selectedLayerIdForAssignment_Internal;
    private int _selectedLayerIdForAssignment 
    { 
        get => _selectedLayerIdForAssignment_Internal; 
        set { _selectedLayerIdForAssignment_Internal = value; _ = LoadAssignedAssets(); } 
    }
    
    private List<TariffGroup>? _groups;
    private List<TariffLayer>? _layers;
    private List<AssetTariff>? _assignedAssets;
    private List<Asset>? _allPossibleAssets;
    private HashSet<int> _selectedAssetIds = new();
    private string _assetFilter = "";
    private bool _allSelected = false;
    private bool _isProcessing = false;
    private bool _isRecurringForAssignment = true;

    private TariffGroup? SelectedGroup;

    private bool _showGroupModal = false;
    private bool _showLayerModal = false;
    private bool _showBulkAssignModal = false;
    private TariffGroup _newGroup = new();
    private TariffLayer _newLayer = new();
    private string _scope = "tenant";

    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadGroups();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ParseQueryParameters())
        {
            _groups = null;
            SelectedGroup = null;
            await LoadGroups();
        }
    }

    private bool ParseQueryParameters()
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query;
        var newScope = query.Contains("scope=association") ? "association" : "tenant";
        
        if (newScope != _scope)
        {
            _scope = newScope;
            return true;
        }
        return false;
    }

    private async Task LoadGroups()
    {
        string url = "api/tariff/groups";
        if (_scope == "association")
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var aid = authState.User.FindFirst("AssociationId")?.Value;
            if (int.TryParse(aid, out int associationId) && associationId != 0)
            {
                url = $"{url}?associationId={associationId}";
            }
        }
        _groups = await ApiService.GetAsync<List<TariffGroup>>(url);
    }

    private async Task SelectGroup(TariffGroup group)
    {
        SelectedGroup = group;
        _layers = null;
        _layers = await ApiService.GetAsync<List<TariffLayer>>($"api/tariff/groups/{group.TariffGroupId}/layers");
    }

    private void ShowCreateGroupForm()
    {
        _newGroup = new();
        _showGroupModal = true;
    }

    private async Task CreateGroup()
    {
        if (string.IsNullOrWhiteSpace(_newGroup.Name)) return;
        var success = await ApiService.PostAsync("api/tariff/groups", _newGroup);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Billing group created."));
            _showGroupModal = false;
            await LoadGroups();
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to create group."));
        }
    }

    private void ShowCreateLayerForm()
    {
        _newLayer = new TariffLayer { TariffGroupId = SelectedGroup!.TariffGroupId };
        _showLayerModal = true;
    }

    private async Task CreateLayer()
    {
        if (string.IsNullOrWhiteSpace(_newLayer.Name)) return;
        var success = await ApiService.PostAsync("api/tariff/layers", _newLayer);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Tariff layer added."));
            _showLayerModal = false;
            if (SelectedGroup != null) await SelectGroup(SelectedGroup);
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to add layer."));
        }
    }

    private async Task DeleteLayer(int id)
    {
        var success = await ApiService.DeleteAsync($"api/tariff/layers/{id}");
        if (success)
        {
            _toastService.Notify(new(ToastType.Warning, "Tariff layer deleted."));
            if (SelectedGroup != null) await SelectGroup(SelectedGroup);
        }
    }

    private async Task LoadAssignedAssets()
    {
        if (_selectedLayerIdForAssignment == 0) 
        {
            _assignedAssets = null;
            return;
        }

        // We don't have a direct "Get Assets by Layer" endpoint in current Controller, 
        // so we might need to fetch association hierarchy and check. 
        // For now, let's assume we fetch all assets for association.
        await LoadAllPossibleAssets();
        
        // This is a bit inefficient (checking every asset for mapping), 
        // ideally we'd have api/tariff/layers/{id}/assignments
        var activeAssignments = new List<AssetTariff>();
        if (_allPossibleAssets != null)
        {
            foreach(var asset in _allPossibleAssets)
            {
                var layerAssignments = await ApiService.GetAsync<List<AssetTariff>>($"api/tariff/assets/{asset.AssetId}");
                if (layerAssignments != null)
                {
                    var match = layerAssignments.FirstOrDefault(a => a.TariffLayerId == _selectedLayerIdForAssignment && a.IsActive);
                    if (match != null) 
                    {
                        match.AssetName = asset.Name; // Inject name for display
                        activeAssignments.Add(match);
                    }
                }
            }
        }
        _assignedAssets = activeAssignments;
    }

    private async Task LoadAllPossibleAssets()
    {
        if (_allPossibleAssets != null) return;
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var aid = authState.User.FindFirst("AssociationId")?.Value;
        if (int.TryParse(aid, out int associationId))
        {
            var assets = await ApiService.GetAsync<List<Asset>>($"api/assets/hierarchy?associationId={associationId}");
            if (assets != null)
            {
                _allPossibleAssets = Flatten(assets).Where(a => a.AssetType == AssetType.Unit || a.AssetType == AssetType.Villa || a.AssetType == AssetType.Property).ToList();
            }
        }
    }

    private IEnumerable<Asset> Flatten(IEnumerable<Asset> assets)
    {
        foreach (var asset in assets)
        {
            yield return asset;
            if (asset.Children != null)
            {
                foreach (var child in Flatten(asset.Children))
                {
                    yield return child;
                }
            }
        }
    }

    private IEnumerable<Asset> GetFilteredAssets()
    {
        if (_allPossibleAssets == null) return Enumerable.Empty<Asset>();
        var filtered = _allPossibleAssets;
        if (!string.IsNullOrWhiteSpace(_assetFilter))
        {
            filtered = filtered.Where(a => a.Name.Contains(_assetFilter, StringComparison.OrdinalIgnoreCase)).ToList();
        }
        return filtered;
    }

    private async Task ShowBulkAssignModal()
    {
        await LoadAllPossibleAssets();
        _selectedAssetIds.Clear();
        _allSelected = false;
        _showBulkAssignModal = true;
    }

    private void ToggleAssetSelection(int assetId, bool selected)
    {
        if (selected) _selectedAssetIds.Add(assetId);
        else _selectedAssetIds.Remove(assetId);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        _allSelected = (bool)e.Value!;
        if (_allSelected)
        {
            foreach (var a in GetFilteredAssets()) _selectedAssetIds.Add(a.AssetId);
        }
        else
        {
            _selectedAssetIds.Clear();
        }
    }

    private async Task ExecuteBulkAssign()
    {
        if (!_selectedAssetIds.Any()) return;
        _isProcessing = true;
        try
        {
            var assignments = _selectedAssetIds.Select(id => new AssetTariff
            {
                AssetId = id,
                TariffLayerId = _selectedLayerIdForAssignment,
                IsActive = true,
                IsRecurring = _isRecurringForAssignment,
                CreatedDate = DateTime.UtcNow
            }).ToList();

            var success = await ApiService.PostAsync("api/tariff/assets/bulk-assign", assignments);
            if (success)
            {
                _toastService.Notify(new(ToastType.Success, $"Successfully assigned layer to {assignments.Count} assets."));
                _showBulkAssignModal = false;
                await LoadAssignedAssets();
            }
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RemoveAssignment(AssetTariff assignment)
    {
        var success = await ApiService.DeleteAsync($"api/tariff/assets/{assignment.AssetId}/layers/{assignment.TariffLayerId}");
        if (success)
        {
            _toastService.Notify(new(ToastType.Warning, "Assignment removed."));
            await LoadAssignedAssets();
        }
    }
}
