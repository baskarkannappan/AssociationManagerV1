@page "/my-wallet"
@using AssociationManager.Shared.Models
@using AssociationManager.Client.Services
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject NavigationManager Navigation
@inject IAppAuthorizationService AuthService
@inject BlazorBootstrap.ToastService ToastService
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize(Policy = "RequireResident")]

<RazorpayCheckout @ref="_razorpayCheckout" OnPaymentSuccess="OnPaymentProcessed" />

<div class="premium-page-header border-bottom px-4 py-3 mb-0">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="premium-page-title mb-0" style="font-size: 1.25rem;">
                <i class="bi bi-wallet2 me-2"></i> My Resident Wallet
            </h1>
            <div class="text-muted extra-small opacity-75 mt-1">
                Manage your prepayments and track your credit balance.
            </div>
        </div>
        <div class="header-right">
            <button class="btn btn-vscode px-4 py-2" @onclick="ShowAdvanceModal">
                <i class="bi bi-plus-circle me-2"></i> Add Funds
            </button>
        </div>
    </div>
</div>

<div class="vscode-content custom-scrollbar p-4">
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="premium-card p-4 text-center border-0 shadow-sm" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); color: white;">
                <div class="text-uppercase small fw-bold opacity-75 mb-2">Available Credit</div>
                <div class="display-5 fw-bold mb-2">₹@(_balance.ToString("N0"))</div>
                <div class="small opacity-75">
                    <i class="bi bi-info-circle me-1"></i> Automatically applied to next invoice
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="premium-card p-4 h-100 bg-white border">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary me-3">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold text-vscode-accent">Wallet Security & Automation</h6>
                        <p class="text-muted small mb-0">Your funds are safe and tracked per unit.</p>
                    </div>
                </div>
                <p class="small text-muted mb-0">Advance payments are stored against your asset (Unit). When a new maintenance or utility invoice is generated, the system will <strong>automatically</strong> consume this credit to mark the invoice as "Paid" instantly.</p>
            </div>
        </div>
    </div>

    <div class="compact-card shadow-sm border-0">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="m-0 fw-semibold text-vscode-accent">Transaction History</h6>
            <div class="d-flex gap-2">
                <div class="input-group input-group-sm" style="width: 250px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search py-1"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search Reference..." 
                           @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyUp" />
                </div>
                <button class="btn btn-sm btn-outline-secondary px-3" @onclick="RefreshGrid">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>

        <Grid @ref="walletGrid" TItem="AdvancePaymentHistory"
              Class="table table-hover table-bordered table-striped compact-table align-middle"
              DataProvider="WalletDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="10"
              AllowSorting="true">

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Date" PropertyName="Date" SortKeySelector="item => item.Date" HeaderClass="ps-3" Class="ps-3">
                <div class="d-flex flex-column">
                    <span class="fw-semibold text-dark">@context.Date.ToString("dd MMM yyyy")</span>
                    <span class="text-muted extra-small opacity-75">@context.Date.ToString("t")</span>
                </div>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Reference" PropertyName="ReferenceId">
                @{
                    bool isSettlement = context.ReferenceId?.Contains("Advance used to pay") == true;
                }
                <div class="d-flex align-items-center gap-2">
                    <div class="ref-icon-circle @(isSettlement ? "bg-warning-subtle text-warning" : "bg-info-subtle text-info")">
                        <i class="bi @(isSettlement ? "bi-receipt-cutoff" : "bi-credit-card")"></i>
                    </div>
                    <div class="d-flex flex-column">
                        @if (isSettlement)
                        {
                            <span class="small fw-semibold text-vscode-accent">Invoice Payment</span>
                            <span class="extra-small text-muted text-truncate" style="max-width: 150px;">@context.ReferenceId</span>
                        }
                        else
                        {
                            <span class="small fw-semibold text-vscode-accent">Wallet Top-up</span>
                            <code class="extra-small text-primary">@context.ReferenceId</code>
                        }
                    </div>
                </div>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Unit" PropertyName="UnitName" SortKeySelector="item => item.UnitName">
                <span class="premium-unit-badge">@context.UnitName</span>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Status" PropertyName="Status" SortKeySelector="item => item.Status">
                <span class="modern-badge @GetStatusClass(context.Status)">@context.Status</span>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Amount" PropertyName="Amount" SortKeySelector="item => item.Amount" HeaderClass="text-end pe-3" Class="text-end pe-3">
                @{
                    bool isPositive = context.Amount >= 0;
                }
                <div class="d-flex flex-column align-items-end">
                    <span class="fw-bold @(isPositive ? "text-success" : "text-danger")" style="font-size: 1rem;">
                        @(isPositive ? "+" : "-")₹@Math.Abs(context.Amount).ToString("N0")
                    </span>
                    <span class="extra-small opacity-50 @(isPositive ? "text-success" : "text-danger")" style="margin-top: -4px;">
                        @(isPositive ? "TOP-UP" : "SETTLEMENT")
                    </span>
                </div>
            </GridColumn>
        </Grid>

    </div>

    @if (_isAdvanceModalOpen)
    {
        <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="premium-card-header">
                        <h6 class="premium-card-title"><i class="bi bi-plus-circle-fill me-2"></i>Add Funds to Wallet</h6>
                        <button type="button" class="btn-close" @onclick="HideAdvanceModal"></button>
                    </div>
                    <div class="p-4">
                        <p class="text-muted small mb-3">Add money to your unit's credit balance. This will be automatically applied to future invoices.</p>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">Amount (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input type="number" class="form-control" @bind="_advanceAmount" placeholder="Enter amount" />
                            </div>
                        </div>
                        <div class="d-grid mt-4">
                            <button class="btn btn-vscode py-2 fw-bold" @onclick="ProcessAdvancePayment" disabled="@(_advanceAmount <= 0)">
                                Proceed to Razorpay Payment
                            </button>
                        </div>
                        <div class="mt-3 text-center">
                            <button class="btn btn-link btn-sm text-muted text-decoration-none" @onclick="HideAdvanceModal">Cancel</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .icon-box {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }
</style>

@code {
    private Grid<AdvancePaymentHistory> walletGrid = default!;
    private decimal _balance = 0;
    private string? _searchTerm;
    private System.Threading.Timer? _searchTimer;
    
    private RazorpayCheckout _razorpayCheckout = default!;
    private bool _isAdvanceModalOpen;
    private decimal _advanceAmount;


    private void ShowAdvanceModal()
    {
        _advanceAmount = 0;
        _isAdvanceModalOpen = true;
        StateHasChanged();
    }

    private void HideAdvanceModal()
    {
        _isAdvanceModalOpen = false;
        StateHasChanged();
    }

    private async Task ProcessAdvancePayment()
    {
        if (_advanceAmount <= 0) return;
        _isAdvanceModalOpen = false;
        
        // Use the first asset for now
        var occupancies = (await ApiService.GetAsync<IEnumerable<Occupancy>>("api/people/my-occupancy"))?.ToList();
        var targetAssetId = occupancies?.FirstOrDefault()?.AssetId;
        
        await InitiateRazorpay(_advanceAmount, null, targetAssetId, "Wallet Top-up");
    }

    private async Task InitiateRazorpay(decimal amount, int? invoiceId, int? assetId, string description)
    {
        try
        {
            var request = new RazorpayOrderRequest
            {
                Amount = amount,
                Currency = "INR",
                InvoiceId = invoiceId,
                AssetId = assetId,
                Description = description
            };

            var response = await ApiService.PostAsync<RazorpayOrderRequest, RazorpayOrderResponse>("api/payments/create-order", request);
            if (response != null)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                
                await _razorpayCheckout.InitializePayment(
                    response, 
                    user.Identity?.Name ?? "Resident", 
                    description, 
                    user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "", 
                    ""
                );
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, $"Payment Failed: {ex.Message}"));
        }
    }

    private async Task OnPaymentProcessed(string paymentId)
    {
        ToastService.Notify(new(ToastType.Success, $"Credits added successfully! ID: {paymentId}"));
        await LoadBalance();
        await RefreshGrid();
    }

    private async Task LoadBalance()
    {
        try 
        {
            var summary = await ApiService.GetAsync<FinanceSummary>("api/finance/summary");
            if (summary != null)
            {
                _balance = summary.TotalAdvanceCredits;
            }
        }
        catch { }
    }

    private void GoHome() => Navigation.NavigateTo("/");

    private async Task<GridDataProviderResult<AdvancePaymentHistory>> WalletDataProvider(GridDataProviderRequest<AdvancePaymentHistory> request)
    {
        try
        {
            var filters = new List<string>();
            filters.Add($"pageNumber={request.PageNumber}");
            filters.Add($"pageSize={request.PageSize}");

            var sort = request.Sorting.FirstOrDefault();
            if (sort != null)
            {
                filters.Add($"sortColumn={sort.SortString}");
                filters.Add($"sortDirection={(sort.SortDirection == SortDirection.Ascending ? "ASC" : "DESC")}");
            }

            if (!string.IsNullOrWhiteSpace(_searchTerm)) filters.Add($"searchTerm={Uri.EscapeDataString(_searchTerm)}");

            // The API handles resident-scoping via the Principal User Claims automatically.
            string url = $"api/finance/advances?{string.Join("&", filters)}";
            var response = await ApiService.GetAsync<PagedResult<AdvancePaymentHistory>>(url);

            if (response != null)
            {
                return new GridDataProviderResult<AdvancePaymentHistory> 
                { 
                    Data = response.Items, 
                    TotalCount = response.TotalCount 
                };
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, $"Failed to load wallet history: {ex.Message}"));
        }

        return new GridDataProviderResult<AdvancePaymentHistory> { Data = new List<AdvancePaymentHistory>(), TotalCount = 0 };
    }

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        _searchTimer?.Dispose();
        _searchTimer = new System.Threading.Timer(async _ => 
        {
            await InvokeAsync(async () => 
            {
                await RefreshGrid();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task RefreshGrid()
    {
        if (walletGrid != null) await walletGrid.RefreshDataAsync();
        StateHasChanged();
    }

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "paid" or "completed" or "captured" or "settled" => "bg-success-subtle-premium",
        "failed" => "bg-danger-subtle-premium",
        _ => "bg-secondary-subtle-premium"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var canAccess = await AuthService.EvaluateRuleAsync(authState.User, "ShowMenu_Wallet");
        if (!canAccess)
        {
            Navigation.NavigateTo("/");
            return;
        }

        await LoadBalance();
    }
}
