@page "/platform/billing"
@attribute [Authorize(Policy = "RequireAssociationAdmin")]
@using AssociationManager.Shared.Models
@using AssociationManager.Client.Services
@using BlazorBootstrap
@inject ApiService ApiService
@inject ToastService _toastService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="vscode-page-header border-bottom">
    <div class="d-flex align-items-center justify-content-between w-100">
        <div class="d-flex align-items-center gap-2 ps-2">
            <i class="bi bi-credit-card text-muted" style="font-size: 14px;"></i>
            <span class="fw-medium">Platform Subscription & Billing</span>
        </div>
    </div>
</div>

<div class="p-3">
    @if (_subscription != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-white h-100 p-3" style="border-top: 4px solid #0078d4 !important;">
                    <div class="small text-muted mb-1 font-heading uppercase letter-spacing-05 fw-bold" style="font-size: 10px;">Active Plan</div>
                    <div class="h4 mb-2 text-primary fw-bold">@_subscription.PlanName</div>
                    <div class="small mb-0 opacity-75">Status: <span class="badge bg-success-subtle text-success border">@_subscription.Status</span></div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-white h-100 p-3">
                    <div class="small text-muted mb-1 font-heading uppercase letter-spacing-05 fw-bold" style="font-size: 10px;">Monthly Cost</div>
                    <div class="h4 mb-1">₹@((_subscription.BasePrice + (_assetCount * _subscription.PricePerAsset)).ToString("N2"))</div>
                    <div class="small text-muted mb-0">Base: ₹@_subscription.BasePrice.ToString("N2") + (₹@_subscription.PricePerAsset.ToString("N2") × @_assetCount assets)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-white h-100 p-3">
                    <div class="small text-muted mb-1 font-heading uppercase letter-spacing-05 fw-bold" style="font-size: 10px;">Next Billing Date</div>
                    <div class="h4 mb-1">@_subscription.NextBillingDate.ToString("dd MMM yyyy")</div>
                    <div class="small text-muted mb-0">Automatic generation approx. monthly.</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-dark text-white h-100 p-3" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%) !important;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="small text-white-50 mb-1 font-heading uppercase letter-spacing-05 fw-bold" style="font-size: 10px;">Wallet Balance</div>
                            <div class="h4 mb-1">₹@_walletBalance.ToString("N2")</div>
                        </div>
                        <button class="btn btn-sm btn-outline-light py-0 px-2" style="font-size: 10px;" @onclick="() => _showTopupModal = true">
                            <i class="bi bi-plus-circle me-1"></i> TOP-UP
                        </button>
                    </div>
                    <div class="small mb-0 opacity-75 mt-auto">Used for automatic settlement.</div>
                </div>
            </div>
        </div>
    }

    <div class="vscode-explorer-header mb-2" style="background: transparent; padding-left: 0; color: var(--text-primary);">Billing History</div>
    
    <div class="border bg-white p-2 mb-4">
        <Grid @ref="invoiceGrid" TItem="PlatformInvoice"
              Class="table table-hover table-bordered table-striped compact-table"
              DataProvider="InvoicesDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="10"
              AllowSorting="true">

            <GridColumn TItem="PlatformInvoice" HeaderText="Date" PropertyName="BillingDate" SortKeySelector="item => item.BillingDate">
                @context.BillingDate.ToString("dd MMM yyyy")
            </GridColumn>

            <GridColumn TItem="PlatformInvoice" HeaderText="Plan" PropertyName="PlanName" SortKeySelector="item => item.PlanName">
                @context.PlanName
            </GridColumn>

            <GridColumn TItem="PlatformInvoice" HeaderText="Amount" PropertyName="Amount" SortKeySelector="item => item.Amount">
                ₹@context.Amount.ToString("N2")
            </GridColumn>

            <GridColumn TItem="PlatformInvoice" HeaderText="Due Date" PropertyName="DueDate" SortKeySelector="item => item.DueDate">
                @context.DueDate.ToString("dd MMM yyyy")
            </GridColumn>

            <GridColumn TItem="PlatformInvoice" HeaderText="Status" PropertyName="Status" SortKeySelector="item => item.Status">
                <span class="badge @(context.Status == "Paid" ? "bg-success-subtle text-success" : (context.Status == "Unpaid" ? "bg-warning-subtle text-warning" : "bg-danger-subtle text-danger")) border">
                    @context.Status
                </span>
            </GridColumn>

            <GridColumn TItem="PlatformInvoice" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                @if (context.Status == "Unpaid")
                {
                    <div class="d-flex justify-content-end gap-2">
                        @if (_walletBalance >= context.Amount)
                        {
                            <button class="btn btn-sm btn-outline-success" @onclick="() => DirectPayWithWallet(context)" disabled="@_isProcessing">
                                <i class="bi bi-patch-check me-1"></i> Pay with Advance
                            </button>
                        }
                        <button class="btn btn-sm btn-vscode" @onclick="() => InitiatePayment(context)">
                            <i class="bi bi-wallet2 me-1"></i> Pay Now
                        </button>
                    </div>
                }
            </GridColumn>
        </Grid>
    </div>

    <div class="vscode-explorer-header mb-2" style="background: transparent; padding-left: 0; color: var(--text-primary);">Wallet Transaction History</div>
    <div class="border bg-white p-2">
        <Grid @ref="walletGrid" TItem="PlatformAdvanceHistory"
              Class="table table-hover table-bordered table-striped compact-table"
              DataProvider="WalletDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="5"
              AllowSorting="true">

            <GridColumn TItem="PlatformAdvanceHistory" HeaderText="Date" PropertyName="Date" SortKeySelector="item => item.Date">
                @context.Date.ToString("dd MMM yyyy HH:mm")
            </GridColumn>

            <GridColumn TItem="PlatformAdvanceHistory" HeaderText="Description" PropertyName="Description">
                @context.Description
            </GridColumn>

            <GridColumn TItem="PlatformAdvanceHistory" HeaderText="Amount" PropertyName="Amount" Class="text-end" HeaderClass="text-end" SortKeySelector="item => item.Amount">
                @if (context.Amount >= 0)
                {
                    <span class="text-success fw-bold">+₹@context.Amount.ToString("N2")</span>
                }
                else
                {
                    <span class="text-danger fw-bold">-₹@Math.Abs(context.Amount).ToString("N2")</span>
                }
            </GridColumn>

            <GridColumn TItem="PlatformAdvanceHistory" HeaderText="Reference" PropertyName="TransactionRef">
                <code class="small text-muted">@context.TransactionRef</code>
            </GridColumn>

            <GridColumn TItem="PlatformAdvanceHistory" HeaderText="Status" PropertyName="Status">
                @context.Status
            </GridColumn>
        </Grid>
    </div>
</div>

@if (_showTopupModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Top-up Platform Wallet</h6>
                    <button type="button" class="btn-close small" @onclick="() => _showTopupModal = false"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Amount to Add (₹)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white">₹</span>
                            <input type="number" class="form-control" @bind="_topupAmount" placeholder="Enter amount" />
                        </div>
                        <div class="mt-2 text-muted" style="font-size: 11px;">
                            <i class="bi bi-info-circle me-1"></i>
                            Credits will be added instantly to your association's wallet after successful payment.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-sm btn-vscode-secondary" @onclick="() => _showTopupModal = false" disabled="@_isProcessing">Cancel</button>
                    <button class="btn btn-sm btn-vscode px-4" @onclick="InitiateTopup" disabled="@(_isProcessing || _topupAmount <= 0)">
                        <i class="bi bi-plus-circle me-1"></i> Proceed to Pay
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showPaymentModal && _selectedInvoice != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h6 class="modal-title fw-bold">Platform Invoice Payment</h6>
                    <button type="button" class="btn-close small" @onclick="() => _showPaymentModal = false"></button>
                </div>
                <div class="modal-body py-4">
                    @if (_isProcessing && _billingAccount == null)
                    {
                        <div class="text-center py-3">
                            <div class="spinner-border spinner-border-sm text-muted mb-2"></div>
                            <p class="text-muted small">Preparing secure checkout...</p>
                        </div>
                    }
                    else
                    {
                        <div class="text-center mb-4">
                            <div class="mb-3 text-primary">
                                <i class="bi bi-shield-check" style="font-size: 48px;"></i>
                            </div>
                            <h5 class="fw-bold mb-1">Invoice Amount: ₹@_selectedInvoice.Amount.ToString("N2")</h5>
                            <p class="text-muted small">You will be redirected to our secure payment gateway to complete the transaction.</p>
                        </div>

                        <div class="bg-light p-3 rounded-3 border mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small uppercase fw-bold" style="font-size: 10px;">Billing Period</span>
                                <span class="small fw-medium">@_selectedInvoice.BillingDate.ToString("MMMM yyyy")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small uppercase fw-bold" style="font-size: 10px;">Subscription Plan</span>
                                <span class="small fw-medium">@_selectedInvoice.PlanName</span>
                            </div>
                        </div>
                        
                        <div class="p-2 bg-info-subtle border border-info-subtle rounded small text-start">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            Your payment will be processed securely via Razorpay.
                        </div>
                    }
                </div>
                <div class="modal-footer border-0 pt-3 d-flex justify-content-between align-items-center">
                    <div class="text-start">
                        <div class="text-muted extra-small uppercase fw-bold" style="font-size: 9px;">Your Wallet Balance</div>
                        <div class="small fw-bold @(_walletBalance >= _selectedInvoice.Amount ? "text-success" : "text-danger")">₹@_walletBalance.ToString("N2")</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-vscode-secondary" @onclick="() => _showPaymentModal = false" disabled="@_isProcessing">Cancel</button>
                        
                        @if (_walletBalance >= _selectedInvoice.Amount)
                        {
                            <button class="btn btn-sm btn-success px-3" @onclick="PayWithWallet" disabled="@_isProcessing">
                                <i class="bi bi-wallet2 me-1"></i> Pay from Wallet
                            </button>
                        }

                        <button class="btn btn-sm btn-vscode px-4" @onclick="InitiateRazorpayPayment" disabled="@_isProcessing">
                            @if (_isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            <i class="bi bi-lock-fill me-1"></i> Proceed to Pay
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .font-heading { font-family: 'Outfit', sans-serif; }
    .uppercase { text-transform: uppercase; }
    .letter-spacing-05 { letter-spacing: 0.05em; }
    .bg-success-subtle { background-color: #f0fdf4 !important; }
    .bg-warning-subtle { background-color: #fffbeb !important; }
    .bg-danger-subtle { background-color: #fef2f2 !important; }
    .badge { font-weight: 500; font-size: 10px; text-transform: uppercase; }
</style>

@code {
    private AssociationSubscription? _subscription;
    private List<PlatformInvoice>? _invoices;
    private Grid<PlatformInvoice> invoiceGrid = default!;
    private Grid<PlatformAdvanceHistory> walletGrid = default!;
    private int _assetCount;
    
    private decimal _walletBalance;
    private bool _showTopupModal;
    private decimal _topupAmount;
    private bool _isTopup;

    private bool _showPaymentModal;
    private PlatformInvoice? _selectedInvoice;
    private PlatformAccount? _billingAccount;
    private bool _isProcessing;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _subscription = await ApiService.GetAsync<AssociationSubscription>("api/subscription/current");
        _invoices = await ApiService.GetAsync<List<PlatformInvoice>>("api/platformbilling/my-invoices");
        _walletBalance = await ApiService.GetAsync<decimal>("api/platformbilling/wallet-balance");
        
        var assets = await ApiService.GetAsync<List<Asset>>("api/assets");
        _assetCount = assets?.Count ?? 0;
    }

    private async Task<GridDataProviderResult<PlatformInvoice>> InvoicesDataProvider(GridDataProviderRequest<PlatformInvoice> request)
    {
        if (_invoices == null) await LoadData();
        return request.ApplyTo(_invoices ?? new List<PlatformInvoice>());
    }

    private async Task<GridDataProviderResult<PlatformAdvanceHistory>> WalletDataProvider(GridDataProviderRequest<PlatformAdvanceHistory> request)
    {
        var result = await ApiService.GetAsync<PagedResult<PlatformAdvanceHistory>>($"api/platformbilling/wallet-history?pageNumber={request.PageNumber}&pageSize={request.PageSize}");
        return new GridDataProviderResult<PlatformAdvanceHistory> { Data = result?.Items ?? new List<PlatformAdvanceHistory>(), TotalCount = result?.TotalCount ?? 0 };
    }

    private async Task InitiatePayment(PlatformInvoice invoice)
    {
        _selectedInvoice = invoice;
        _isTopup = false;
        _showPaymentModal = true;
        _billingAccount = null;
        
        try
        {
            var response = await ApiService.GetAsync<PlatformAccount>("api/platformbilling/billing-account");
            if (response == null)
            {
                _toastService.Notify(new(ToastType.Warning, "Billing account not configured for this association. Please contact support."));
                _showPaymentModal = false;
                return;
            }
            _billingAccount = response;
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Failed to load bank details: {ex.Message}"));
            _showPaymentModal = false;
        }
    }

    private async Task InitiateTopup()
    {
        if (_topupAmount <= 0) return;
        _isProcessing = true;
        _isTopup = true;

        try
        {
            var orderResponse = await ApiService.PostAsync<decimal, RazorpayOrderResponse>("api/platformbilling/create-topup-order", _topupAmount);
            if (orderResponse != null) await OpenRazorpay(orderResponse, "Platform Wallet Top-up");
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Top-up initiation failed: {ex.Message}"));
            _isProcessing = false;
        }
    }

    private async Task InitiateRazorpayPayment()
    {
        if (_selectedInvoice == null || _isProcessing) return;
        _isProcessing = true;
        _isTopup = false;

        try
        {
            var orderResponse = await ApiService.PostAsync<object, RazorpayOrderResponse>($"api/platformbilling/create-order/{_selectedInvoice.PlatformInvoiceId}", new { });
            if (orderResponse != null) await OpenRazorpay(orderResponse, $"Platform Fee - {_selectedInvoice.BillingDate:MMM yyyy}");
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Payment initialization failed: {ex.Message}"));
            _isProcessing = false;
        }
    }

    private async Task OpenRazorpay(RazorpayOrderResponse orderResponse, string description)
    {
        if (orderResponse == null) throw new Exception("Failed to create payment order.");

        var options = new
        {
            key = orderResponse.KeyId,
            amount = orderResponse.Amount,
            currency = orderResponse.Currency,
            name = "Association Manager",
            description = description,
            order_id = orderResponse.OrderId,
            prefill = new
            {
                name = "", 
                email = "" 
            },
            theme = new { color = "#0078d4" }
        };

        await JSRuntime.InvokeVoidAsync("razorpayInterop.openCheckout", options, DotNetObjectReference.Create(this));
    }

    private async Task DirectPayWithWallet(PlatformInvoice invoice)
    {
        if (invoice == null || _isProcessing) return;
        _selectedInvoice = invoice;
        await PayWithWallet();
    }

    private async Task PayWithWallet()
    {
        if (_selectedInvoice == null || _isProcessing) return;
        _isProcessing = true;

        try
        {
            var success = await ApiService.PostAsync<object, bool>($"api/platformbilling/pay-with-wallet/{_selectedInvoice.PlatformInvoiceId}", new { });
            if (success)
            {
                _toastService.Notify(new(ToastType.Success, "Payment successful! Your wallet balance has been deducted."));
                await FinalizeSuccess();
            }
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Wallet payment failed: {ex.Message}"));
            _isProcessing = false;
        }
    }

    private async Task FinalizeSuccess()
    {
        _showPaymentModal = false;
        _showTopupModal = false;
        _invoices = null;
        await LoadData();
        if (invoiceGrid != null) await invoiceGrid.RefreshDataAsync();
        if (walletGrid != null) await walletGrid.RefreshDataAsync();
    }

    [JSInvokable]
    public async Task HandlePaymentSuccess(RazorpayVerifyResponse response)
    {
        try
        {
            if (_isTopup)
            {
                var verifyRequest = new RazorpayVerifyRequest
                {
                    RazorpayOrderId = response.razorpay_order_id,
                    RazorpayPaymentId = response.razorpay_payment_id,
                    RazorpaySignature = response.razorpay_signature,
                    Amount = _topupAmount
                };
                var success = await ApiService.PostAsync<RazorpayVerifyRequest, bool>("api/platformbilling/verify-topup-payment", verifyRequest);
                if (success)
                {
                    _toastService.Notify(new(ToastType.Success, "Top-up successful! Credits added to your wallet."));
                    await FinalizeSuccess();
                }
            }
            else
            {
                var verifyRequest = new RazorpayVerifyRequest
                {
                    InvoiceId = _selectedInvoice?.PlatformInvoiceId,
                    RazorpayOrderId = response.razorpay_order_id,
                    RazorpayPaymentId = response.razorpay_payment_id,
                    RazorpaySignature = response.razorpay_signature
                };

                var success = await ApiService.PostAsync<RazorpayVerifyRequest, bool>("api/platformbilling/verify-payment", verifyRequest);
                if (success)
                {
                    _toastService.Notify(new(ToastType.Success, "Payment successful! Your subscription is updated."));
                    await FinalizeSuccess();
                }
            }
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Error: {ex.Message}"));
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnPaymentDismiss()
    {
        _isProcessing = false;
        _toastService.Notify(new(ToastType.Info, "Payment cancelled."));
        StateHasChanged();
    }

    public void Dispose()
    {
    }

    public class RazorpayVerifyResponse
    {
        public string razorpay_payment_id { get; set; } = string.Empty;
        public string razorpay_order_id { get; set; } = string.Empty;
        public string razorpay_signature { get; set; } = string.Empty;
    }
}
