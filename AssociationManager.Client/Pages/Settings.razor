@page "/settings"
@attribute [Authorize(Policy = "RequireAssociationAdmin")]
@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums
@using AssociationManager.Client.Services
@inject ApiService ApiService
@inject ToastService _toastService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="vscode-page-header border-bottom">
    <div class="d-flex align-items-center gap-2">
        <i class="bi bi-gear-fill text-muted" style="font-size: 14px;"></i>
        <span class="fw-medium">
            @(_scope == "tenant" ? "Platform Settings" : "Association Profile")
        </span>
    </div>
</div>

<div class="p-3">
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border spinner-border-sm text-muted mb-2" role="status"></div>
            <p class="text-muted small">Loading configuration...</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-md-8">
                <div class="compact-card mb-3">
                    <div class="fw-bold mb-3 small text-uppercase text-muted border-bottom pb-2">
                        @(_scope == "tenant" ? "General Information" : "Identity & Branding")
                    </div>
                    
                    <div class="compact-form">
                        <div class="mb-3">
                            <label>Display Name</label>
                            <input @bind="_displayName" class="form-control" />
                        </div>
                        
                        <div class="mb-3">
                            <label>Description</label>
                            <textarea @bind="_description" class="form-control" rows="3"></textarea>
                        </div>

                        @if (_scope == "association")
                        {
                            <div class="mb-3">
                                <label>Registration ID / License</label>
                                <input class="form-control" placeholder="Optional..." />
                            </div>
                        }
                    </div>
                </div>

                <div class="compact-card">
                    <div class="fw-bold mb-3 small text-uppercase text-muted border-bottom pb-2">Preferences</div>
                    <div class="compact-form">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label">Enable Email Notifications</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label">Enable Real-time Updates</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="compact-card mb-3">
                    <div class="fw-bold mb-3 small text-uppercase text-muted border-bottom pb-2">Status</div>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">Environment</span>
                            <span class="badge bg-success-subtle text-success border">Production</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">Access Level</span>
                            <span class="badge bg-secondary-subtle text-secondary border">Admin</span>
                        </div>
                    </div>
                </div>
                
                <div class="d-grid">
                    <button class="btn-vscode py-2" @onclick="HandleSave">
                        <i class="bi bi-save me-2"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _scope = "tenant";
    private bool _loading = true;
    private string _displayName = "";
    private string _description = "";

    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadSettings();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ParseQueryParameters())
        {
            await LoadSettings();
        }
    }

    private bool ParseQueryParameters()
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query;
        var newScope = query.Contains("scope=association") ? "association" : "tenant";
        
        if (newScope != _scope)
        {
            _scope = newScope;
            return true;
        }
        return false;
    }

    private async Task LoadSettings()
    {
        _loading = true;
        try 
        {
            if (_scope == "association")
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var aid = authState.User.FindFirst("AssociationId")?.Value;
                if (int.TryParse(aid, out int associationId) && associationId != 0)
                {
                    var assoc = await ApiService.GetAsync<Association>($"api/associations/{associationId}");
                    if (assoc != null)
                    {
                        _displayName = assoc.Name;
                        _description = assoc.Description ?? "";
                    }
                }
            }
            else
            {
                _displayName = "Association Manager Platform";
                _description = "Central management portal for the entire portfolio.";
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleSave()
    {
        // Placeholder for real save logic
        await Task.Delay(500); 
        _toastService.Notify(new(ToastType.Success, "Configuration updated."));
    }
}
