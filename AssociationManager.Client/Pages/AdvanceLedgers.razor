@page "/finance/advances"
@using AssociationManager.Shared.Models
@using AssociationManager.Client.Services
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject BlazorBootstrap.ToastService ToastService
@attribute [Authorize(Policy = "RequireFinanceManager")]

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1 fw-bold text-dark">Advance Payment Ledgers</h4>
            <div class="text-muted small">
                <i class="bi bi-info-circle me-1"></i> Tracking all pre-paid funds held in resident wallets.
            </div>
        </div>
        <div class="d-flex gap-2">
             <button class="btn btn-outline-secondary btn-sm" @onclick="LoadData" disabled="@_isLoading">
                <i class="bi bi-arrow-clockwise me-1"></i> Refresh
            </button>
            <div class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 p-2 px-3">
                Total Advance Pool: ₹@(_advances?.Sum(a => a.Amount).ToString("N0") ?? "0")
            </div>
        </div>
    </div>

    <div class="premium-card bg-white border shadow-sm">
        <div class="p-0">
            @if (_isLoading)
            {
                <div class="p-5 text-center">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (_advances == null || !_advances.Any())
            {
                <div class="p-5 text-center text-muted">
                    No advance payments recorded in this association.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" style="font-size: 13px;">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Date</th>
                                <th>Resident</th>
                                <th>Unit / Asset</th>
                                <th>Transaction Ref</th>
                                <th class="text-end pe-4">Amount (INR)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var adv in _advances)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-medium">@adv.CreatedDate.ToString("dd MMM yyyy")</div>
                                        <div class="text-muted opacity-75" style="font-size: 11px;">@adv.CreatedDate.ToString("hh:mm tt")</div>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">@adv.ResidentName</div>
                                        <div class="text-muted small">@adv.ResidentEmail</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border p-2">
                                            <i class="bi bi-house-door me-1"></i> @adv.UnitName
                                        </span>
                                    </td>
                                    <td>
                                        <code class="text-primary smaller">@adv.GatewayReference</code>
                                        @if (!string.IsNullOrEmpty(adv.Notes))
                                        {
                                            <div class="text-muted smaller mt-1">Note: @adv.Notes</div>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="fw-bold fs-6">₹@adv.Amount.ToString("N0")</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .smaller { font-size: 0.85em; }
</style>

@code {
    private List<AdvancePaymentHistory>? _advances;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var history = await ApiService.GetAsync<IEnumerable<AdvancePaymentHistory>>("api/finance/advances");
            _advances = history?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(BlazorBootstrap.ToastType.Danger, $"Error loading ledgers: {ex.Message}"));
        }
        finally
        {
            _isLoading = false;
        }
    }
}
