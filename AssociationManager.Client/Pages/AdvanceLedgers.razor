@page "/finance/advances"
@using AssociationManager.Shared.Models
@using AssociationManager.Client.Services
@using Microsoft.AspNetCore.Authorization
@inject ApiService ApiService
@inject BlazorBootstrap.ToastService ToastService
@attribute [Authorize(Policy = "RequireResident")]

<div class="premium-page-header border-bottom px-4 py-3 mb-0">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="premium-page-title mb-0" style="font-size: 1.25rem;">
                <i class="bi bi-safe2 me-2"></i> Advance Payment Ledgers
            </h1>
            <div class="text-muted extra-small opacity-75 mt-1">
                Auditing all pre-paid funds and wallet top-ups across the association.
            </div>
        </div>
        <div class="header-right">
            <div class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 p-2 px-3">
                <i class="bi bi-piggy-bank me-1"></i> Total Advance Pool: ₹@(_totalAdvancePool.ToString("N0"))
            </div>
        </div>
    </div>
</div>

<div class="vscode-content custom-scrollbar p-4">
    <div class="compact-card shadow-sm border-0">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="m-0 fw-semibold text-vscode-accent">Audit Trail</h6>
            <div class="d-flex gap-2">
                <div class="input-group input-group-sm" style="width: 300px;">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search py-1"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search Resident or Unit..." 
                           @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyUp" />
                </div>
                <select class="form-select form-select-sm" style="width: 140px;" @bind="_statusFilter" @bind:after="OnFilterChanged">
                    <option value="">All Status</option>
                    <option value="Paid">Paid</option>
                    <option value="Completed">Completed</option>
                    <option value="Failed">Failed</option>
                </select>
                <button class="btn btn-sm btn-outline-secondary px-3" @onclick="RefreshGrid">
                    <i class="bi bi-arrow-clockwise"></i>
                </button>
            </div>
        </div>

        <Grid @ref="advanceGrid" TItem="AdvancePaymentHistory"
              Class="table table-hover table-bordered table-striped compact-table align-middle"
              DataProvider="AdvancesDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="10"
              AllowSorting="true">

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Date" PropertyName="Date" SortKeySelector="item => item.Date" HeaderClass="ps-3" Class="ps-3">
                <div class="d-flex flex-column">
                    <span class="fw-semibold text-dark">@context.Date.ToString("dd MMM yyyy")</span>
                    <span class="text-muted extra-small opacity-75">@context.Date.ToString("t")</span>
                </div>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Resident" PropertyName="ResidentName" SortKeySelector="item => item.ResidentName">
                <div class="d-flex align-items-center gap-2">
                    <div class="avatar-sm rounded-circle d-flex align-items-center justify-content-center @(context.ResidentName == "System" ? "bg-secondary-subtle" : "bg-primary-subtle")" style="width: 28px; height: 28px;">
                        @if (context.ResidentName == "System")
                        {
                            <i class="bi bi-cpu text-secondary" style="font-size: 14px;"></i>
                        }
                        else
                        {
                            <i class="bi bi-person-fill text-primary" style="font-size: 14px;"></i>
                        }
                    </div>
                    <span class="fw-bold text-dark" style="font-size: 0.85rem;">@context.ResidentName</span>
                </div>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Unit" PropertyName="UnitName" SortKeySelector="item => item.UnitName">
                <span class="premium-unit-badge">@context.UnitName</span>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Reference" PropertyName="ReferenceId">
                @{
                    bool isSettlement = context.ReferenceId?.Contains("Advance used to pay") == true;
                }
                <div class="d-flex align-items-center gap-2">
                    @if (isSettlement)
                    {
                        <div class="ref-icon-circle bg-warning-subtle text-warning">
                            <i class="bi bi-receipt-cutoff"></i>
                        </div>
                        <span class="small text-muted text-truncate" style="max-width: 200px;" title="@context.ReferenceId">
                            @context.ReferenceId
                        </span>
                    }
                    else
                    {
                        <div class="ref-icon-circle bg-info-subtle text-info">
                            <i class="bi bi-credit-card"></i>
                        </div>
                        <code class="text-primary extra-small fw-semibold">@context.ReferenceId</code>
                    }
                </div>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Status" PropertyName="Status" SortKeySelector="item => item.Status">
                <span class="modern-badge @GetStatusClass(context.Status)">@context.Status</span>
            </GridColumn>

            <GridColumn TItem="AdvancePaymentHistory" HeaderText="Amount" PropertyName="Amount" SortKeySelector="item => item.Amount" HeaderClass="text-end pe-3" Class="text-end pe-3">
                @{
                    bool isPositive = context.Amount >= 0;
                }
                <div class="d-flex flex-column align-items-end">
                    <span class="fw-bold @(isPositive ? "text-success" : "text-danger")" style="font-size: 1rem;">
                        @(isPositive ? "+" : "")₹@context.Amount.ToString("N0")
                    </span>
                    @if (!isPositive)
                    {
                        <span class="extra-small opacity-50 text-danger" style="margin-top: -4px;">SETTLEMENT</span>
                    }
                    else
                    {
                        <span class="extra-small opacity-50 text-success" style="margin-top: -4px;">TOP-UP</span>
                    }
                </div>
            </GridColumn>
        </Grid>

    </div>
</div>

@code {
    private Grid<AdvancePaymentHistory> advanceGrid = default!;
    private decimal _totalAdvancePool = 0;
    private string? _searchTerm;
    private string? _statusFilter;
    private System.Threading.Timer? _searchTimer;

    private async Task<GridDataProviderResult<AdvancePaymentHistory>> AdvancesDataProvider(GridDataProviderRequest<AdvancePaymentHistory> request)
    {
        try
        {
            var filters = new List<string>();
            filters.Add($"pageNumber={request.PageNumber}");
            filters.Add($"pageSize={request.PageSize}");

            var sort = request.Sorting.FirstOrDefault();
            if (sort != null)
            {
                filters.Add($"sortColumn={sort.SortString}");
                filters.Add($"sortDirection={(sort.SortDirection == SortDirection.Ascending ? "ASC" : "DESC")}");
            }

            if (!string.IsNullOrWhiteSpace(_searchTerm)) filters.Add($"searchTerm={Uri.EscapeDataString(_searchTerm)}");
            if (!string.IsNullOrWhiteSpace(_statusFilter)) filters.Add($"status={_statusFilter}");

            string url = $"api/finance/advances?{string.Join("&", filters)}";
            var response = await ApiService.GetAsync<PagedResult<AdvancePaymentHistory>>(url);

            if (response != null)
            {
                // Note: In a real app we might get the total pool from a separate summary API or response header
                // For now we'll maintain state if it's the first load
                if (request.PageNumber == 1 && string.IsNullOrEmpty(_searchTerm) && string.IsNullOrEmpty(_statusFilter))
                {
                    // This is a simplified calculation, ideally we use api/finance/summary
                }

                return new GridDataProviderResult<AdvancePaymentHistory> 
                { 
                    Data = response.Items, 
                    TotalCount = response.TotalCount 
                };
            }
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, $"Failed to load ledgers: {ex.Message}"));
        }

        return new GridDataProviderResult<AdvancePaymentHistory> { Data = new List<AdvancePaymentHistory>(), TotalCount = 0 };
    }

    private void HandleSearchKeyUp(KeyboardEventArgs e)
    {
        _searchTimer?.Dispose();
        _searchTimer = new System.Threading.Timer(async _ => 
        {
            await InvokeAsync(async () => 
            {
                await RefreshGrid();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private async Task OnFilterChanged() => await RefreshGrid();

    private async Task RefreshGrid()
    {
        if (advanceGrid != null) await advanceGrid.RefreshDataAsync();
        StateHasChanged();
    }

    private string GetStatusClass(string status) => status?.ToLower() switch
    {
        "paid" or "completed" or "captured" => "bg-success-subtle-premium",
        "settled" => "bg-secondary-subtle-premium",
        "failed" => "bg-danger-subtle-premium",
        _ => "bg-secondary-subtle-premium"
    };

    protected override async Task OnInitializedAsync()
    {
        // Fetch summary for the header badge
        try 
        {
            var summary = await ApiService.GetAsync<dynamic>("api/finance/summary");
            if (summary != null)
            {
                _totalAdvancePool = summary.totalAdvanceCredits ?? 0;
            }
        }
        catch { /* Fallback to 0 */ }
    }
}
