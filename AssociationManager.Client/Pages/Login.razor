@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@using Microsoft.Extensions.Configuration
@using AssociationManager.Client.Services
@inject IConfiguration Configuration
@inject AuthService AuthService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthProvider
@using AssociationManager.Shared.Enums

<div class="vh-100 d-flex align-items-center justify-content-center bg-login">
    <div class="login-mesh"></div>
    
    <div class="glass-panel text-center shadow-lg animate-scale-in" style="max-width: 440px; width: 90%; position: relative; z-index: 10;">
        <div class="mb-5">
            <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-4 mb-4" 
                 style="background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2);">
                <i class="bi bi-shield-lock-fill text-primary fs-2"></i>
            </div>
            <h1 class="fw-bold mb-2">AssociationManager</h1>
            <p class="text-secondary small">Authenticate to access your organization dashboard</p>
        </div>

        <div class="py-4 position-relative" style="min-height: 100px;">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger border-0 rounded-4 mb-4 small animate-fade-in" style="background: rgba(239, 68, 68, 0.1); color: #f87171;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    @_errorMessage
                </div>
            }

            <div class="d-flex flex-column gap-3 justify-content-center">
                <button class="btn btn-primary rounded-pill py-2 px-4 shadow-sm animate-scale-in" @onclick="HandleMSALLogin">
                    <i class="bi bi-microsoft me-2"></i> Continue with Microsoft
                </button>
                
                <p class="mt-3 small text-muted">Supports Google, Microsoft & Social Logins via Entra</p>
            </div>
        </div>

        <div class="mt-5 border-top border-dark border-opacity-5 pt-4">
            <div class="d-flex justify-content-center gap-3 small">
                <a href="#" class="text-secondary text-decoration-none hover-white">Terms</a>
                <span class="text-muted opacity-25">•</span>
                <a href="#" class="text-secondary text-decoration-none hover-white">Privacy</a>
                <span class="text-muted opacity-25">•</span>
                <a href="#" class="text-secondary text-decoration-none hover-white">Support</a>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-login { background: #f8fafc; overflow: hidden; position: relative; }
    .login-mesh {
        position: absolute; inset: 0;
        background-image: 
            radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.08) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(168, 85, 247, 0.08) 0px, transparent 50%);
        opacity: 0.8;
    }
    .glass-panel {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 1);
        padding: 40px;
    }
    .animate-scale-in { animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes scaleIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    .hover-white:hover { color: var(--vscode-accent) !important; }
    .btn-skeleton { width: 200px; height: 44px; border-radius: 22px; background: rgba(0,0,0,0.05); }
</style>

@code {
    private string? _errorMessage;

    private async Task HandleMSALLogin()
    {
        _errorMessage = null;
        StateHasChanged();

        try 
        {
            var clientId = Configuration["AzureAd:ClientId"];
            var authority = Configuration["AzureAd:Authority"];
            var scope = "api://af161f39-c71a-42ae-873f-9367d85144f8/access_as_user";

            // Use the JS helper to perform login and get the access token
            var token = await JS.InvokeAsync<string>("msalHelper.login", clientId, authority, scope);
            
            if (!string.IsNullOrEmpty(token))
            {
                var result = await AuthService.LoginWithB2C(token);
                if (result?.Success == true)
                {
                    await RedirectAfterLogin();
                }
                else
                {
                    _errorMessage = result?.Message ?? "Backend authentication failed.";
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Login failed: {ex.Message}";
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await RedirectAfterLogin();
            return;
        }
    }

    private async Task RedirectAfterLogin()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        var allRoleClaims = user.FindAll(System.Security.Claims.ClaimTypes.Role)
            .Select(c => c.Value).ToList()
            .Concat(user.FindAll("Role").Select(c => c.Value))
            .Concat(user.FindAll("http://schemas.microsoft.com/ws/2008/06/identity/claims/role").Select(c => c.Value))
            .ToList();

        var individualRoles = allRoleClaims
            .SelectMany(r => r.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            .ToList();

        bool isSystemAdmin = individualRoles.Any(r => r == AppRole.SystemAdmin || r == AppRole.PlatformAdmin);
        bool hasAssociationRole = individualRoles.Any(AppRole.IsAssociationRole);
        
        if (isSystemAdmin || hasAssociationRole)
        {
            var assocIdClaim = user.FindFirst("AssociationId")?.Value;
            if (string.IsNullOrEmpty(assocIdClaim) || assocIdClaim == "0")
            {
                Navigation.NavigateTo("/context-selection");
            }
            else
            {
                Navigation.NavigateTo("/");
            }
        }
        else
        {
            // If they have corporate roles but no association roles, they should use the Corporate portal
            if (individualRoles.Any(AppRole.IsCorporateRole))
            {
                _errorMessage = "Access Denied: This portal is for Association/Resident tasks. Please use the Corporate Portal for administrative overhead.";
            }
            else
            {
                // Truly pending or no access at all
                Navigation.NavigateTo("/");
            }
            
            StateHasChanged();
        }
    }



    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Check if we just returned from an MSAL Redirect login
            try 
            {
                var clientId = Configuration["AzureAd:ClientId"];
                var authority = Configuration["AzureAd:Authority"];
                var scope = "api://af161f39-c71a-42ae-873f-9367d85144f8/access_as_user";

                var token = await JS.InvokeAsync<string>("msalHelper.handleRedirect", clientId, authority, scope);
                
                if (!string.IsNullOrEmpty(token))
                {
                    var result = await AuthService.LoginWithB2C(token);
                    if (result?.Success == true)
                    {
                        await RedirectAfterLogin();
                    }
                    else
                    {
                        _errorMessage = result?.Message ?? "Backend authentication failed.";
                        StateHasChanged();
                    }
                }
            }
            catch (Exception ex)
            {
                _errorMessage = $"Redirect handle failed: {ex.Message}";
                StateHasChanged();
            }

            // Normal auth check
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated == true)
            {
                await RedirectAfterLogin();
            }
        }
    }
}
