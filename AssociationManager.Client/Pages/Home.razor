@page "/"
@using AssociationManager.Client.Services
@using AssociationManager.Client.Components.Dashboard
@using AssociationManager.Client.Components.Base
@using AssociationManager.Shared.Interfaces
@inherits StatefulComponentBase
@inject LayoutStateService LayoutState
@inject DashboardStateService DashboardService
@inject AuthenticationStateProvider AuthStateProvider
@inject ITenantContext TenantContext
@inject IRuleEngineService RuleEngine
@inject BlazorBootstrap.ToastService ToastService

<RazorpayCheckout @ref="_razorpayCheckout" OnPaymentSuccess="OnPaymentProcessed" OnPaymentFailed="OnPaymentFailed" />

<AuthorizeView Context="authContext">
    <Authorized>
        @if (_isInitialLoading)
        {
            <div class="d-flex flex-column align-items-center justify-content-center vh-100 text-muted">
                <div class="spinner-border text-primary mb-3" role="status"></div>
                <div class="fw-bold h5">Preparing Dashboard...</div>
                <div class="small opacity-50">Syncing association context and rules</div>
            </div>
        }
        else
        {
            var assocIdClaim = authContext.User.FindFirst("AssociationId")?.Value;
            bool hasAssociation = !string.IsNullOrEmpty(assocIdClaim) && assocIdClaim != "0";
            bool isSystemAdmin = _isSystemAdmin;
            bool isPending = !isSystemAdmin && !hasAssociation;

            @if (!hasAssociation && !isSystemAdmin)
            {
                @if (isPending)
                {
                    <PendingDashboard UserEmail="@authContext.User.FindFirst("email")?.Value" />
                }
                else
                {
                    { Navigation.NavigateTo("/context-selection"); }
                    <div class="d-flex flex-column align-items-center justify-content-center vh-100 text-muted">
                        <div class="spinner-border spinner-border-sm mb-3" role="status"></div>
                        <span>Redirecting to context selection...</span>
                    </div>
                }
            }
            else
            {
                @if (_isResident)
                {
                    <ResidentDashboard @ref="_residentDashboard"
                                       OnTopUpClicked="ShowAdvanceModal" 
                                       OnPayNow="OnInvoicePayNow" 
                                       OnPayWithAdvance="OnPayWithAdvance" />

                    @if (_isAdvanceModalOpen)
                    {
                        <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 shadow">
                                    <div class="premium-card-header">
                                        <h6 class="premium-card-title"><i class="bi bi-plus-circle-fill me-2"></i>Pay Advance / Top Up Wallet</h6>
                                        <button type="button" class="btn-close" @onclick="HideAdvanceModal"></button>
                                    </div>
                                    <div class="p-4">
                                        <p class="text-muted small mb-3">Add money to your unit's credit balance. This will be automatically applied to future invoices.</p>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold small">Amount (₹)</label>
                                            <div class="input-group">
                                                <span class="input-group-text">₹</span>
                                                <input type="number" class="form-control" @bind="_advanceAmount" placeholder="Enter amount" />
                                            </div>
                                        </div>
                                        <div class="d-grid mt-4">
                                            <button class="btn btn-vscode py-2 fw-bold" @onclick="ProcessAdvancePayment" disabled="@(_advanceAmount <= 0)">
                                                Proceed to Razorpay Payment
                                            </button>
                                        </div>
                                        <div class="mt-3 text-center">
                                            <button class="btn btn-link btn-sm text-muted text-decoration-none" @onclick="HideAdvanceModal">Cancel</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <AdminDashboard />
                }
            }
        }
    </Authorized>
    <NotAuthorized>
        @{ Navigation.NavigateTo("/login"); }
    </NotAuthorized>
</AuthorizeView>

@code {
    [Inject] private ApiService ApiService { get; set; } = default!;

    private bool _isResident;
    private bool _isSystemAdmin;
    private ResidentDashboard? _residentDashboard;
    
    private int? _currentlyPayingInvoiceId;
    private RazorpayCheckout _razorpayCheckout = default!;
    private bool _isAdvanceModalOpen;
    private decimal _advanceAmount;
    private bool _isInitialLoading = true;

    protected override async Task OnInitializedAsync()
    {
        RegisterStateService(DashboardService);
        LayoutState.SetPageMetadata("Dashboard", "bi-grid-1x2-fill");
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var roles = user.Claims.Where(c => c.Type == "role" || c.Type == System.Security.Claims.ClaimTypes.Role)
                               .Select(c => c.Value);

        var securityContext = new SecurityContext
        {
            UserRole = string.Join(",", roles),
            UserLevel = AppRole.GetMaxLevel(user.Claims),
            AssociationId = TenantContext.AssociationId,
            AssociationStatus = TenantContext.AssociationStatus
        };

        bool isManagement = await RuleEngine.EvaluateRuleAsync("RequireManagement", securityContext);
        _isResident = await RuleEngine.EvaluateRuleAsync("IsResident", securityContext);
        _isSystemAdmin = await RuleEngine.EvaluateRuleAsync("RequireAdmin", securityContext);
        
        // Ensure valid tenant context upon entry
        if (TenantContext.TenantId == 0 && !_isSystemAdmin)
        {
            Navigation.NavigateTo("/context-selection");
            return;
        }

        if (TenantContext.AssociationId != 0 || _isSystemAdmin)
        {
            await DashboardService.InitializeAsync(isManagement, _isResident);
        }
        
        _isInitialLoading = false;
        StateHasChanged();
    }

    private void ShowAdvanceModal() => _isAdvanceModalOpen = true;
    private void HideAdvanceModal() => _isAdvanceModalOpen = false;

    private async Task OnInvoicePayNow(Invoice invoice)
    {
        _currentlyPayingInvoiceId = invoice.InvoiceId;
        var totalAmount = invoice.Amount + invoice.LineItems.Where(l => l.InvoiceLineItemId == 0 || l.ChargeName.Contains("Penalty") || l.ChargeName.Contains("Fine")).Sum(li => li.Amount);
        await InitiateRazorpay(totalAmount, invoice.InvoiceId, invoice.AssetId, $"Payment for Invoice #{invoice.InvoiceId}");
    }

    private async Task ProcessAdvancePayment()
    {
        if (_advanceAmount <= 0) return;
        _isAdvanceModalOpen = false;
        var targetAssetId = DashboardService.Occupancies?.FirstOrDefault()?.AssetId;
        await InitiateRazorpay(_advanceAmount, null, targetAssetId, "Advance Payment / Wallet Top-up");
    }

    private async Task InitiateRazorpay(decimal amount, int? invoiceId, int? assetId, string description)
    {
        try
        {
            var request = new RazorpayOrderRequest { Amount = amount, Currency = "INR", InvoiceId = invoiceId, AssetId = assetId, Description = description };
            var response = await ApiService.PostAsync<RazorpayOrderRequest, RazorpayOrderResponse>("api/payments/create-order", request);
            if (response != null)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                await _razorpayCheckout.InitializePayment(response, authState.User.Identity?.Name ?? "Resident", description, authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "", "");
            }
        }
        catch (Exception ex) { ToastService.Notify(new(ToastType.Danger, $"Payment Failed: {ex.Message}")); }
    }

    private async Task OnPaymentProcessed(string paymentId)
    {
        ToastService.Notify(new(ToastType.Success, $"Payment recorded successfully! ID: {paymentId}"));
        _currentlyPayingInvoiceId = null;
        await DashboardService.LoadResidentDataAsync();
        if (_residentDashboard != null) await _residentDashboard.RefreshInvoiceListAsync();
    }

    private void OnPaymentFailed()
    {
        ToastService.Notify(new(ToastType.Danger, "Payment failed or was cancelled."));
        _currentlyPayingInvoiceId = null;
    }

    private async Task OnPayWithAdvance(Invoice invoice)
    {
        try
        {
            var success = await ApiService.PostAsync($"api/finance/invoices/{invoice.InvoiceId}/settled-with-advance", new { });
            if (success)
            {
                ToastService.Notify(new(ToastType.Success, $"Invoice #{invoice.InvoiceId} paid successfully using advance credit!"));
                await DashboardService.LoadResidentDataAsync();
                if (_residentDashboard != null) await _residentDashboard.RefreshInvoiceListAsync();
            }
            else ToastService.Notify(new(ToastType.Danger, "Failed to pay using advance credit."));
        }
        catch (Exception ex) { ToastService.Notify(new(ToastType.Danger, $"Error: {ex.Message}")); }
    }
}
