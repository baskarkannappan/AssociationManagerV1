@page "/assets"
@attribute [Authorize(Policy = "RequireResident")]
@using AssociationManager.Client.Components
@using AssociationManager.Client.Components.Assets
@using AssociationManager.Client.Components.Base
@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums
@inherits StatefulComponentBase
@inject AssetStateService AssetState
@inject LayoutStateService LayoutState
@inject ApiService ApiService
@inject ToastService _toastService
@inject AuthenticationStateProvider AuthStateProvider

<RazorpayCheckout @ref="_razorpayCheckout" OnPaymentSuccess="OnPaymentProcessed" OnPaymentFailed="OnPaymentFailed" />

<AuthorizeView Context="assetAuthContext">
    <Authorized>
        <div class="assets-page h-100 d-flex flex-column bg-white forced-text-dark">
            <div class="flex-grow-1 d-flex overflow-hidden @(AssetState.ShowDetailOnMobile ? "mobile-detail-active" : "")">
                <!-- Asset Tree Pane -->
                <div class="asset-tree-wrapper @(AssetState.IsSidebarCollapsed ? "collapsed" : "") @(AssetState.ShowDetailOnMobile ? "d-none d-lg-block" : "w-explorer")" style="flex-shrink: 0;">
                    <AssetTree Hierarchy="AssetState.Hierarchy" 
                               SelectedAsset="AssetState.SelectedAsset" 
                               ExpandedIds="AssetState.ExpandedIds" 
                               CanManage="AssetState.CanManageAssets"
                               OnSelected="AssetState.SelectAssetAsync" 
                               OnToggleExpand="AssetState.ToggleExpand"
                               OnAddRoot="AssetState.CreateRootProperty"
                               OnBulkCreate="() => _bulkModal.ShowAsync()"
                               OnCollapse="() => AssetState.IsSidebarCollapsed = true" />
                </div>

                <!-- Detail/Editor Pane -->
                <div class="detail-pane flex-grow-1 custom-scrollbar forced-text-dark @(AssetState.ShowDetailOnMobile ? "d-block" : "d-none d-lg-block")" style="background: #ffffff;">
                    @if (AssetState.SelectedAsset != null)
                    {
                        <div class="premium-detail-header">
                            <div class="premium-breadcrumb text-uppercase">
                                PROPERTIES <i class="bi bi-chevron-right"></i> @AssetState.SelectedAsset.Name
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <h1 class="mb-0 fw-bold" style="font-size: 28px; letter-spacing: -0.5px;">
                                    @(AssetState.IsNew ? "Initialize New Asset" : AssetState.SelectedAsset.Name)
                                </h1>
                                @if (!AssetState.IsNew)
                                {
                                    <span class="modern-badge modern-badge-alt">@AssetState.SelectedAsset.AssetType</span>
                                    <span class="modern-badge modern-badge-outline ms-auto">ID: @AssetState.SelectedAsset.AssetId</span>
                                }
                            </div>
                        </div>

                        <div class="premium-tab-container">
                            <div class="premium-tab @(AssetState.ActiveTab == "details" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "details"'>Details</div>
                            @if (!AssetState.IsNew)
                            {
                                <div class="premium-tab @(AssetState.ActiveTab == "governance" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "governance"'>Governance</div>
                                <div class="premium-tab @(AssetState.ActiveTab == "finance" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "finance"'>Finance</div>
                                <div class="premium-tab @(AssetState.ActiveTab == "rules" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "rules"'>Rules</div>
                                <div class="premium-tab @(AssetState.ActiveTab == "task" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "task"'>Task</div>
                                <div class="premium-tab @(AssetState.ActiveTab == "assignments" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "assignments"'>Assignments</div>
                                <div class="premium-tab @(AssetState.ActiveTab == "metrics" ? "active" : "")" @onclick='() => AssetState.ActiveTab = "metrics"'>Metrics</div>
                            }
                        </div>

                        <div class="p-0">
                            @if (AssetState.ActiveTab == "details" || AssetState.IsNew)
                            {
                                <AssetDetailForm Asset="AssetState.SelectedAsset" 
                                                IsNew="AssetState.IsNew" 
                                                IsReadOnly="!AssetState.CanManageAssets"
                                                OnSave="AssetState.SaveAssetAsync" 
                                                OnAddChild="AssetState.CreateChild" 
                                                OnDelete="AssetState.DeleteAssetAsync" />
                            }
                            else if (AssetState.ActiveTab == "governance") { <AssetGovernanceTab /> }
                            else if (AssetState.ActiveTab == "finance") { <AssetFinanceTab OnPayNow="OnInvoicePayNow" /> }
                            else if (AssetState.ActiveTab == "rules") { <div class="p-5 text-center opacity-50"><i class="bi bi-shield-check display-1"></i><p>Security Rules & Automation</p></div> }
                            else if (AssetState.ActiveTab == "task") { <div class="p-4"><WorkOrderList WorkOrders="AssetState.WorkOrders" /></div> }
                            else if (AssetState.ActiveTab == "assignments") { <AssetAssignmentsTab /> }
                            else if (AssetState.ActiveTab == "metrics") { <div class="p-5 text-center opacity-50"><i class="bi bi-graph-up display-1"></i><p>Consumption Metrics</p></div> }
                        </div>
                    }
                    else
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                            <i class="bi bi-diagram-3" style="font-size: 4rem; opacity: 0.1;"></i>
                            <p class="mt-3">Select an asset from the explorer to begin management.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>

<BulkCreateModal @ref="_bulkModal" ParentId="AssetState.SelectedAsset?.AssetId" OnSubmit="HandleBulkSubmit" />

<style>
    .detail-pane { overflow-y: auto; height: 100%; transition: all 0.3s ease; }
    .asset-tree-wrapper { transition: width 0.3s ease, margin-left 0.3s ease; overflow: hidden; background: #f1f5f9; }
    .asset-tree-wrapper.collapsed { width: 0; margin-left: -1px; }
</style>

@code {
    private BulkCreateModal _bulkModal = default!;
    private RazorpayCheckout _razorpayCheckout = default!;

    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        RegisterStateService(AssetState);
        LayoutState.SetPageMetadata("Asset Registry", "bi-diagram-3", new List<AppBreadcrumbItem> {
            new AppBreadcrumbItem { Text = "Association" },
            new AppBreadcrumbItem { Text = "Inventory", IsActive = true }
        });

        await AssetState.InitializePermissionsAsync();
        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated == true) await AssetState.LoadHierarchyAsync();
    }

    private async Task HandleBulkSubmit(BulkCreateRequest request)
    {
        await _bulkModal.HideAsync();
        var success = await ApiService.PostAsync("api/assets/bulk", request);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Bulk asset creation complete."));
            await AssetState.LoadHierarchyAsync();
        }
    }

    private async Task OnInvoicePayNow(Invoice invoice)
    {
        await InitiateRazorpay(invoice.Amount, invoice.InvoiceId, invoice.AssetId, $"Payment for Invoice #{invoice.InvoiceId}");
    }

    private async Task InitiateRazorpay(decimal amount, int? invoiceId, int? assetId, string description)
    {
        try
        {
            var request = new RazorpayOrderRequest { Amount = amount, Currency = "INR", InvoiceId = invoiceId, AssetId = assetId, Description = description };
            var response = await ApiService.PostAsync<RazorpayOrderRequest, RazorpayOrderResponse>("api/payments/create-order", request);
            if (response != null)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                await _razorpayCheckout.InitializePayment(response, authState.User.Identity?.Name ?? "Resident", description, authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "", "");
            }
        }
        catch (Exception ex) { _toastService.Notify(new(ToastType.Danger, $"Payment Failed: {ex.Message}")); }
    }

    private async Task OnPaymentProcessed(string paymentId)
    {
        _toastService.Notify(new(ToastType.Success, $"Payment recorded successfully!"));
        if (AssetState.SelectedAsset != null) await AssetState.LoadUnitDataAsync(AssetState.SelectedAsset.AssetId);
    }

    private void OnPaymentFailed() => _toastService.Notify(new(ToastType.Danger, "Payment failed or was cancelled."));
}
