@page "/assets"
@attribute [Authorize(Policy = "RequireResident")]
@using AssociationManager.Client.Components
@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums
@inject ApiService ApiService
@inject ToastService _toastService
@inject NavigationManager Navigation
@inject IAppAuthorizationService AuthService

<AuthorizeView Context="assetAuthContext">
    <Authorized>
        <div class="assets-page h-100 d-flex flex-column bg-white forced-text-dark">
            <div class="premium-page-header border-bottom px-4 py-3 mb-0">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="premium-page-title mb-0">
                            <i class="bi bi-diagram-3 me-2"></i> Asset Registry
                        </h1>
                    </div>
                    @if (_canManageAssets)
                    {
                        <div class="actions d-flex gap-2">
                            <button class="btn-vscode" @onclick="() => _bulkModal.ShowAsync()">
                                <i class="bi bi-grid-3x3-gap"></i> Select from Template
                            </button>
                            <button class="btn-vscode" @onclick="CreateRootProperty">
                                <i class="bi bi-plus"></i> New Property
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="flex-grow-1 d-flex overflow-hidden">
                <!-- Asset Tree Pane -->
                <AssetTree Hierarchy="_hierarchy" 
                           SelectedAsset="_selectedAsset" 
                           ExpandedIds="_expandedIds" 
                           OnSelected="HandleAssetSelected" 
                           OnToggleExpand="HandleToggleExpand" />

                <!-- Detail/Editor Pane -->
                <div class="detail-pane flex-grow-1 p-4 custom-scrollbar forced-text-dark" style="background: #fdfdfd;">
                    @if (_selectedAsset != null)
                    {
                        <div class="premium-property-card mx-auto" style="max-width: 900px; border: 1px solid #e2e8f0;">
                            <div class="d-flex align-items-center gap-3 mb-4">
                                <div class="premium-header-icon @GetIconColorClass(_selectedAsset.AssetType)">
                                    <i class="bi @GetIconClass(_selectedAsset.AssetType)"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h3 class="mb-0 fw-bold">@(_isNew ? "Create New" : _selectedAsset.Name)</h3>
                                        @if (!_isNew)
                                        {
                                            <span class="badge bg-opacity-10 bg-primary text-primary border border-primary border-opacity-20 px-2">ID: @_selectedAsset.AssetId</span>
                                        }
                                    </div>
                                    <div class="text-secondary small d-flex align-items-center gap-2">
                                        <i class="bi bi-tag-fill opacity-50"></i>
                                        <span>@_selectedAsset.AssetType</span>
                                        @if (_selectedAsset.ParentId != null)
                                        {
                                            <span class="mx-1 opacity-30">|</span>
                                            <i class="bi bi-arrow-return-right opacity-50"></i>
                                            <span>Sub-component of Registry</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="vscode-tabs mb-3 border-bottom">
                                <div class="vscode-tab @(_activeTab == "details" ? "active" : "")" @onclick='() => _activeTab = "details"'>Details</div>
                                @if (!_isNew && IsUnitType(_selectedAsset.AssetType))
                                {
                                    <div class="vscode-tab @(_activeTab == "occupants" ? "active" : "")" @onclick='() => _activeTab = "occupants"'>Occupants</div>
                                    <div class="vscode-tab @(_activeTab == "vehicles" ? "active" : "")" @onclick='() => _activeTab = "vehicles"'>Vehicles</div>
                                    <div class="vscode-tab @(_activeTab == "pets" ? "active" : "")" @onclick='() => _activeTab = "pets"'>Pets</div>
                                    <div class="vscode-tab @(_activeTab == "announcements" ? "active" : "")" @onclick='() => _activeTab = "announcements"'>Announcements</div>
                                    <div class="vscode-tab @(_activeTab == "history" ? "active" : "")" @onclick='() => _activeTab = "history"'>History</div>
                                }
                            </div>

                            @if (_activeTab == "details" || _isNew)
                            {
                                <AssetDetailForm Asset="_selectedAsset" 
                                                IsNew="_isNew" 
                                                IsReadOnly="!_canManageAssets"
                                                OnSave="HandleSave" 
                                                OnAddChild="CreateChild" 
                                                OnDelete="HandleDelete" />
                            }
                            else if (_activeTab == "occupants")
                            {
                                <OccupancyList AssetId="_selectedAsset.AssetId" 
                                               Occupants="_occupants" 
                                               OnDelete="RemoveOccupant" 
                                               OnDataChanged="() => LoadUnitData(_selectedAsset.AssetId)" />
                            }
                            else if (_activeTab == "vehicles")
                            {
                                <VehicleList AssetId="_selectedAsset.AssetId" 
                                             Vehicles="_vehicles" 
                                             OnDelete="RemoveVehicle" 
                                             OnDataChanged="() => LoadUnitData(_selectedAsset.AssetId)" />
                            }
                            else if (_activeTab == "pets")
                            {
                                <PetList AssetId="_selectedAsset.AssetId" 
                                         Pets="_pets" 
                                         OnDelete="RemovePet" 
                                         OnDataChanged="() => LoadUnitData(_selectedAsset.AssetId)" />
                            }
                            else if (_activeTab == "announcements")
                            {
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold small mb-0">Unit Announcements</h6>
                                    @if (_canManageAssets)
                                    {
                                        <button class="btn btn-sm btn-vscode" @onclick="() => _assetBroadcastList?.ShowCreateModal()">
                                            <i class="bi bi-plus"></i> Post to Unit
                                        </button>
                                    }
                                </div>
                                <BroadcastList @ref="_assetBroadcastList" AssetId="_selectedAsset.AssetId" />
                            }
                            else if (_activeTab == "history")
                            {
                                <div class="row g-3">
                                    <div class="col-12">
                                        <h6 class="fw-bold small mb-2">Service Requests</h6>
                                        <WorkOrderList WorkOrders="_workOrders" />
                                    </div>
                                    <div class="col-12 pt-3 border-top">
                                        <h6 class="fw-bold small mb-2">Billing History</h6>
                                        <InvoiceList Invoices="_invoices" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                            <i class="bi bi-diagram-3" style="font-size: 4rem; opacity: 0.1;"></i>
                            <p class="mt-3">Select an asset to view details or create a new one.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Authorizing session...</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

<BulkCreateModal @ref="_bulkModal" 
                 ParentId="_selectedAsset?.AssetId" 
                 OnClose="() => {}" 
                 OnSubmit="HandleBulkSubmit" />

<style>
    .detail-pane { overflow-y: auto; height: 100%; }
    .vscode-tabs .vscode-tab:hover { background: #e8e8e8; }
</style>

@code {
    private List<Asset>? _hierarchy;
    private Asset? _selectedAsset;
    private bool _isNew;
    private bool _isResident;
    private string _activeTab = "details";
    private HashSet<int> _expandedIds = new();

    // Reusable Data
    private List<Occupancy>? _occupants;
    private List<Vehicle>? _vehicles;
    private List<Pet>? _pets;
    private IEnumerable<WorkOrder>? _workOrders;
    private IEnumerable<Invoice>? _invoices;

    private BroadcastList? _assetBroadcastList;
    private BulkCreateModal _bulkModal = default!;
    private bool _canManageAssets;

    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        _canManageAssets = await AuthService.HasLevelAsync(authState.User, AppRole.LevelAssociationAdmin);
        _isResident = !_canManageAssets;

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await LoadHierarchy();
        }
    }

    private async Task LoadHierarchy()
    {
        var result = await ApiService.GetAsync<List<Asset>>("api/assets/hierarchy");
        _hierarchy = result;
        
        if (_selectedAsset != null && !_isNew)
        {
            _selectedAsset = FindInHierarchy(_hierarchy, _selectedAsset.AssetId);
        }
    }

    private void HandleToggleExpand(int assetId)
    {
        if (_expandedIds.Contains(assetId))
            _expandedIds.Remove(assetId);
        else
            _expandedIds.Add(assetId);
    }

    private Asset? FindInHierarchy(IEnumerable<Asset>? assets, int id)
    {
        if (assets == null) return null;
        foreach (var asset in assets)
        {
            if (asset.AssetId == id) return asset;
            var found = FindInHierarchy(asset.Children, id);
            if (found != null) return found;
        }
        return null;
    }

    private async Task HandleAssetSelected(Asset asset)
    {
        _selectedAsset = asset;
        _isNew = false;
        _activeTab = "details";
        
        if (IsUnitType(asset.AssetType))
        {
            await LoadUnitData(asset.AssetId);
        }
        
        StateHasChanged();
    }

    private async Task LoadUnitData(int assetId)
    {
        // Re-evaluate management permission for the specific asset
        _canManageAssets = await ApiService.GetAsync<bool>($"api/people/can-manage-unit/{assetId}");
        
        _occupants = await ApiService.GetAsync<List<Occupancy>>($"api/people/unit/{assetId}/occupants");
        _vehicles = await ApiService.GetAsync<List<Vehicle>>($"api/people/unit/{assetId}/vehicles");
        _pets = await ApiService.GetAsync<List<Pet>>($"api/people/unit/{assetId}/pets");
        
        // Fetch history
        _workOrders = await ApiService.GetAsync<List<WorkOrder>>($"api/operations/workorders?assetId={assetId}");
        var invoiceResult = await ApiService.GetAsync<PagedResult<Invoice>>($"api/finance/invoices?assetId={assetId}");
        _invoices = invoiceResult?.Items;
    }

    private void CreateRootProperty()
    {
        _selectedAsset = new Asset { AssetType = AssetType.Property };
        _isNew = true;
        _activeTab = "details";
    }

    private void CreateChild()
    {
        if (_selectedAsset == null) return;
        var parentId = _selectedAsset.AssetId;
        _selectedAsset = new Asset 
        { 
            ParentId = parentId,
            AssetType = GetDefaultChildType(_selectedAsset.AssetType)
        };
        _isNew = true;
        _activeTab = "details";
    }

    private async Task HandleSave()
    {
        if (_selectedAsset == null) return;

        bool success;
        if (_isNew)
        {
            success = await ApiService.PostAsync("api/assets", _selectedAsset);
            if (success) _toastService.Notify(new(ToastType.Success, "New asset created."));
        }
        else
        {
            success = await ApiService.PutAsync($"api/assets/{_selectedAsset.AssetId}", _selectedAsset);
            if (success) _toastService.Notify(new(ToastType.Success, "Asset updated."));
        }

        if (success)
        {
            await LoadHierarchy();
            _isNew = false;
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to save asset."));
        }
        StateHasChanged();
    }

    private async Task HandleDelete()
    {
        if (_selectedAsset == null) return;
        var success = await ApiService.DeleteAsync($"api/assets/{_selectedAsset.AssetId}");
        if (success)
        {
            _toastService.Notify(new(ToastType.Warning, "Asset deleted."));
            _selectedAsset = null;
            await LoadHierarchy();
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to delete asset."));
        }
    }

    private async Task HandleBulkSubmit(BulkCreateRequest request)
    {
        await _bulkModal.HideAsync();
        var success = await ApiService.PostAsync("api/assets/bulk", request);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Bulk asset creation complete."));
            await LoadHierarchy();
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Bulk creation failed."));
        }
        StateHasChanged();
    }

    private async Task RemoveOccupant(int id) {
        var success = await ApiService.DeleteAsync($"api/people/occupancy/{id}");
        if (success) {
            _toastService.Notify(new(ToastType.Warning, "Occupant removed."));
            if (_selectedAsset != null) await LoadUnitData(_selectedAsset.AssetId);
        }
    }

    private async Task RemoveVehicle(int id) {
        var success = await ApiService.DeleteAsync($"api/people/vehicles/{id}");
        if (success) {
            _toastService.Notify(new(ToastType.Warning, "Vehicle removed."));
            if (_selectedAsset != null) await LoadUnitData(_selectedAsset.AssetId);
        }
    }

    private async Task RemovePet(int id) {
        var success = await ApiService.DeleteAsync($"api/people/pets/{id}");
        if (success) {
            _toastService.Notify(new(ToastType.Warning, "Pet record removed."));
            if (_selectedAsset != null) await LoadUnitData(_selectedAsset.AssetId);
        }
    }

    private bool IsUnitType(AssetType type) => type == AssetType.Unit || type == AssetType.Villa;

    private string GetIconClass(AssetType type) => type switch
    {
        AssetType.Property => "bi-geo-alt",
        AssetType.Building => "bi-building",
        AssetType.Floor => "bi-layers",
        AssetType.Unit => "bi-door-closed",
        AssetType.Villa => "bi-house-heart",
        AssetType.CommonArea => "bi-tree",
        AssetType.Amenity => "bi-water",
        AssetType.SecurityGate => "bi-shield-lock",
        _ => "bi-box"
    };

    private string GetIconColorClass(AssetType type) => type switch
    {
        AssetType.Property => "asset-icon-property",
        AssetType.Building => "asset-icon-building",
        AssetType.Floor => "asset-icon-floor",
        AssetType.Unit => "asset-icon-unit",
        AssetType.Villa => "asset-icon-villa",
        AssetType.CommonArea => "asset-icon-common",
        _ => ""
    };

    private AssetType GetDefaultChildType(AssetType parentType) => parentType switch
    {
        AssetType.Property => AssetType.Building,
        AssetType.Building => AssetType.Floor,
        AssetType.Floor => AssetType.Unit,
        _ => AssetType.Unit
    };
}
