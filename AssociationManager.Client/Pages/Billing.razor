@page "/billing"
@using AssociationManager.Shared.Models
@using AssociationManager.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "RequireResident")]
@inject ApiService Api
@inject ToastService _toastService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="premium-page-header border-bottom px-4 py-3 mb-0">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="premium-page-title mb-0" style="font-size: 1.25rem;">
                <i class="bi bi-wallet2 me-2"></i>
                @(_scope == "tenant" ? "Corporate Finance & Billing" : "Association Finance & Billing")
            </h1>
        </div>
        <div class="header-right">
            <AuthorizeView Policy="RequireFinanceManager" Context="financeHeaderContext">
                <Authorized>
                    @if (_scope == "association")
                    {
                        <button class="btn-vscode" @onclick="ShowCreateInvoice">
                            <i class="bi bi-plus-lg"></i> New Association Invoice
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-vscode-accent px-3" disabled title="Tenant billing is aggregated">
                            <i class="bi bi-bar-chart-fill me-1"></i> Aggregate View
                        </button>
                    }
                </Authorized>
                <NotAuthorized>
                    @if (_scope != "association")
                    {
                        <button class="btn btn-sm btn-vscode-accent px-3" disabled title="Tenant billing is aggregated">
                            <i class="bi bi-bar-chart-fill me-1"></i> Aggregate View
                        </button>
                    }
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>

<div class="vscode-content custom-scrollbar">
    <div class="container-fluid py-4">
        <!-- Dashboard Stats -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="compact-card text-center">
                    <div class="text-muted mb-1" style="font-size: 11px; text-transform: uppercase;">Total Unpaid</div>
                    <div class="h4 m-0 fw-bold text-danger">₹@(_invoices?.Where(i => i.Status == "Unpaid").Sum(i => i.Amount) ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="compact-card text-center">
                    <div class="text-muted mb-1" style="font-size: 11px; text-transform: uppercase;">Collected (30d)</div>
                    <div class="h4 m-0 fw-bold text-success">₹@(_payments?.Where(p => p.CreatedDate > DateTime.Now.AddDays(-30)).Sum(p => p.Amount) ?? 0)</div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="nav nav-tabs mb-4" id="billingTabs" role="tablist">
                    <button class="nav-link @(_activeTab == "invoices" ? "active" : "")" @onclick='() => _activeTab = "invoices"'>
                        <i class="bi bi-list-check me-2"></i>Recent Invoices
                    </button>
                    <AuthorizeView Policy="RequireFinanceManager" Context="batchTabContext">
                        @if (_scope == "association")
                        {
                            <button class="nav-link @(_activeTab == "batch" ? "active" : "")" @onclick='() => _activeTab = "batch"'>
                                <i class="bi bi-stack me-2"></i>Batch Generation
                            </button>
                        }
                    </AuthorizeView>
                </div>

                @if (_activeTab == "invoices")
                {
                    <div class="row">
                        <!-- Invoices List -->
                        <div class="col-md-8">
                            <div class="compact-card">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="m-0 fw-semibold">Recent Invoices</h6>
                                    <div class="d-flex gap-2">
                                        <span class="tree-badge">Filter: All</span>
                                    </div>
                                </div>

                                @if (_invoices == null)
                                {
                                    <div class="p-4 text-center opacity-50">
                                        <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                                        <div>Loading invoices...</div>
                                    </div>
                                }
                                else if (!_invoices.Any())
                                {
                                    <div class="p-5 text-center opacity-50">
                                        <i class="bi bi-receipt-cutoff display-6 mb-3"></i>
                                        <p>No invoices found for this association.</p>
                                    </div>
                                }
                                else
                                {
                                    <Grid @ref="invoiceGrid" TItem="Invoice"
                                          Class="table table-hover table-bordered table-striped compact-table"
                                          DataProvider="InvoicesDataProvider"
                                          Responsive="true"
                                          AllowPaging="true"
                                          PageSize="10"
                                          AllowSorting="true">

                                        <GridColumn TItem="Invoice" HeaderText="Title" PropertyName="Title" SortKeySelector="item => item.Title">
                                            <span class="fw-medium">@context.Title</span>
                                        </GridColumn>

                                        <GridColumn TItem="Invoice" HeaderText="Unit" PropertyName="AssetName" SortKeySelector="item => item.AssetName">
                                            <span class="tree-badge">@context.AssetName</span>
                                        </GridColumn>

                                        <GridColumn TItem="Invoice" HeaderText="Amount" PropertyName="Amount" SortKeySelector="item => item.Amount">
                                            <span class="fw-semibold">₹@context.Amount</span>
                                        </GridColumn>

                                        <GridColumn TItem="Invoice" HeaderText="Due Date" PropertyName="DueDate" SortKeySelector="item => item.DueDate">
                                            @context.DueDate.ToShortDateString()
                                        </GridColumn>

                                        <GridColumn TItem="Invoice" HeaderText="Status" PropertyName="Status" SortKeySelector="item => item.Status">
                                            <span class="badge @GetStatusClass(context.Status)" style="font-size: 11px; border-radius: 2px;">@context.Status</span>
                                        </GridColumn>

                                        <GridColumn TItem="Invoice" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                                            @if (context.Status == "Unpaid")
                                            {
                                                <button class="btn btn-sm btn-link p-0 text-primary me-2" title="Pay with Razorpay" @onclick="() => InitiateRazorpayPayment(context)">
                                                    <i class="bi bi-credit-card-2-back"></i>
                                                </button>
                                                <AuthorizeView Policy="RequireFinanceManager" Context="recordPayContext">
                                                    <button class="btn btn-sm btn-link p-0 text-success me-2" title="Record Manual Payment" @onclick="() => RecordPayment(context)">
                                                        <i class="bi bi-cash-stack"></i>
                                                    </button>
                                                </AuthorizeView>
                                            }
                                            <button class="btn btn-sm btn-link p-0 text-info me-2" title="Transaction History" @onclick="() => ShowTransactionHistory(context)">
                                                <i class="bi bi-clock-history"></i>
                                            </button>
                                            <button class="btn btn-sm btn-link p-0 text-muted">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                        </GridColumn>
                                    </Grid>
                                }
                            </div>
                        </div>

                        <!-- Payment History -->
                        <div class="col-md-4">
                            <div class="compact-card">
                                <h6 class="m-0 fw-semibold mb-3">Recent Payments</h6>
                                @if (_payments == null)
                                {
                                    <div class="text-center py-3 opacity-50">Loading...</div>
                                }
                                else if (!_payments.Any())
                                {
                                    <div class="text-muted small">No payment history.</div>
                                }
                                else
                                {
                                    <div class="list-group list-group-flush">
                                        @foreach (var pay in _payments.OrderByDescending(p => p.CreatedDate).Take(10))
                                        {
                                            <div class="list-group-item px-0 py-2 border-0">
                                                <div class="d-flex justify-content-between">
                                                    <span class="small fw-medium">Manual Payment</span>
                                                    <span class="small fw-bold text-success">+₹@pay.Amount</span>
                                                </div>
                                                <div class="d-flex justify-content-between opacity-50" style="font-size: 10px;">
                                                    <span>@pay.CreatedDate.ToString("g")</span>
                                                    <span>@pay.Currency</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else if (_activeTab == "batch")
                {
                    <div class="compact-card">
                        <div class="row align-items-end g-3 mb-4">
                            <div class="col-md-3">
                                <label class="small fw-bold text-muted mb-1 d-block text-uppercase">Month</label>
                                <select class="form-select form-select-sm" @bind="_batchRequest.Month">
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i">@System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(i)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="small fw-bold text-muted mb-1 d-block text-uppercase">Year</label>
                                <select class="form-select form-select-sm" @bind="_batchRequest.Year">
                                    @for (int i = DateTime.Today.Year - 1; i <= DateTime.Today.Year + 1; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="small fw-bold text-muted mb-1 d-block text-uppercase">Due Date</label>
                                <input type="date" class="form-control form-control-sm" @bind="_batchRequest.DueDate" />
                            </div>
                            <div class="col-md-4 d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary flex-grow-1" @onclick="PreviewBatch" disabled="@_isProcessingBatch">
                                    @if (_isProcessingBatch) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-eye me-1"></i> Preview Batch
                                </button>
                                @if (_batchResult != null && _batchResult.Previews.Any() && !_batchResult.IsLocked)
                                {
                                    <button class="btn btn-sm btn-vscode flex-grow-1" @onclick="CommitBatch" disabled="@_isProcessingBatch">
                                        <i class="bi bi-check-circle me-1"></i> Confirm & Generate
                                    </button>
                                }
                            </div>
                        </div>

                        @if (_batchResult != null)
                        {
                            @if (_batchResult.IsLocked)
                            {
                                <div class="alert alert-warning py-2 px-3 mb-3 d-flex align-items-center" style="font-size: 13px;">
                                    <i class="bi bi-lock-fill me-2 fs-5"></i>
                                    <div>
                                        <strong>Billing Locked:</strong> Invoices for this period have already been generated. 
                                        As per policy, no new generation is allowed. Please handle adjustments in the next month.
                                    </div>
                                </div>
                            }

                            <div class="alert alert-info py-2 px-3 mb-3 d-flex justify-content-between align-items-center" style="font-size: 13px;">
                                <div>
                                    <i class="bi bi-info-circle me-2"></i>
                                    @_batchResult.Message
                                </div>
                                <div class="fw-bold">Total: ₹@_batchResult.TotalAmount</div>
                            </div>

                            <div class="table-responsive border rounded" style="max-height: 400px;">
                                <table class="table table-sm table-hover mb-0" style="font-size: 12px;">
                                    <thead class="bg-light sticky-top">
                                        <tr>
                                            <th>Asset</th>
                                            <th class="text-end">Amount</th>
                                            <th>Breakdown</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _batchResult.Previews)
                                        {
                                            <tr>
                                                <td><span class="tree-badge">@item.AssetName</span></td>
                                                <td class="text-end fw-bold">₹@item.Amount</td>
                                                <td class="text-muted small">@item.Description</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-5 text-center text-muted border border-dashed rounded">
                                <i class="bi bi-stack display-6 mb-3 opacity-25"></i>
                                <p>Select a period and click "Preview Batch" to view calculated invoices.</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (_isCreateModalOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content compact-card p-0 overflow-hidden shadow-lg" style="background: white; border: 1px solid var(--vscode-border);">
                <div class="premium-card-header">
                    <h6 class="premium-card-title">New Invoice</h6>
                    <button type="button" class="btn-close" style="font-size: 10px;" @onclick="CloseModals"></button>
                </div>
                <div class="p-3 compact-form">
                    <EditForm Model="_newInvoice" OnValidSubmit="HandleCreateInvoice">
                        <div class="mb-3">
                            <label class="form-label small mb-1">Title</label>
                            <InputText @bind-Value="_newInvoice.Title" class="form-control" placeholder="e.g. Monthly Dues April 2026" />
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label small mb-1">Amount</label>
                                <InputNumber @bind-Value="_newInvoice.Amount" class="form-control" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-1">Due Date</label>
                                <InputDate @bind-Value="_newInvoice.DueDate" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small mb-1">Description</label>
                            <InputTextArea @bind-Value="_newInvoice.Description" class="form-control" rows="2" />
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn-vscode-secondary" @onclick="CloseModals">Cancel</button>
                            <button type="submit" class="btn-vscode">Generate Invoice</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (_isHistoryModalOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content compact-card p-0 overflow-hidden shadow-lg" style="background: white; border: 1px solid var(--vscode-border);">
                <div class="premium-card-header">
                    <h6 class="premium-card-title">Transaction History: @(_selectedInvoice?.Title)</h6>
                    <button type="button" class="btn-close" style="font-size: 10px;" @onclick="CloseModals"></button>
                </div>
                <div class="p-3">
                    @if (_historyLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border spinner-border-sm text-primary"></div>
                            <div class="small mt-2">Fetching gateway details...</div>
                        </div>
                    }
                    else if (_historyTransactions == null || !_historyTransactions.Any())
                    {
                        <div class="text-center py-5 opacity-50">
                            <i class="bi bi-receipt-cutoff display-6 mb-2"></i>
                            <div>No payment activity recorded for this invoice.</div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover" style="font-size: 12px;">
                                <thead class="bg-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Method</th>
                                        <th>Target Account & RRN</th>
                                        <th>Reference ID</th>
                                        <th>Status</th>
                                        <th class="text-end">Amount (Net)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var tx in _historyTransactions)
                                    {
                                        <tr>
                                            <td>@tx.CreatedDate.ToString("g")</td>
                                            <td>
                                                <div class="small fw-medium text-capitalize">@(tx.PaymentMethod ?? "Gateway")</div>
                                                @if (!string.IsNullOrEmpty(tx.BankName) || !string.IsNullOrEmpty(tx.CardNetwork))
                                                {
                                                    <div class="text-muted extra-small" style="font-size: 10px;">@(tx.BankName ?? tx.CardNetwork)</div>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(tx.PrimaryAccountName))
                                                {
                                                    <div class="small fw-semibold">@tx.PrimaryAccountName</div>
                                                    <div class="text-muted extra-small" style="font-size: 10px;">@tx.PrimaryAccountNumber</div>
                                                }
                                                @if (!string.IsNullOrEmpty(tx.BankRrn))
                                                {
                                                    <div class="mt-1 badge bg-info-subtle text-info border-info" style="font-size: 9px; padding: 1px 4px;">RRN: @tx.BankRrn</div>
                                                }
                                            </td>
                                            <td><code class="small text-muted">@tx.ReferenceId</code></td>
                                            <td><span class="badge @GetPaymentStatusClass(tx.Status)" style="font-size: 10px;">@tx.Status</span></td>
                                            <td class="text-end">
                                                <div class="fw-bold">₹@tx.Amount</div>
                                                @if (tx.GatewayFee.HasValue)
                                                {
                                                    <div class="extra-small text-muted" style="font-size: 9px;" title="Fee: ₹@tx.GatewayFee, Tax: ₹@tx.GatewayTax">
                                                        Net: ₹@(tx.Amount - (tx.GatewayFee ?? 0) - (tx.GatewayTax ?? 0))
                                                    </div>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    <div class="d-flex justify-content-end mt-3">
                        <button class="btn btn-sm btn-vscode-secondary" @onclick="CloseModals">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<RazorpayCheckout @ref="_razorpayCheckout" OnPaymentSuccess="OnPaymentProcessed" />

@code {
    private Grid<Invoice> invoiceGrid = default!;
    private List<Invoice>? _invoices;
    private List<Payment>? _payments;
    private bool _isCreateModalOpen;
    private Invoice _newInvoice = new() { DueDate = DateTime.Today.AddDays(7) };
    private string _scope = "tenant";
    private string _activeTab = "invoices";
    private InvoiceBatchRequest _batchRequest = new() { Month = DateTime.Today.Month, Year = DateTime.Today.Year, DueDate = DateTime.Today.AddDays(15) };
    private InvoiceBatchResult? _batchResult;
    private bool _isProcessingBatch;
    private RazorpayCheckout _razorpayCheckout = default!;
    
    // History Modal
    private bool _isHistoryModalOpen;
    private bool _historyLoading;
    private Invoice? _selectedInvoice;
    private List<PaymentHistoryItem>? _historyTransactions;


    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ParseQueryParameters())
        {
            _invoices = null;
            _payments = null;
            await LoadData();
        }
    }

    private bool ParseQueryParameters()
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query;
        var newScope = query.Contains("scope=association") ? "association" : "tenant";
        
        if (newScope != _scope)
        {
            _scope = newScope;
            return true;
        }
        return false;
    }

    private async Task<GridDataProviderResult<Invoice>> InvoicesDataProvider(GridDataProviderRequest<Invoice> request)
    {
        if (_invoices == null) await LoadData();
        return request.ApplyTo(_invoices ?? new List<Invoice>());
    }

    private async Task LoadData()
    {
        try 
        {
            string baseUrl = "api/finance";
            string invoicesUrl = $"{baseUrl}/invoices";
            string paymentsUrl = $"{baseUrl}/payments";

            if (_scope == "association")
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var aid = authState.User.FindFirst("AssociationId")?.Value;
                

                if (int.TryParse(aid, out int associationId) && associationId != 0)
                {
                    invoicesUrl += $"?associationId={associationId}";
                    paymentsUrl += $"?associationId={associationId}";
                    
                }
            }

            var invoices = await Api.GetAsync<IEnumerable<Invoice>>(invoicesUrl);
            _invoices = invoices?.ToList();
            
            var payments = await Api.GetAsync<IEnumerable<Payment>>(paymentsUrl);
            _payments = payments?.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading billing data: {ex.Message}");
            _invoices = new List<Invoice>();
            _payments = new List<Payment>();
        }
    }

    private void ShowCreateInvoice()
    {
        _newInvoice = new() { DueDate = DateTime.Today.AddDays(7) };
        _isCreateModalOpen = true;
    }

    private async Task HandleCreateInvoice()
    {
        var success = await Api.PostAsync<object>("api/finance/invoices", _newInvoice);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Invoice created successfully."));
            _isCreateModalOpen = false;
            _invoices = null;
            await invoiceGrid.RefreshDataAsync();
            
            // Also refresh payments just in case
            _payments = null; 
            await LoadData(); // Full reload to update dashboard stats too
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to generate invoice."));
        }
    }

    private async Task RecordPayment(Invoice invoice)
    {
        var payment = new Payment 
        { 
            Amount = invoice.Amount,
            InvoiceId = invoice.InvoiceId,
            Status = "Paid",
            Currency = "INR"
        };
        var success = await Api.PostAsync<object>("api/finance/payments", payment);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, $"Payment of ₹{invoice.Amount} recorded."));
            _invoices = null;
            _payments = null;
            await invoiceGrid.RefreshDataAsync();
            await LoadData(); // Reload for stats and payment list
        }
    }

    private async Task InitiateRazorpayPayment(Invoice invoice)
    {
        try
        {
            var request = new RazorpayOrderRequest
            {
                Amount = invoice.Amount,
                Currency = "INR",
                InvoiceId = invoice.InvoiceId,
                Receipt = $"INV_{invoice.InvoiceId}"
            };

            var response = await Api.PostAsync<RazorpayOrderRequest, RazorpayOrderResponse>("api/payments/create-order", request);
            if (response != null)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                
                await _razorpayCheckout.InitializePayment(
                    response, 
                    user.Identity?.Name ?? "Guest", 
                    $"Payment for {invoice.Title}", 
                    user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "", 
                    ""
                );
            }
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Payment initialization failed: {ex.Message}"));
        }
    }

    private async Task OnPaymentProcessed(string paymentId)
    {
        _toastService.Notify(new(ToastType.Success, $"Payment successful! Transaction ID: {paymentId}"));
        _invoices = null;
        _payments = null;
        if (invoiceGrid != null) await invoiceGrid.RefreshDataAsync();
        await LoadData();
    }

    private async Task ShowTransactionHistory(Invoice invoice)
    {
        _selectedInvoice = invoice;
        _isHistoryModalOpen = true;
        _historyLoading = true;
        _historyTransactions = null;
        
        try
        {
            var result = await Api.GetAsync<PaymentHistoryResponse>($"api/payments/history/{invoice.InvoiceId}");
            if (result != null && result.Transactions != null)
            {
                _historyTransactions = result.Transactions.ToList();
            }
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Error loading history: {ex.Message}"));
        }
        finally
        {
            _historyLoading = false;
        }
    }

    private void CloseModals()
    {
        _isCreateModalOpen = false;
        _isHistoryModalOpen = false;
    }

    private string GetPaymentStatusClass(string status) => status switch
    {
        "Paid" or "Captured" or "captured" => "bg-success-subtle text-success",
        "Unpaid" or "failed" => "bg-danger-subtle text-danger",
        "Created" or "attempted" => "bg-info-subtle text-info",
        _ => "bg-secondary-subtle text-secondary"
    };

    private class PaymentHistoryResponse
    {
        public IEnumerable<PaymentHistoryItem> Transactions { get; set; } = new List<PaymentHistoryItem>();
        public IEnumerable<PaymentOrder> Orders { get; set; } = new List<PaymentOrder>();
    }

    private string GetStatusClass(string status) => status switch
    {
        "Paid" => "bg-success-subtle text-success",
        "Unpaid" => "bg-danger-subtle text-danger",
        "Partial" => "bg-warning-subtle text-warning",
        _ => "bg-secondary-subtle text-secondary"
    };

    private async Task PreviewBatch()
    {
        _isProcessingBatch = true;
        _batchResult = null;
        try 
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var aid = authState.User.FindFirst("AssociationId")?.Value;
            if (int.TryParse(aid, out int associationId))
            {
                _batchRequest.AssociationId = associationId;
                _batchRequest.DryRun = true;
                _batchResult = await Api.PostAsync<InvoiceBatchRequest, InvoiceBatchResult>("api/finance/batch-generate", _batchRequest);
            }
        }
        finally
        {
            _isProcessingBatch = false;
        }
    }

    private async Task CommitBatch()
    {
        _isProcessingBatch = true;
        try 
        {
            _batchRequest.DryRun = false;
            var result = await Api.PostAsync<InvoiceBatchRequest, InvoiceBatchResult>("api/finance/batch-generate", _batchRequest);
            if (result != null)
            {
                _toastService.Notify(new(ToastType.Success, result.Message));
                _batchResult = null;
                _activeTab = "invoices";
                _invoices = null;
                await LoadData();
            }
        }
        finally
        {
            _isProcessingBatch = false;
        }
    }

}
