@page "/billing"
@attribute [Authorize(Policy = "RequireResident")]
@using AssociationManager.Client.Components.Billing
@using AssociationManager.Client.Components.Base
@using AssociationManager.Shared.Models
@inherits StatefulComponentBase
@inject LayoutStateService LayoutState
@inject BillingStateService BillingState
@inject AuthenticationStateProvider AuthStateProvider
@inject ApiService ApiService
@inject IAppAuthorizationService AuthService
@inject ToastService _toastService

<div class="h-100 d-flex flex-column bg-white forced-text-dark">
    <RazorpayCheckout @ref="_razorpayCheckout" OnPaymentSuccess="OnPaymentProcessed" OnPaymentFailed="OnPaymentFailed" />

    <div class="flex-grow-1 d-flex overflow-hidden">
        <!-- Main Content Area -->
        <div class="flex-grow-1 d-flex flex-column" style="min-width: 0;">
            <div class="premium-tab-container-wrapper px-4 pt-3">
                <div class="premium-tab-container border-bottom-0 pb-0">
                    <div class="premium-tab @(BillingState.ActiveTab == "invoices" ? "active" : "")" @onclick='() => BillingState.ActiveTab = "invoices"'>Invoices</div>
                    <AuthorizeView Policy="RequireManagement">
                        @if (_canManageGeneration)
                        {
                            <div class="premium-tab @(BillingState.ActiveTab == "generation" ? "active" : "")" @onclick='() => BillingState.ActiveTab = "generation"'>Batch Generation</div>
                        }
                    </AuthorizeView>
                </div>
            </div>

            <div class="flex-grow-1 overflow-auto p-4 custom-scrollbar">
                @if (BillingState.ActiveTab == "invoices")
                {
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="mb-0 fw-bold">Financial History</h5>
                        <AuthorizeView Policy="RequireManagement">
                            <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" @onclick="ReconcileBalances" disabled="@_isReconciling">
                                @if (_isReconciling) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                <i class="bi bi-arrow-repeat me-1"></i> Recalculate Balances
                            </button>
                        </AuthorizeView>
                    </div>
                    <InvoiceGrid @ref="_invoiceGrid"
                                 OnInitiatePayment="OnInvoicePayNow" 
                                 OnPayWithAdvance="OnPayWithAdvance" 
                                 OnRecordManualPayment="OnManualPayClicked"
                                 OnDownloadInvoice="OnDownloadPdf" />
                }
                else if (_canManageGeneration)
                {
                    <BatchGenerator />
                }
                else
                {
                    <div class="p-5 text-center text-muted opacity-50">
                        <i class="bi bi-lock-fill display-1 mb-3"></i>
                        <p>You do not have permission to access batch generation.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (BillingState.ShowTransactionHistory && BillingState.TargetInvoiceId != 0)
{
    <TransactionHistoryModal />
}

@if (BillingState.IdToAdjust != 0)
{
    <AdjustInvoiceModal />
}

@if (BillingState.ShowManualPaymentModal)
{
    <RecordManualPaymentModal />
}

@code {
    private RazorpayCheckout _razorpayCheckout = default!;
    private InvoiceGrid _invoiceGrid = default!;
    private bool _isReconciling;
    private bool _canManageGeneration;

    protected override async Task OnInitializedAsync()
    {
        RegisterStateService(BillingState);
        
        LayoutState.SetPageMetadata("Finance & Billing", "bi-cash-stack", new List<AppBreadcrumbItem> {
            new AppBreadcrumbItem { Text = "Association" },
            new AppBreadcrumbItem { Text = "Finance", IsActive = true }
        });

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var canAccess = await AuthService.EvaluateRuleAsync(authState.User, "ShowMenu_Finance");
        if (!canAccess)
        {
            Navigation.NavigateTo("/");
            return;
        }

        await BillingState.InitializeAsync();
        
        _canManageGeneration = await AuthService.EvaluateRuleAsync(authState.User, "BillingRule_ManageGeneration");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (BillingState.ParseQueryParameters())
        {
            await BillingState.InitializeAsync();
        }
    }

    private async Task OnInvoicePayNow(Invoice invoice)
    {
        var totalAmount = invoice.Amount + invoice.LineItems.Where(l => l.InvoiceLineItemId == 0 || l.ChargeName.Contains("Penalty") || l.ChargeName.Contains("Fine")).Sum(li => li.Amount);
        
        try
        {
            var request = new RazorpayOrderRequest { Amount = totalAmount, Currency = "INR", InvoiceId = invoice.InvoiceId, AssetId = invoice.AssetId, Description = $"Payment for Invoice #{invoice.InvoiceId}" };
            var response = await ApiService.PostAsync<RazorpayOrderRequest, RazorpayOrderResponse>("api/payments/create-order", request);
            if (response != null)
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                await _razorpayCheckout.InitializePayment(response, authState.User.Identity?.Name ?? "Resident", request.Description, authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "", "");
            }
        }
        catch (Exception ex) { _toastService.Notify(new(ToastType.Danger, $"Payment Failed: {ex.Message}")); }
    }

    private async Task OnPayWithAdvance(Invoice invoice)
    {
        if (await BillingState.SettleInvoiceWithAdvanceAsync(invoice.InvoiceId))
        {
            await _invoiceGrid.RefreshAsync();
        }
    }

    private void OnManualPayClicked(Invoice invoice)
    {
        BillingState.ManualPaymentInvoice = invoice;
        BillingState.ShowManualPaymentModal = true;
    }

    private async Task OnDownloadPdf(Invoice invoice)
    {
        await BillingState.DownloadInvoicePdfAsync(invoice.InvoiceId);
    }

    private async Task OnPaymentProcessed(string paymentId)
    {
        _toastService.Notify(new(ToastType.Success, $"Payment recorded successfully! ID: {paymentId}"));
        await BillingState.InitializeAsync();
        await _invoiceGrid.RefreshAsync();
    }

    private void OnPaymentFailed()
    {
        _toastService.Notify(new(ToastType.Danger, "Payment failed or was cancelled."));
    }

    private async Task ReconcileBalances()
    {
        _isReconciling = true;
        try
        {
            var result = await ApiService.PostAsync<object, ApiResponse>("api/finance/reconcile-all", new { });
            if (result != null && result.Success)
            {
                _toastService.Notify(new(ToastType.Success, "Balances recalculated successfully! Dashboard updated."));
                await _invoiceGrid.RefreshAsync();
            }
            else
            {
                _toastService.Notify(new(ToastType.Danger, "Failed to recalculate balances."));
            }
        }
        catch (Exception ex)
        {
            _toastService.Notify(new(ToastType.Danger, $"Error: {ex.Message}"));
        }
        finally
        {
            _isReconciling = false;
        }
    }
}
