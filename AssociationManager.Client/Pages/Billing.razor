@page "/billing"
@using AssociationManager.Shared.Models
@using AssociationManager.Client.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = $"{AppRole.FinanceManager},{AppRole.AssociationAdmin},{AppRole.SystemAdmin},{AppRole.Resident}")]
@inject ApiService Api
@inject ToastService _toastService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="vscode-page-header">
    <div class="header-left">
        <h5 class="m-0 fw-semibold">
            <i class="bi bi-wallet2 me-2"></i>
            @(_scope == "tenant" ? "Corporate Finance & Billing" : "Association Finance & Billing")
        </h5>
    </div>
    <div class="header-right">
        @if (_scope == "association")
        {
            <button class="btn-vscode" @onclick="ShowCreateInvoice">
                <i class="bi bi-plus-lg"></i> New Association Invoice
            </button>
        }
        else
        {
             <button class="btn btn-sm btn-vscode-accent px-3" disabled title="Tenant billing is aggregated">
                <i class="bi bi-bar-chart-fill me-1"></i> Aggregate View
            </button>
        }
    </div>
</div>

<div class="vscode-content custom-scrollbar">
    <div class="container-fluid py-4">
        <!-- Dashboard Stats -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="compact-card text-center">
                    <div class="text-muted mb-1" style="font-size: 11px; text-transform: uppercase;">Total Unpaid</div>
                    <div class="h4 m-0 fw-bold text-danger">₹@(_invoices?.Where(i => i.Status == "Unpaid").Sum(i => i.Amount) ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="compact-card text-center">
                    <div class="text-muted mb-1" style="font-size: 11px; text-transform: uppercase;">Collected (30d)</div>
                    <div class="h4 m-0 fw-bold text-success">₹@(_payments?.Where(p => p.CreatedDate > DateTime.Now.AddDays(-30)).Sum(p => p.Amount) ?? 0)</div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Invoices List -->
            <div class="col-md-8">
                <div class="compact-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="m-0 fw-semibold">Recent Invoices</h6>
                        <div class="d-flex gap-2">
                            <span class="tree-badge">Filter: All</span>
                        </div>
                    </div>

                    @if (_invoices == null)
                    {
                        <div class="p-4 text-center opacity-50">
                            <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                            <div>Loading invoices...</div>
                        </div>
                    }
                    else if (!_invoices.Any())
                    {
                        <div class="p-5 text-center opacity-50">
                            <i class="bi bi-receipt-cutoff display-6 mb-3"></i>
                            <p>No invoices found for this association.</p>
                        </div>
                    }
                    else
                    {
                        <Grid @ref="invoiceGrid" TItem="Invoice"
                              Class="table table-hover table-bordered table-striped compact-table"
                              DataProvider="InvoicesDataProvider"
                              Responsive="true"
                              AllowPaging="true"
                              PageSize="10"
                              AllowSorting="true">

                            <GridColumn TItem="Invoice" HeaderText="Title" PropertyName="Title" SortKeySelector="item => item.Title">
                                <span class="fw-medium">@context.Title</span>
                            </GridColumn>

                            <GridColumn TItem="Invoice" HeaderText="Unit" PropertyName="AssetName" SortKeySelector="item => item.AssetName">
                                <span class="tree-badge">@context.AssetName</span>
                            </GridColumn>

                            <GridColumn TItem="Invoice" HeaderText="Amount" PropertyName="Amount" SortKeySelector="item => item.Amount">
                                <span class="fw-semibold">₹@context.Amount</span>
                            </GridColumn>

                            <GridColumn TItem="Invoice" HeaderText="Due Date" PropertyName="DueDate" SortKeySelector="item => item.DueDate">
                                @context.DueDate.ToShortDateString()
                            </GridColumn>

                            <GridColumn TItem="Invoice" HeaderText="Status" PropertyName="Status" SortKeySelector="item => item.Status">
                                <span class="badge @GetStatusClass(context.Status)" style="font-size: 11px; border-radius: 2px;">@context.Status</span>
                            </GridColumn>

                            <GridColumn TItem="Invoice" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                                @if (context.Status == "Unpaid")
                                {
                                    <button class="btn btn-sm btn-link p-0 text-success me-2" @onclick="() => RecordPayment(context)">
                                        <i class="bi bi-cash-stack"></i>
                                    </button>
                                }
                                <button class="btn btn-sm btn-link p-0 text-muted">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                            </GridColumn>
                        </Grid>
                    }
                </div>
            </div>

            <!-- Payment History -->
            <div class="col-md-4">
                <div class="compact-card">
                    <h6 class="m-0 fw-semibold mb-3">Recent Payments</h6>
                    @if (_payments == null)
                    {
                        <div class="text-center py-3 opacity-50">Loading...</div>
                    }
                    else if (!_payments.Any())
                    {
                        <div class="text-muted small">No payment history.</div>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var pay in _payments.OrderByDescending(p => p.CreatedDate).Take(10))
                            {
                                <div class="list-group-item px-0 py-2 border-0">
                                    <div class="d-flex justify-content-between">
                                        <span class="small fw-medium">Manual Payment</span>
                                        <span class="small fw-bold text-success">+₹@pay.Amount</span>
                                    </div>
                                    <div class="d-flex justify-content-between opacity-50" style="font-size: 10px;">
                                        <span>@pay.CreatedDate.ToString("g")</span>
                                        <span>@pay.Currency</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (_isCreateModalOpen)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content compact-card p-0 overflow-hidden shadow-lg" style="background: white; border: 1px solid var(--vscode-border);">
                <div class="vscode-page-header py-2 px-3">
                    <h6 class="m-0 fw-semibold">New Invoice</h6>
                    <button type="button" class="btn-close" style="font-size: 10px;" @onclick="CloseModals"></button>
                </div>
                <div class="p-3 compact-form">
                    <EditForm Model="_newInvoice" OnValidSubmit="HandleCreateInvoice">
                        <div class="mb-3">
                            <label class="form-label small mb-1">Title</label>
                            <InputText @bind-Value="_newInvoice.Title" class="form-control" placeholder="e.g. Monthly Dues April 2026" />
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label small mb-1">Amount</label>
                                <InputNumber @bind-Value="_newInvoice.Amount" class="form-control" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-1">Due Date</label>
                                <InputDate @bind-Value="_newInvoice.DueDate" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small mb-1">Description</label>
                            <InputTextArea @bind-Value="_newInvoice.Description" class="form-control" rows="2" />
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn-vscode-secondary" @onclick="CloseModals">Cancel</button>
                            <button type="submit" class="btn-vscode">Generate Invoice</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Grid<Invoice> invoiceGrid = default!;
    private List<Invoice>? _invoices;
    private List<Payment>? _payments;
    private bool _isCreateModalOpen;
    private Invoice _newInvoice = new() { DueDate = DateTime.Today.AddDays(7) };
    private string _scope = "tenant";

    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (ParseQueryParameters())
        {
            _invoices = null;
            _payments = null;
            await LoadData();
        }
    }

    private bool ParseQueryParameters()
    {
        var uri = new Uri(Navigation.Uri);
        var query = uri.Query;
        var newScope = query.Contains("scope=association") ? "association" : "tenant";
        
        if (newScope != _scope)
        {
            _scope = newScope;
            return true;
        }
        return false;
    }

    private async Task<GridDataProviderResult<Invoice>> InvoicesDataProvider(GridDataProviderRequest<Invoice> request)
    {
        if (_invoices == null) await LoadData();
        return request.ApplyTo(_invoices ?? new List<Invoice>());
    }

    private async Task LoadData()
    {
        try 
        {
            string baseUrl = "api/finance";
            string invoicesUrl = $"{baseUrl}/invoices";
            string paymentsUrl = $"{baseUrl}/payments";

            if (_scope == "association")
            {
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var aid = authState.User.FindFirst("AssociationId")?.Value;
                if (int.TryParse(aid, out int associationId) && associationId != 0)
                {
                    invoicesUrl += $"?associationId={associationId}";
                    paymentsUrl += $"?associationId={associationId}";
                }
            }

            var invoices = await Api.GetAsync<IEnumerable<Invoice>>(invoicesUrl);
            _invoices = invoices?.ToList();
            
            var payments = await Api.GetAsync<IEnumerable<Payment>>(paymentsUrl);
            _payments = payments?.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading billing data: {ex.Message}");
            _invoices = new List<Invoice>();
            _payments = new List<Payment>();
        }
    }

    private void ShowCreateInvoice()
    {
        _newInvoice = new() { DueDate = DateTime.Today.AddDays(7) };
        _isCreateModalOpen = true;
    }

    private async Task HandleCreateInvoice()
    {
        var success = await Api.PostAsync<object>("api/finance/invoices", _newInvoice);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Invoice created successfully."));
            _isCreateModalOpen = false;
            _invoices = null;
            await invoiceGrid.RefreshDataAsync();
            
            // Also refresh payments just in case
            _payments = null; 
            await LoadData(); // Full reload to update dashboard stats too
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to generate invoice."));
        }
    }

    private async Task RecordPayment(Invoice invoice)
    {
        var payment = new Payment 
        { 
            Amount = invoice.Amount,
            InvoiceId = invoice.InvoiceId,
            Status = "Paid",
            Currency = "INR"
        };
        var success = await Api.PostAsync<object>("api/finance/payments", payment);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, $"Payment of ₹{invoice.Amount} recorded."));
            _invoices = null;
            _payments = null;
            await invoiceGrid.RefreshDataAsync();
            await LoadData(); // Reload for stats and payment list
        }
    }

    private void CloseModals() => _isCreateModalOpen = false;

    private string GetStatusClass(string status) => status switch
    {
        "Paid" => "bg-success-subtle text-success",
        "Unpaid" => "bg-danger-subtle text-danger",
        "Partial" => "bg-warning-subtle text-warning",
        _ => "bg-secondary-subtle text-secondary"
    };
}
