@using AssociationManager.Shared.Models
@inject AssociationManager.Client.Services.ApiService ApiService
@inject AssociationManager.Client.Services.IAppAuthorizationService AuthService
@inject ToastService _toastService

<div class="vehicles-section forced-text-dark">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-bold">Registered Vehicles</h6>
        <AuthorizeView Context="vehicleAuthContext">
            @if (_canManage)
            {
                <button class="btn btn-sm btn-vscode" @onclick='() => _showAddForm = true'><i class="bi bi-plus"></i> Add</button>
            }
        </AuthorizeView>
    </div>

    @if (_showAddForm)
    {
        <div class="bg-light p-2 mb-3 border compact-form">
            <h6 class="fw-bold mb-2" style="font-size: 11px;">Add Vehicle</h6>
            <div class="row g-1">
                <div class="col-4"><input @bind="_newVehicle.LicensePlate" class="form-control" placeholder="Plate #" /></div>
                <div class="col-4"><input @bind="_newVehicle.Make" class="form-control" placeholder="Make" /></div>
                <div class="col-4"><input @bind="_newVehicle.Model" class="form-control" placeholder="Model" /></div>
                <div class="col-12 mt-1"><input @bind="_newVehicle.ParkingSlot" class="form-control" placeholder="Parking Slot (Optional)" /></div>
            </div>
            <div class="mt-2 text-end">
                <button class="btn btn-sm btn-vscode-secondary" @onclick='() => _showAddForm = false'>Cancel</button>
                <button class="btn btn-sm btn-vscode px-3" @onclick="SaveVehicle">Add Vehicle</button>
            </div>
        </div>
    }

        <Grid TItem="Vehicle"
              @ref="grid"
              Class="table table-hover table-bordered table-striped compact-table"
              DataProvider="VehiclesDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="5"
              AllowSorting="true">

            <GridColumn TItem="Vehicle" HeaderText="Make/Model" PropertyName="Make" SortKeySelector="item => item.Make">
                @context.Make @context.Model
            </GridColumn>

            <GridColumn TItem="Vehicle" HeaderText="Plate" PropertyName="LicensePlate" SortKeySelector="item => item.LicensePlate">
                <span class="badge bg-light text-dark border">@context.LicensePlate</span>
            </GridColumn>

            <GridColumn TItem="Vehicle" HeaderText="Slot" PropertyName="ParkingSlot" SortKeySelector="item => item.ParkingSlot">
                @context.ParkingSlot
            </GridColumn>

            <GridColumn TItem="Vehicle" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                <AuthorizeView Context="vehicleAuthContext">
                    @if (_canManage)
                    {
                        <button class="btn btn-sm btn-vscode-danger ms-2" @onclick="() => OnDelete.InvokeAsync(context.VehicleId)">
                            <i class="bi bi-trash"></i>
                        </button>
                    }
                </AuthorizeView>
            </GridColumn>
        </Grid>
</div>

@code {
    [Parameter] public int AssetId { get; set; }
    [Parameter] public List<Vehicle>? Vehicles { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private Grid<Vehicle> grid = default!;
    private bool _canManage;

    protected override async Task OnParametersSetAsync()
    {
        _canManage = await ApiService.GetAsync<bool>($"api/people/can-manage-unit/{AssetId}");
        if (grid != null) await grid.RefreshDataAsync();
    }

    private async Task<GridDataProviderResult<Vehicle>> VehiclesDataProvider(GridDataProviderRequest<Vehicle> request)
    {
        return await Task.FromResult(request.ApplyTo(Vehicles ?? new List<Vehicle>()));
    }

    private bool _showAddForm;
    private Vehicle _newVehicle = new();

    private async Task SaveVehicle()
    {
        _newVehicle.AssetId = AssetId;
        var success = await ApiService.PostAsync("api/people/vehicles", _newVehicle);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Vehicle registered."));
            _newVehicle = new();
            _showAddForm = false;
            
            await OnDataChanged.InvokeAsync();
            await grid.RefreshDataAsync();
        }
    }
}
