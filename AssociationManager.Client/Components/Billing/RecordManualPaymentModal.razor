@using AssociationManager.Shared.Models
@inject BillingStateService BillingService
@inject ToastService ToastService

<div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); z-index: 1050;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content compact-card p-0 overflow-hidden shadow-lg" style="background: white; border: 1px solid var(--vscode-border);">
            <div class="premium-card-header bg-success bg-opacity-10 py-2 border-bottom">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-cash-stack text-success"></i>
                    <h6 class="premium-card-title m-0">Record Manual Payment</h6>
                </div>
                <button type="button" class="btn-close" style="font-size: 10px;" @onclick="OnClose"></button>
            </div>
            
            <div class="p-3">
                @if (BillingService.ManualPaymentInvoice != null)
                {
                    <div class="payment-target-info p-2 mb-3 rounded bg-light border small text-muted">
                        <div class="d-flex justify-content-between">
                            <span>Target Invoice:</span>
                            <span class="fw-bold text-dark">#@BillingService.ManualPaymentInvoice.InvoiceId</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Asset/Unit:</span>
                            <span class="fw-bold text-dark">@BillingService.ManualPaymentInvoice.AssetName</span>
                        </div>
                    </div>

                    <EditForm Model="_payment" OnValidSubmit="HandleSubmit">
                        <div class="mb-3">
                            <label class="form-label small mb-1">Amount to Record (₹)</label>
                            <InputNumber @bind-Value="_payment.Amount" class="form-control form-control-sm bg-light" step="0.01" readonly />
                            <div class="small text-muted mt-1" style="font-size: 10px;">Full amount: ₹@_totalAmount.ToString("N2")</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small mb-1">Payment Date</label>
                            <InputDate @bind-Value="_payment.CreatedDate" class="form-control form-control-sm bg-light" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small mb-1">Reference / Method</label>
                            <InputTextArea @bind-Value="_payment.Notes" class="form-control form-control-sm bg-light" rows="2" readonly />
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                            <button type="button" class="btn btn-sm btn-vscode-secondary" @onclick="OnClose">Cancel</button>
                            <button type="submit" class="btn btn-sm btn-success px-3" disabled="@_isSubmitting">
                                @if (_isSubmitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                <i class="bi bi-check2-circle me-1"></i> Record Payment
                            </button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private Payment _payment = new();
    private decimal _totalAmount;
    private bool _isSubmitting;

    protected override void OnInitialized()
    {
        if (BillingService.ManualPaymentInvoice != null)
        {
            var inv = BillingService.ManualPaymentInvoice;
            _totalAmount = inv.Amount + inv.LineItems.Where(l => l.InvoiceLineItemId == 0 || l.ChargeName.Contains("Penalty") || l.ChargeName.Contains("Fine")).Sum(l => l.Amount);
            
            _payment = new Payment
            {
                InvoiceId = inv.InvoiceId,
                AssetId = inv.AssetId,
                AssociationId = inv.AssociationId,
                TenantId = inv.TenantId,
                Amount = _totalAmount,
                Status = "Paid", // For manual entries, we assume it's already cleared or being cleared immediately
                Currency = "INR",
                Notes = "Manual Entry",
                CreatedDate = DateTime.Today
            };
        }
    }

    private void OnClose() => BillingService.ShowManualPaymentModal = false;

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        
        // Final sanity check
        if (_payment.Amount <= 0)
        {
            ToastService.Notify(new(ToastType.Danger, "Payment amount must be greater than zero."));
            _isSubmitting = false;
            return;
        }

        var success = await BillingService.RecordManualPaymentAsync(_payment);
        _isSubmitting = false;
        
        if (success)
        {
            // The service already handles toast and closing the modal
        }
    }
}
