@using AssociationManager.Client.Services
@using AssociationManager.Shared.Models
@inject BillingStateService BillingService

<div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content compact-card p-0 overflow-hidden shadow-lg" style="background: white; border: 1px solid var(--vscode-border);">
            <div class="premium-card-header">
                <h6 class="premium-card-title">Adjust Pro-forma: @(BillingService.AdjustingInvoice?.AssetName ?? "Invoice #" + BillingService.AdjustingInvoice?.InvoiceId)</h6>
                <button type="button" class="btn-close" style="font-size: 10px;" @onclick="OnClose"></button>
            </div>
            <div class="p-3">
                <div class="alert alert-info py-2 px-3 mb-3 small">
                    <i class="bi bi-info-circle me-2"></i>
                    Editing a pro-forma invoice allowing you to add one-time charges or modify calculated maintenance fees.
                </div>

                <div class="table-responsive" style="max-height: 300px;">
                    <table class="table table-sm table-bordered" style="font-size: 12px;">
                        <thead class="bg-light">
                            <tr>
                                <th>Charge Name</th>
                                <th style="width: 120px;">Amount</th>
                                <th>Description</th>
                                <th style="width: 40px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in BillingService.AdjustingLineItems)
                            {
                                <tr>
                                    <td><input type="text" class="form-control form-control-sm" @bind="item.ChargeName" /></td>
                                    <td><input type="number" class="form-control form-control-sm" @bind="item.Amount" /></td>
                                    <td><input type="text" class="form-control form-control-sm" @bind="item.Description" /></td>
                                    <td class="text-center">
                                        <button class="btn btn-link text-danger p-0" @onclick="() => BillingService.AdjustingLineItems.Remove(item)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <button class="btn btn-sm btn-outline-primary mt-2 mb-3" @onclick='() => BillingService.AdjustingLineItems.Add(new InvoiceLineItem { ChargeName = "Adjustment", Amount = 0 })'>
                    <i class="bi bi-plus-lg me-1"></i> Add Manual Charge
                </button>
                
                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                    <div class="fw-bold">Total Billable: ₹@BillingService.AdjustingLineItems.Sum(l => l.Amount).ToString("N2")</div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-vscode-secondary" @onclick="OnClose">Cancel</button>
                        <button class="btn btn-sm btn-vscode" @onclick="HandleSave">Save Adjustments</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void OnClose() 
    {
        BillingService.ShowAdjustModal = false;
        BillingService.IdToAdjust = 0;
    }

    private async Task HandleSave()
    {
        await BillingService.SaveAdjustmentAsync();
    }
}
