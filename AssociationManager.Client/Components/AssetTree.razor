@using AssociationManager.Shared.Models

<div class="asset-tree-pane custom-scrollbar">
    <div class="tree-header d-flex justify-content-between align-items-center">
        <span class="header-text">EXPLORER</span>
        <div class="d-flex gap-2">
            <button class="btn btn-link p-0 text-secondary" style="font-size: 14px;" @onclick="OnCollapse">
                <i class="bi bi-layout-sidebar-inset-reverse"></i>
            </button>
        </div>
    </div>
    
    <div class="explorer-search-container">
        <div class="position-relative">
            <i class="bi bi-search position-absolute" style="left: 10px; top: 7px; font-size: 11px; opacity: 0.5;"></i>
            <input type="text" 
                   class="explorer-search-input" 
                   placeholder="Filter assets..." 
                   style="padding-left: 28px;"
                   @bind="_searchTerm" 
                   @bind:event="oninput" />
        </div>
    </div>
    
    <div class="tree-content">
        @if (Hierarchy == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <p class="mt-2 text-muted" style="font-size: 11px;">Building Hierarchy...</p>
            </div>
        }
        else if (!Hierarchy.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building-add" style="font-size: 2rem; opacity: 0.2;"></i>
                <p class="mt-2 small">No assets registered yet.</p>
            </div>
        }
        else
        {
            <div class="tree-container">
                @foreach (var root in GetFilteredHierarchy())
                {
                    <AssetTreeNode Asset="root" 
                                   Level="0"
                                   OnSelected="OnSelected" 
                                   SelectedAsset="SelectedAsset"
                                   ExpandedIds="ExpandedIds"
                                   OnToggleExpand="OnToggleExpand"
                                   SearchTerm="@_searchTerm" />
                }
            </div>
        }
    </div>
</div>

<style>
    .asset-tree-pane {
        width: 100%;
        min-width: 250px;
        background: #f1f5f9;
        height: 100%;
        border-right: 1px solid #cbd5e1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .tree-header {
        padding: 10px 16px;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }
    .header-text {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.05em;
    }
    .tree-content {
        flex-grow: 1;
        overflow-y: auto;
        padding-top: 8px;
    }
    .tree-container {
        padding-bottom: 20px;
    }
</style>

@code {
    [Parameter] public List<Asset>? Hierarchy { get; set; }
    [Parameter] public Asset? SelectedAsset { get; set; }
    [Parameter] public HashSet<int> ExpandedIds { get; set; } = new();
    [Parameter] public EventCallback<Asset> OnSelected { get; set; }
    [Parameter] public EventCallback<int> OnToggleExpand { get; set; }
    [Parameter] public EventCallback OnCollapse { get; set; }

    private string _searchTerm = "";

    private List<Asset> GetFilteredHierarchy()
    {
        if (Hierarchy == null) return new();
        if (string.IsNullOrWhiteSpace(_searchTerm)) return Hierarchy;
        
        return Hierarchy.Select(a => FilterAsset(a, _searchTerm))
                        .Where(a => a != null)
                        .Cast<Asset>()
                        .ToList();
    }

    private Asset? FilterAsset(Asset asset, string term)
    {
        // Recursively filter children first
        var filteredChildren = asset.Children
            .Select(c => FilterAsset(c, term))
            .Where(c => c != null)
            .Cast<Asset>()
            .ToList();

        // If name matches OR any child matches, keep this asset
        if (asset.Name.Contains(term, StringComparison.OrdinalIgnoreCase) || filteredChildren.Any())
        {
            var clone = new Asset 
            {
                AssetId = asset.AssetId,
                ParentId = asset.ParentId,
                TenantId = asset.TenantId,
                AssociationId = asset.AssociationId,
                Name = asset.Name,
                Description = asset.Description,
                AssetType = asset.AssetType,
                MetadataJson = asset.MetadataJson,
                IsActive = asset.IsActive,
                Children = filteredChildren
            };
            
            // Auto-expand if children match
            if (filteredChildren.Any() && !string.IsNullOrWhiteSpace(term))
            {
                ExpandedIds.Add(asset.AssetId);
            }
            
            return clone;
        }

        return null;
    }
}
