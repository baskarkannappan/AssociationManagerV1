@using AssociationManager.Shared.Models

<div class="asset-tree-pane custom-scrollbar">
    <div class="tree-header d-flex justify-content-between align-items-center">
        <span class="header-text">EXPLORER</span>
        <div class="d-flex align-items-center gap-2">
            @if (CanManage)
            {
                <button class="btn btn-link p-0 text-vscode-accent" title="Add Root Asset" @onclick="OnAddRoot">
                    <i class="bi bi-plus-lg"></i>
                </button>
                <button class="btn btn-link p-0 text-vscode-accent" title="Bulk Create" @onclick="OnBulkCreate">
                    <i class="bi bi-cloud-upload"></i>
                </button>
            }
            <button class="btn btn-link p-0 text-secondary ms-1" style="font-size: 14px;" @onclick="OnCollapse">
                <i class="bi bi-layout-sidebar-inset-reverse"></i>
            </button>
        </div>
    </div>
    
    <div class="explorer-search-container">
        <div class="position-relative">
            <i class="bi bi-search position-absolute" style="left: 10px; top: 7px; font-size: 11px; opacity: 0.5;"></i>
            <input type="text" 
                   class="explorer-search-input" 
                   placeholder="Filter assets..." 
                   style="padding-left: 28px;"
                   @bind="AssetState.SearchTerm" 
                   @bind:event="oninput" />
        </div>
    </div>
    
    <div class="tree-content">
        @if (AssetState.Hierarchy == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <p class="mt-2 text-muted" style="font-size: 11px;">Building Hierarchy...</p>
            </div>
        }
        else if (!AssetState.Hierarchy.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-building-add" style="font-size: 2rem; opacity: 0.2;"></i>
                <p class="mt-2 small">No assets registered yet.</p>
            </div>
        }
        else
        {
            <div class="tree-container">
                <Virtualize Items="AssetState.VisibleNodes" Context="node" SpacerElement="div">
                    <AssetTreeNode Node="node" 
                                   OnSelected="OnSelected" 
                                   SelectedAsset="SelectedAsset"
                                   OnToggleExpand="OnToggleExpand" />
                </Virtualize>
            </div>
        }
    </div>
</div>

<style>
    .asset-tree-pane {
        width: 100%;
        min-width: 250px;
        background: #f1f5f9;
        height: 100%;
        border-right: 1px solid #cbd5e1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .tree-header {
        padding: 10px 16px;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }
    .header-text {
        font-size: 11px;
        font-weight: 700;
        color: #64748b;
        letter-spacing: 0.05em;
    }
    .tree-content {
        flex-grow: 1;
        overflow-y: auto;
        padding-top: 8px;
    }
    .tree-container {
        padding-bottom: 20px;
    }
</style>

@inject AssetStateService AssetState

@code {
    [Parameter] public Asset? SelectedAsset { get; set; }
    [Parameter] public bool CanManage { get; set; }
    [Parameter] public EventCallback<Asset> OnSelected { get; set; }
    [Parameter] public EventCallback<int> OnToggleExpand { get; set; }
    [Parameter] public EventCallback OnCollapse { get; set; }
    [Parameter] public EventCallback OnAddRoot { get; set; }
    [Parameter] public EventCallback OnBulkCreate { get; set; }
}
