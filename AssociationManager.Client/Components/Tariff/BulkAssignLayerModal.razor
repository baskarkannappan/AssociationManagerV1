@using AssociationManager.Client.Services
@using AssociationManager.Shared.Models
@inject TariffStateService TariffState
@inject ApiService Api
@inject ToastService _toastService

<div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-light py-2">
                <h6 class="modal-title fw-bold">Bulk Assign Layer</h6>
                <button type="button" class="btn-close small" @onclick="() => TariffState.ShowBulkAssignModal = false"></button>
            </div>
            
            <div class="p-3 bg-white border-bottom">
                 <div class="input-group input-group-sm mb-2">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Filter assets..." @bind="assetFilter" @bind:event="oninput" />
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" checked="@isAllSelected" @onchange="ToggleSelectAll" id="selectAllAssets">
                        <label class="form-check-label small fw-semibold" for="selectAllAssets">Select All Visible</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="isRecurring" id="recurringCharge">
                        <label class="form-check-label small fw-semibold text-primary" for="recurringCharge">Recurring Charge</label>
                    </div>
                    <span class="small text-muted">@selectedAssets.Count selected</span>
                </div>
            </div>

            <div class="modal-body p-0" style="max-height: 60vh; overflow-y: auto;">
                @if (isLoading)
                {
                    <div class="p-4 text-center">
                        <div class="spinner-border spinner-border-sm text-primary mb-2"></div>
                        <p class="mt-2 text-muted">Loading available assets...</p>
                    </div>
                }
                else if (!availableAssets.Any())
                {
                    <div class="p-5 text-center">
                        <i class="bi bi-check2-circle display-6 text-success opacity-50 mb-2 d-block"></i>
                        <p class="mt-2">All assets are already assigned to this layer!</p>
                    </div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var asset in FilteredAssets)
                        {
                            <label class="list-group-item d-flex align-items-center py-2 hover-bg-slate cursor-pointer">
                                <input class="form-check-input me-3" type="checkbox" 
                                       checked="@selectedAssets.Contains(asset)" 
                                       @onchange='(e) => ToggleAssetSelection(asset, (bool)e.Value!)'>
                                <div>
                                    <div class="fw-medium small">@asset.Name</div>
                                    <div class="text-muted" style="font-size: 10px;">@asset.AssetType | @asset.Description</div>
                                </div>
                            </label>
                        }
                    </div>
                }
            </div>
            
            <div class="modal-footer border-0 bg-light py-2">
                <div class="text-muted small me-auto">
                    @selectedAssets.Count assets selected
                </div>
                <button class="btn btn-sm btn-secondary" @onclick="() => TariffState.ShowBulkAssignModal = false">Cancel</button>
                <button class="btn btn-sm btn-vscode px-4" @onclick="ExecuteBulkAssign" disabled="@(!selectedAssets.Any() || isSaving)">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Confirm Assignment
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int LayerId { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }

    private List<Asset> availableAssets = new();
    private HashSet<Asset> selectedAssets = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private bool isRecurring = true;
    private string assetFilter = "";

    private IEnumerable<Asset> FilteredAssets => string.IsNullOrWhiteSpace(assetFilter) 
        ? availableAssets 
        : availableAssets.Where(a => a.Name.Contains(assetFilter, StringComparison.OrdinalIgnoreCase));

    private bool isAllSelected => FilteredAssets.Any() && FilteredAssets.All(a => selectedAssets.Contains(a));

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableAssets();
    }

    private async Task LoadAvailableAssets()
    {
        isLoading = true;
        availableAssets = await TariffState.GetAvailableAssetsForLayerAsync(LayerId);
        isLoading = false;
    }

    private void ToggleAssetSelection(Asset asset, bool selected)
    {
        if (selected) selectedAssets.Add(asset);
        else selectedAssets.Remove(asset);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool select = (bool)e.Value!;
        if (select)
        {
            foreach (var a in FilteredAssets) selectedAssets.Add(a);
        }
        else
        {
            foreach (var a in FilteredAssets) selectedAssets.Remove(a);
        }
    }

    private async Task ExecuteBulkAssign()
    {
        if (!selectedAssets.Any() || LayerId == 0) return;
        isSaving = true;
        try
        {
            var assignments = selectedAssets.Select(asset => new AssetTariff
            {
                AssetId = asset.AssetId,
                TariffLayerId = LayerId,
                IsActive = true,
                IsRecurring = isRecurring,
                CreatedDate = DateTime.UtcNow
            }).ToList();

            var success = await TariffState.AssignTariffsBulkAsync(assignments);
            if (success)
            {
                // Clear cached assignments so they refresh in the workbench
                TariffState.AssignedAssets = null; 
                
                _toastService.Notify(new(ToastType.Success, $"Assigned to {assignments.Count} assets."));
                
                if (OnSuccess.HasDelegate)
                    await OnSuccess.InvokeAsync();

                TariffState.ShowBulkAssignModal = false;
            }
        }
        catch (Exception ex)
        {
             _toastService.Notify(new(ToastType.Danger, $"Assignment failed: {ex.Message}"));
        }
        finally { isSaving = false; }
    }
}
