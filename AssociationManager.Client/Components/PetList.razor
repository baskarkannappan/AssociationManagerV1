@using AssociationManager.Shared.Models
@inject AssociationManager.Client.Services.ApiService ApiService
@inject AssociationManager.Client.Services.IAppAuthorizationService AuthService
@inject ToastService _toastService

<div class="pets-section forced-text-dark">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-bold">Registered Pets</h6>
        <AuthorizeView Context="petAuthContext">
            @if (_canManage)
            {
                <button class="btn btn-sm btn-vscode" @onclick='() => { _showAddForm = true; _newPet = new(); }'><i class="bi bi-plus"></i> Add</button>
            }
        </AuthorizeView>
    </div>

    @if (_showAddForm)
    {
        <div class="bg-light p-3 mb-3 border compact-form rounded shadow-sm">
            <h6 class="fw-bold mb-3" style="font-size: 11px;">@(_newPet.PetId > 0 ? "Edit" : "Add") Pet</h6>
            <div class="row g-2">
                <div class="col-4"><input @bind="_newPet.Name" class="form-control" placeholder="Pet Name" /></div>
                <div class="col-4"><input @bind="_newPet.Species" class="form-control" placeholder="Species (Dog...)" /></div>
                <div class="col-4"><input @bind="_newPet.TagNumber" class="form-control" placeholder="Tag #" /></div>
            </div>
            <div class="mt-3 text-end">
                <button class="btn btn-sm btn-vscode-secondary" @onclick='() => _showAddForm = false'>Cancel</button>
                <button class="btn btn-sm btn-vscode px-3" @onclick="SavePet">@(_newPet.PetId > 0 ? "Save Changes" : "Add Pet")</button>
            </div>
        </div>
    }

        <Grid TItem="Pet"
              @ref="grid"
              Class="table table-hover table-bordered table-striped compact-table"
              DataProvider="PetsDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="5"
              AllowSorting="true">

            <GridColumn TItem="Pet" HeaderText="Name" PropertyName="Name" SortKeySelector="item => item.Name">
                @context.Name
            </GridColumn>

            <GridColumn TItem="Pet" HeaderText="Species" PropertyName="Species" SortKeySelector="item => item.Species">
                @context.Species (@context.Breed)
            </GridColumn>

            <GridColumn TItem="Pet" HeaderText="Tag" PropertyName="TagNumber" SortKeySelector="item => item.TagNumber">
                @context.TagNumber
            </GridColumn>

            <GridColumn TItem="Pet" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                <AuthorizeView Context="petAuthContext">
                    @if (_canManage)
                    {
                        <button class="btn btn-sm btn-vscode-secondary" @onclick="() => EditPet(context)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-vscode-danger ms-2" @onclick="() => OnDelete.InvokeAsync(context.PetId)">
                            <i class="bi bi-trash"></i>
                        </button>
                    }
                </AuthorizeView>
            </GridColumn>
        </Grid>
</div>

@code {
    [Parameter] public int AssetId { get; set; }
    [Parameter] public List<Pet>? Pets { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private Grid<Pet> grid = default!;
    private bool _canManage;

    protected override async Task OnParametersSetAsync()
    {
        _canManage = await ApiService.GetAsync<bool>($"api/people/can-manage-unit/{AssetId}");
        if (grid != null) await grid.RefreshDataAsync();
    }

    private async Task<GridDataProviderResult<Pet>> PetsDataProvider(GridDataProviderRequest<Pet> request)
    {
        return await Task.FromResult(request.ApplyTo(Pets ?? new List<Pet>()));
    }

    private bool _showAddForm;
    private Pet _newPet = new();

    private void EditPet(Pet p)
    {
        _newPet = new Pet
        {
            PetId = p.PetId,
            AssetId = p.AssetId,
            TenantId = p.TenantId,
            AssociationId = p.AssociationId,
            Name = p.Name,
            Species = p.Species,
            Breed = p.Breed,
            TagNumber = p.TagNumber,
            IsActive = p.IsActive
        };
        _showAddForm = true;
    }

    private async Task SavePet()
    {
        _newPet.AssetId = AssetId;
        bool success;
        
        if (_newPet.PetId > 0)
        {
            success = await ApiService.PutAsync($"api/people/pets/{_newPet.PetId}", _newPet);
        }
        else
        {
            success = await ApiService.PostAsync("api/people/pets", _newPet);
        }

        if (success)
        {
            _toastService.Notify(new(ToastType.Success, _newPet.PetId > 0 ? "Pet record updated." : "Pet record added."));
            _newPet = new();
            _showAddForm = false;
            
            await OnDataChanged.InvokeAsync();
            await grid.RefreshDataAsync();
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to save pet details."));
        }
    }
}
