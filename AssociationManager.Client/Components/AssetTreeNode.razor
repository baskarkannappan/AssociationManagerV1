@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums

<div class="asset-tree-node">
    <div class="vscode-tree-item @(IsSelected ? "active" : "")" 
         style="padding-left: @(GetPadding())px;"
         @onclick="HandleToggleExpansion">
        
        <div class="expand-icon-container">
            @if (Asset.Children.Any())
            {
                <i class="bi @(IsExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
            }
        </div>
        
        <i class="bi @GetIconClass() @GetIconColorClass() asset-icon"></i>
        
        <span class="asset-name">
            @if (string.IsNullOrWhiteSpace(SearchTerm))
            {
                @Asset.Name
            }
            else
            {
                @GetHighlightedText(Asset.Name, SearchTerm)
            }
        </span>
        
        <span class="tree-type-badge">@Asset.AssetType</span>
    </div>

    @if (IsExpanded && Asset.Children.Any())
    {
        <div class="asset-children-group">
            @foreach (var child in Asset.Children)
            {
                <AssetTreeNode Asset="child" 
                               Level="@(Level + 1)"
                               OnSelected="OnSelected" 
                               SelectedAsset="SelectedAsset"
                               ExpandedIds="ExpandedIds"
                               OnToggleExpand="OnToggleExpand"
                               SearchTerm="@SearchTerm" />
            }
        </div>
    }
</div>

<style>
    .vscode-tree-item {
        display: flex;
        align-items: center;
        padding: 2px 8px;
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
        font-size: 13px;
        color: #334155;
        border-radius: 4px;
        margin: 1px 4px;
        transition: background-color 0.1s;
    }
    .vscode-tree-item:hover {
        background-color: #e2e8f0;
    }
    .vscode-tree-item.active {
    background-color: #e0f2fe;
    color: #0369a1;
    font-weight: 600;
}
    .expand-icon-container {
        width: 16px;
        height: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-right: 2px;
    }
    .expand-icon-container i {
        font-size: 10px;
        opacity: 0.5;
    }
    .asset-icon {
        font-size: 14px;
        margin-right: 8px;
        flex-shrink: 0;
    }
    .asset-name {
        flex-grow: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-right: 8px;
    }
    .tree-count {
        font-size: 10px;
        background: #94a3b8;
        color: white;
        padding: 0 5px;
        border-radius: 10px;
        margin-right: 6px;
        flex-shrink: 0;
    }
    .tree-type-badge {
        font-size: 9px;
        text-transform: uppercase;
        color: #64748b;
        letter-spacing: 0.05em;
        font-weight: 600;
        flex-shrink: 0;
        opacity: 0.7;
    }
</style>

@code {
    [Parameter] public int Level { get; set; } = 0;
    [Parameter] public Asset Asset { get; set; } = null!;
    [Parameter] public Asset? SelectedAsset { get; set; }
    [Parameter] public EventCallback<Asset> OnSelected { get; set; }
    
    [Parameter] public HashSet<int> ExpandedIds { get; set; } = new();
    [Parameter] public EventCallback<int> OnToggleExpand { get; set; }
    [Parameter] public string SearchTerm { get; set; } = "";

    private bool IsExpanded => ExpandedIds.Contains(Asset.AssetId);
    private bool IsSelected => SelectedAsset?.AssetId == Asset.AssetId;

    private int GetPadding() => 8 + (Level * 16);

    private async Task HandleToggleExpansion()
    {
        await OnToggleExpand.InvokeAsync(Asset.AssetId);
        await OnSelected.InvokeAsync(Asset);
    }

    private string GetIconClass() => Asset.AssetType switch
    {
        AssociationManager.Shared.Enums.AssetType.Property => "bi-geo-alt",
        AssociationManager.Shared.Enums.AssetType.Building => "bi-building",
        AssociationManager.Shared.Enums.AssetType.Floor => "bi-layers",
        AssociationManager.Shared.Enums.AssetType.Unit => "bi-door-closed",
        AssociationManager.Shared.Enums.AssetType.Villa => "bi-house-heart",
        AssociationManager.Shared.Enums.AssetType.CommonArea => "bi-tree",
        AssociationManager.Shared.Enums.AssetType.Amenity => "bi-water",
        AssociationManager.Shared.Enums.AssetType.SecurityGate => "bi-shield-lock",
        _ => "bi-box"
    };

    private string GetIconColorClass() => Asset.AssetType switch
    {
        AssociationManager.Shared.Enums.AssetType.Property => "asset-icon-property",
        AssociationManager.Shared.Enums.AssetType.Building => "asset-icon-building",
        AssociationManager.Shared.Enums.AssetType.Floor => "asset-icon-floor",
        AssociationManager.Shared.Enums.AssetType.Unit => "asset-icon-unit",
        AssociationManager.Shared.Enums.AssetType.Villa => "asset-icon-villa",
        AssociationManager.Shared.Enums.AssetType.CommonArea => "asset-icon-common",
        _ => ""
    };

    private RenderFragment GetHighlightedText(string text, string term) => builder =>
    {
        var index = text.IndexOf(term, StringComparison.OrdinalIgnoreCase);
        if (index == -1)
        {
            builder.AddContent(0, text);
            return;
        }

        builder.AddContent(1, text.Substring(0, index));
        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "style", "background: #fff9c4; font-weight: 700;");
        builder.AddContent(4, text.Substring(index, term.Length));
        builder.CloseElement();
        builder.AddContent(5, text.Substring(index + term.Length));
    };
}
