@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums
@inject AssociationManager.Client.Services.ApiService ApiService
@inject AssociationManager.Client.Services.IAppAuthorizationService AuthService
@inject ToastService _toastService
@inject AuthenticationStateProvider AuthStateProvider

<div class="occupants-section forced-text-dark">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-bold">Current Occupants</h6>
        <AuthorizeView Context="occupancyAuthContext">
            @if (_canManage)
            {
                <button class="btn btn-sm btn-vscode" @onclick='() => { _showAddForm = true; _newPerson = new(); _newOccupancy = new(); }'><i class="bi bi-plus"></i> Add</button>
            }
        </AuthorizeView>
    </div>

    @if (_showAddForm)
    {
        <div class="bg-light p-3 mb-3 border compact-form rounded shadow-sm">
            <h6 class="fw-bold mb-3" style="font-size: 11px;">@(_newOccupancy.OccupancyId > 0 ? "Edit" : "Add") Resident/Occupant</h6>
            <div class="row g-2">
                <div class="col-6"><input @bind="_newPerson.FirstName" class="form-control" placeholder="First Name" /></div>
                <div class="col-6"><input @bind="_newPerson.LastName" class="form-control" placeholder="Last Name" /></div>
                <div class="col-12"><input @bind="_newPerson.Email" class="form-control" placeholder="Email" /></div>
                <div class="col-6">
                    <select @bind="_newOccupancy.OccupancyType" class="form-select">
                        @foreach (var type in Enum.GetValues<OccupancyType>()) { <option value="@type">@type</option> }
                    </select>
                </div>
                <div class="col-6 d-flex align-items-center px-2">
                    <div class="form-check m-0">
                        <input type="checkbox" class="form-check-input" @bind="_newOccupancy.IsPrimaryContact" id="primary-contact" />
                        <label class="form-check-label" style="font-size: 11px;" for="primary-contact">Primary (Auto-swaps)</label>
                    </div>
                </div>
            </div>
            <div class="mt-3 text-end">
                <button class="btn btn-sm btn-vscode-secondary" @onclick='() => _showAddForm = false'>Cancel</button>
                <button class="btn btn-sm btn-vscode px-3" @onclick="SaveOccupant">@(_newOccupancy.OccupancyId > 0 ? "Save Changes" : "Add Occupant")</button>
            </div>
        </div>
    }

        <Grid TItem="Occupancy"
              @ref="grid"
              Class="table table-hover table-bordered table-striped compact-table"
              DataProvider="OccupanciesDataProvider"
              Responsive="true"
              AllowPaging="true"
              PageSize="5"
              AllowSorting="true">

            <GridColumn TItem="Occupancy" HeaderText="Type" PropertyName="OccupancyType" SortKeySelector="item => item.OccupancyType">
                @context.OccupancyType
            </GridColumn>

            <GridColumn TItem="Occupancy" HeaderText="Contact" PropertyName="PersonName" SortKeySelector="item => item.PersonName">
                <div class="fw-bold">@context.PersonName</div>
                <div class="text-muted" style="font-size: 10px;">@context.Email</div>
            </GridColumn>

            <GridColumn TItem="Occupancy" HeaderText="Primary" PropertyName="IsPrimaryContact" SortKeySelector="item => item.IsPrimaryContact">
                @(context.IsPrimaryContact ? "Yes" : "No")
            </GridColumn>

            <GridColumn TItem="Occupancy" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                <AuthorizeView Context="occupancyAuthContext">
                    @if (_canManage)
                    {
                        <button class="btn btn-sm btn-vscode-secondary" @onclick="() => EditOccupant(context)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-sm btn-vscode-danger ms-2" @onclick="() => OnDelete.InvokeAsync(context.OccupancyId)">
                            <i class="bi bi-x-circle"></i>
                        </button>
                    }
                </AuthorizeView>
            </GridColumn>
        </Grid>
</div>

@code {
    [Parameter] public int AssetId { get; set; }
    [Parameter] public List<Occupancy>? Occupants { get; set; }
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private Grid<Occupancy> grid = default!;
    private bool _canManage;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var ruleMatch = await AuthService.EvaluateRuleAsync(authState.User, "AssetRule_ManageOccupancy", AssetId);
        var apiMatch = await ApiService.GetAsync<bool>($"api/people/can-manage-unit/{AssetId}");
        
        _canManage = ruleMatch && apiMatch;
        
        if (grid != null) await grid.RefreshDataAsync();
    }

    private async Task<GridDataProviderResult<Occupancy>> OccupanciesDataProvider(GridDataProviderRequest<Occupancy> request)
    {
        return await Task.FromResult(request.ApplyTo(Occupants ?? new List<Occupancy>()));
    }

    private bool _showAddForm;
    private Person _newPerson = new();
    private Occupancy _newOccupancy = new();

    private void EditOccupant(Occupancy occ)
    {
        _newOccupancy = new Occupancy
        {
            OccupancyId = occ.OccupancyId,
            AssetId = occ.AssetId,
            PersonId = occ.PersonId,
            TenantId = occ.TenantId,
            AssociationId = occ.AssociationId,
            OccupancyType = occ.OccupancyType,
            StartDate = occ.StartDate,
            EndDate = occ.EndDate,
            IsPrimaryContact = occ.IsPrimaryContact
        };
        
        _newPerson = new Person
        {
            PersonId = occ.PersonId,
            FirstName = occ.PersonName?.Split(' ').FirstOrDefault() ?? "",
            LastName = occ.PersonName?.Contains(' ') == true ? occ.PersonName?.Split(' ').LastOrDefault() ?? "" : "",
            Email = occ.Email
        };
        
        _showAddForm = true;
    }

    private async Task SaveOccupant()
    {
        bool success = false;
        
        // 1. Update/Create Person
        if (_newOccupancy.OccupancyId > 0)
        {
            await ApiService.PutAsync($"api/people/{_newPerson.PersonId}", _newPerson);
            success = await ApiService.PutAsync($"api/people/occupancy/{_newOccupancy.OccupancyId}", _newOccupancy);
        }
        else
        {
            var personId = await ApiService.PostAsync<Person, int>("api/people", _newPerson);
            if (personId > 0)
            {
                _newOccupancy.PersonId = personId;
                _newOccupancy.AssetId = AssetId;
                success = await ApiService.PostAsync("api/people/occupancy", _newOccupancy);
            }
        }
        
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, _newOccupancy.OccupancyId > 0 ? "Occupant updated." : "Occupant added."));
            _newPerson = new();
            _newOccupancy = new();
            _showAddForm = false;
            
            await OnDataChanged.InvokeAsync();
            await grid.RefreshDataAsync();
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to save occupant."));
        }
    }
}
