@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums

<div class="px-4 py-2">
    <!-- Identity Section -->
    <div class="mb-5">
        <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-info-circle text-primary"></i>
            <span class="fw-bold small text-uppercase text-muted">Identity & Type</span>
        </div>
        
        <EditForm Model="Asset" OnValidSubmit="HandleValidSubmit">
            <div class="horizontal-form-row">
                <div class="horizontal-form-label">Name</div>
                <div class="horizontal-form-value">
                    <InputText @bind-Value="Asset.Name" class="horizontal-form-input" placeholder="e.g. vVilla1" disabled="@IsReadOnly" />
                </div>
            </div>

            <div class="horizontal-form-row">
                <div class="horizontal-form-label">Classification</div>
                <div class="horizontal-form-value">
                    <InputSelect @bind-Value="Asset.AssetType" class="horizontal-form-input" style="max-width: 300px;" disabled="@IsReadOnly">
                        @foreach (var type in Enum.GetValues<AssetType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </InputSelect>
                </div>
            </div>

            <div class="horizontal-form-row">
                <div class="horizontal-form-label">Status</div>
                <div class="horizontal-form-value">
                    <div class="form-check form-switch m-0 d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" role="switch" @bind="Asset.IsActive" disabled="@IsReadOnly" id="assetStatus">
                        <label class="form-check-label small fw-semibold @(Asset.IsActive ? "text-success" : "text-danger")" for="assetStatus">
                            @(Asset.IsActive ? "ACTIVE" : "INACTIVE")
                        </label>
                    </div>
                </div>
            </div>

            <!-- Address Section (Simulated/Metadata based) -->
            <div class="mt-5 mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-geo-alt text-primary"></i>
                <span class="fw-bold small text-uppercase text-muted">Location Details</span>
            </div>

            <div class="horizontal-form-row">
                <div class="horizontal-form-label">Street Address</div>
                <div class="horizontal-form-value">
                    <input type="text" class="horizontal-form-input" placeholder="Primary street address..." disabled="@IsReadOnly" />
                </div>
            </div>

            <div class="horizontal-form-row">
                <div class="horizontal-form-label">City</div>
                <div class="horizontal-form-value">
                    <input type="text" class="horizontal-form-input" style="max-width: 250px;" placeholder="City..." disabled="@IsReadOnly" />
                </div>
            </div>

            <div class="horizontal-form-row">
                <div class="horizontal-form-label">Postal Code</div>
                <div class="horizontal-form-value">
                    <input type="text" class="horizontal-form-input" style="max-width: 150px;" placeholder="Zip..." disabled="@IsReadOnly" />
                </div>
            </div>

            <!-- Description Section -->
            <div class="mt-5 mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-chat-left-text text-primary"></i>
                <span class="fw-bold small text-uppercase text-muted">Association Notes</span>
            </div>

            <div class="horizontal-form-row border-bottom-0">
                <div class="horizontal-form-label">Description</div>
                <div class="horizontal-form-value">
                    <InputTextArea @bind-Value="Asset.Description" class="horizontal-form-input" rows="4" placeholder="Internal notes or special instructions..." disabled="@IsReadOnly" />
                </div>
            </div>

            <AuthorizeView Policy="RequireAssetManager" Context="authContext">
                <Authorized>
                    <div class="d-flex align-items-center gap-3 pt-5 mt-4">
                        <button type="submit" class="btn btn-sm btn-vscode px-4 py-2">
                            <i class="bi bi-check-circle-fill"></i> @(IsNew ? "Initialize Asset" : "Update Asset")
                        </button>
                        
                        @if (!IsNew)
                        {
                            <button type="button" class="btn btn-sm btn-vscode-secondary px-3 py-2" @onclick="OnAddChild">
                                <i class="bi bi-plus-circle"></i> Add Component
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-danger ms-auto px-3 py-2" @onclick="OnDelete">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
        </EditForm>
    </div>
</div>

@code {
    [Inject] private ApiService ApiService { get; set; } = default!;
    [Parameter] public Asset Asset { get; set; } = new();
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnAddChild { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnSave.InvokeAsync();
    }
}
