@using AssociationManager.Client.Services
@inherits StatefulComponentBase
@inject DashboardStateService DashboardService

@code {
    protected override void OnInitialized() => RegisterStateService(DashboardService);
}

@if (DashboardService.ResidentMetrics != null && DashboardService.ResidentMetrics.CreditAvailable > 0)
{
    <div class="compact-card bg-white border h-100 p-4 d-flex flex-column justify-content-center align-items-center text-center">
        <div class="text-muted small text-uppercase fw-bold mb-2">
            <span class="text-secondary opacity-75"><i class="bi bi-wallet2 me-1"></i> MY WALLET</span>
        </div>
        <div class="display-5 fw-bold text-success">₹@(DashboardService.ResidentMetrics.CreditAvailable.ToString("N0"))</div>
        <div class="mt-3 w-100 d-grid gap-2">
            <button class="btn btn-vscode w-100 py-2 fw-bold" @onclick="OnTopUpClicked">
                <i class="bi bi-plus-circle-fill me-2"></i> Pay Advance / Top-up
            </button>
        </div>
    </div>
}
else if (DashboardService.ResidentMetrics != null)
{
    <div class="compact-card bg-white border p-3 h-100 d-flex align-items-center">
        <button class="btn btn-vscode-outline w-100 py-1 fw-bold small" @onclick="OnTopUpClicked">
            <i class="bi bi-plus-circle-fill me-1"></i> TOP UP WALLET
        </button>
    </div>
}

@code {
    [Parameter] public EventCallback OnTopUpClicked { get; set; }
}
