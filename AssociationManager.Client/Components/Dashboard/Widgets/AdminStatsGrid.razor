@using AssociationManager.Client.Services
@inherits StatefulComponentBase
@inject DashboardStateService DashboardService

@code {
    protected override void OnInitialized() => RegisterStateService(DashboardService);
}

<div class="row g-2 mb-3">
    <div class="col-md-3">
        <div class="compact-card h-100 bg-white border">
            <div class="text-muted small text-uppercase fw-bold mb-1" style="font-size: 10px;">Total Members</div>
            <div class="h4 mb-1 fw-bold">
                @if (DashboardService.IsLoadingAdmin) { <div class="spinner-border spinner-border-sm opacity-25"></div> }
                else { @(DashboardService.TotalMembers) }
            </div>
            <div class="small text-success" style="font-size: 11px;">
                <i class="bi bi-people-fill"></i> Community Portfolio
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="compact-card h-100 bg-white border border-start-0" style="border-left: 3px solid var(--vscode-accent) !important;">
            <div class="text-muted small text-uppercase fw-bold mb-1" style="font-size: 10px;">Committee Members</div>
            <div class="h4 mb-1 fw-bold">
                @if (DashboardService.IsLoadingAdmin) { <div class="spinner-border spinner-border-sm opacity-25"></div> }
                else { @(DashboardService.CommitteeCount) }
            </div>
            <div class="small text-muted" style="font-size: 11px;">Active Governance</div>
        </div>
    </div>
    <AuthorizeView Policy="ShowWidget_Outstanding" Context="widgetContext">
        <div class="col-md-3">
            <div class="compact-card h-100 bg-white border">
                <div class="text-muted small text-uppercase fw-bold mb-1" style="font-size: 10px;">Total Revenue (30d)</div>
                <div class="h4 mb-1 fw-bold text-accent" style="color: var(--vscode-accent);">
                    @if (DashboardService.IsLoadingAdmin) { <div class="spinner-border spinner-border-sm opacity-25"></div> }
                    else { <span>₹@(DashboardService.Revenue30D.ToString("N0"))</span> }
                </div>
                <div class="small text-success" style="font-size: 11px;">
                    <i class="bi bi-graph-up-arrow"></i> Collections
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="compact-card h-100 bg-white border">
                <div class="text-muted small text-uppercase fw-bold mb-1" style="font-size: 10px;">Net Outstanding</div>
                <div class="h4 mb-1 fw-bold @(DashboardService.NetOutstanding > 0 ? "text-danger" : "text-success")">
                    @if (DashboardService.IsLoadingAdmin) { <div class="spinner-border spinner-border-sm opacity-25"></div> }
                    else { <span>₹@(DashboardService.NetOutstanding.ToString("N0"))</span> }
                </div>
                <div class="d-flex align-items-center gap-1 small text-muted" style="font-size: 11px;">
                    <i class="bi bi-hourglass-split"></i> To be collected
                </div>
            </div>
        </div>
         <div class="col-lg-3 col-md-6 mt-md-2 mt-lg-0">
            <div class="compact-card h-100 bg-white border border-success border-opacity-25" style="border-left: 3px solid #10b981 !important;">
                <div class="text-muted small text-uppercase fw-bold mb-1" style="font-size: 10px;">Held Advance Money</div>
                <div class="h4 mb-1 fw-bold text-success">
                    @if (DashboardService.IsLoadingAdmin) { <div class="spinner-border spinner-border-sm opacity-25"></div> }
                    else { <span>₹@(DashboardService.HeldAdvanceMoney.ToString("N0"))</span> }
                </div>
                <div class="d-flex align-items-center gap-1 small text-muted" style="font-size: 11px;">
                    <i class="bi bi-piggy-bank-fill text-success"></i> Prepaid by @(DashboardService.UnitsWithCredit) units
                </div>
            </div>
        </div>
    </AuthorizeView>
</div>
