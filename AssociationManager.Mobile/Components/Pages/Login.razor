@page "/login"
@using AssociationManager.Mobile.Services
@inject MobileAuthService AuthService
@inject NavigationManager Navigation

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h3>AssociationManager Mobile</h3>
            <p class="text-muted">High-Security Mobile Gateway</p>
            
            <div class="card mt-4 p-4 shadow-sm border-0 bg-light">
                <div class="card-body">
                    <img src="Resources/Images/dotnet_bot.svg" width="80" class="mb-3" alt="Logo" />
                    <h5 class="mb-4">Secure Sign-In</h5>
                    
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    <div class="d-grid gap-2">
                        <Button Color="ButtonColor.Primary" Size="ButtonSize.Large" @onclick="HandleGoogleLoginAsync">
                            <Icon Name="IconName.Google" class="me-2" /> Sign in with Google
                        </Button>
                    </div>
                    
                    <p class="mt-4 small text-muted">
                        Targeting Android 9+ (API 21+)
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? _errorMessage;

    private async Task HandleGoogleLoginAsync()
    {
        _errorMessage = null;
        
        // --- NOTE FOR USER ---
        // In a full production build, we would use Microsoft.Maui.Authentication.WebAuthenticator here.
        // For this secure bootstrap, we are triggering the auth flow.
        
        try 
        {
            // Placeholder for Google ID Token acquisition on Mobile
            // For now, this service will call the backend /api/auth/google
            await Task.Delay(500); // Simulate network
            _errorMessage = "Mobile Google Auth setup required (WebAuthenticator + Intent Filter)";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
