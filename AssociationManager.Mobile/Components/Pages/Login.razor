@page "/"
@attribute [AllowAnonymous]
@using AssociationManager.Mobile.Services
@using Microsoft.Identity.Client
@using Microsoft.Identity.Client.Extensibility
@inject MobileAuthService AuthService
@inject NavigationManager Navigation
@inject MobileAuthenticationStateProvider AuthStateProvider
@inject IPublicClientApplication PublicClientApp

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h3>AssociationManager Mobile</h3>
            <p class="text-muted">Multi-Provider brokered by Microsoft Entra</p>
            
            <div class="card mt-4 p-4 shadow-sm border-0 bg-light">
                <div class="card-body">
                    <img src="Resources/Images/dotnet_bot.svg" width="80" class="mb-3" alt="Logo" />
                    <h5 class="mb-4">Secure Sign-In</h5>
                    
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    @if (_isLoggingIn)
                    {
                        <div class="text-center">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2 text-muted">Redirecting to Identity Broker...</p>
                        </div>
                    }
                    else 
                    {
                        <div class="d-grid gap-2">
                            <Button Color="ButtonColor.Primary" Size="ButtonSize.Large" @onclick="HandleB2CLoginAsync">
                                <Icon Name="IconName.ShieldLock" class="me-2" /> Sign In
                            </Button>
                        </div>
                        <p class="mt-3 small text-muted">Supports Google, Microsoft, Facebook & more</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? _errorMessage;
    private bool _isLoggingIn;
    private string[] _scopes = new[] { "openid", "offline_access", "api://af161f39-c71a-42ae-873f-9367d85144f8/access_as_user" };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await AuthService.GetTokenFromStorageAsync();
            if (!string.IsNullOrEmpty(token))
            {
                // Verify if token is still valid (simplified check)
                Navigation.NavigateTo("/context-selection");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[LOGIN_INIT_ERROR] {ex.Message}");
        }
    }

    private async Task HandleB2CLoginAsync()
    {
        _errorMessage = null;
        _isLoggingIn = true;
        
        try 
        {
            Console.WriteLine("[AUTH_FLOW] Starting AcquireTokenInteractive...");
            
            // Trigger MSAL Interactive Login
            AuthenticationResult authResult = null;
            await MainThread.InvokeOnMainThreadAsync(async () =>
            {
                authResult = await PublicClientApp.AcquireTokenInteractive(_scopes)
#if ANDROID
                    .WithParentActivityOrWindow(Microsoft.Maui.ApplicationModel.Platform.CurrentActivity)
#else
                    .WithParentActivityOrWindow(null)
#endif
                    .ExecuteAsync();
            });

            Console.WriteLine("[AUTH_FLOW] AcquireTokenInteractive completed successfully.");

            var b2cToken = authResult?.IdToken;
            if (string.IsNullOrEmpty(b2cToken))
            {
                Console.WriteLine("[AUTH_FLOW] Failed: No IdToken received.");
                _errorMessage = "Authentication failed: No access token received from B2C.";
                return;
            }

            Console.WriteLine("[AUTH_FLOW] Exchanging CIAM token with Backend...");

            // Exchange the B2C Access Token for our internal JWT
            var success = await AuthService.LoginWithB2CAsync(b2cToken);
            if (success)
            {
                Console.WriteLine("[AUTH_FLOW] Exchange successful! Notifying AuthStateProvider...");
                
                // Get the newly saved token and notify the provider
                var internalToken = await AuthService.GetTokenFromStorageAsync();
                AuthStateProvider.NotifyUserAuthentication(internalToken!);
                
                Console.WriteLine("[AUTH_FLOW] Navigating to /context-selection...");
                Navigation.NavigateTo("/context-selection");
            }
            else 
            {
                Console.WriteLine("[AUTH_FLOW] Exchange failed. Invalid user.");
                _errorMessage = "Identity verification failed. Your account might not be authorized for this platform.";
            }
        }
        catch (MsalClientException ex) when (ex.ErrorCode == "authentication_canceled")
        {
            Console.WriteLine("[AUTH_FLOW] User cancelled the authentication.");
            // User cancelled
        }
        catch (Exception ex)
        {
            _errorMessage = $"Login Error: {ex.Message}";
            Console.WriteLine($"[AUTH_ERROR] Exception in Auth Flow: {ex}");
        }
        finally
        {
            _isLoggingIn = false;
        }
    }
}
