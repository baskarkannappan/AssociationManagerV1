@implements IDisposable
@inherits LayoutComponentBase

<div class="vscode-shell">
    <!-- Top Header Bar -->
    <header class="vscode-top-header">
        <div class="header-left">
            <button class="mobile-menu-btn" @onclick="ToggleMobileMenu">
                <i class="bi bi-list"></i>
            </button>
            <svg viewBox="0 14 170 66" xmlns="http://www.w3.org/2000/svg" class="app-logo me-2">
                <g transform="translate(0,0)">
                    <rect x="0" y="20" width="35" height="60" fill="black"/>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="black"/>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"/>
                </g>
                <g transform="translate(45,0)">
                    <rect x="0" y="20" width="35" height="60" fill="#6366f1"/>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="#6366f1"/>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"/>
                </g>
                <g transform="translate(90,0)">
                    <rect x="0" y="20" width="35" height="60" fill="black"/>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="black"/>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"/>
                </g>
                <g transform="translate(135,0)">
                    <rect x="0" y="20" width="35" height="60" fill="#6366f1"/>
                    <ellipse cx="17.5" cy="20" rx="17.5" ry="6" fill="#6366f1"/>
                    <ellipse cx="17.5" cy="20" rx="12" ry="4" fill="white"/>
                </g>
            </svg>
            <span class="app-title fw-semibold text-white">Corporate Manager</span>
            <span class="ms-2 opacity-50 text-white" style="font-size: 11px;">(v1.0.4 - Corporate)</span>
        </div>
        <div class="header-right">
            <AuthorizeView Context="authContext">
                <Authorized>
                    <div class="user-identity ms-3 me-2 text-white" title="@authContext.User.Identity?.Name">
                        <i class="bi bi-person me-1"></i>
                        <div class="d-flex flex-column">
                            <span class="fw-bold text-white" style="line-height: 1;">@(authContext.User.FindFirst("email")?.Value ?? authContext.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)</span>
                            <span class="text-white x-small opacity-75">@(GetDisplayRole(_currentRole))</span>
                        </div>
                    </div>
                    <button class="logout-btn" @onclick="HandleLogout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>

    <div class="vscode-main">
        <!-- Sidebar Explorer -->
        <div class="sidebar-wrapper @(_isMobileMenuOpen ? "mobile-active" : "")">
            <Explorer />
        </div>

        @if (_isMobileMenuOpen)
        {
            <div class="mobile-backdrop" @onclick="ToggleMobileMenu"></div>
        }

        <!-- Content Area -->
        <div class="vscode-editor-pane">
            <Toasts class="p-3" AutoHide="true" Delay="10000" Placement="ToastsPlacement.TopRight" />
            <main class="vscode-content">
                @Body
            </main>
        </div>
    </div>

    <!-- Status Bar
    <footer class="vscode-statusbar">
        <div class="section">
            <i class="bi bi-check2-all"></i>
            <span>Connected</span>
            <span>UTF-8</span>
        </div>
        <div class="section">
            <span>AssociationManager Project</span>
            <i class="bi bi-bell"></i>
        </div>
    </footer>
    -->
</div>

<link href="css/vscode.css" rel="stylesheet" />

<style>
    .app-logo { height: 18px; width: auto; vertical-align: middle; }
    .max-width-dashboard { max-width: 1200px; }
    .custom-scrollbar::-webkit-scrollbar { width: 10px; height: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cccccc; border: 3px solid transparent; background-clip: content-box; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #aaaaaa; border: 3px solid transparent; background-clip: content-box; }
    
    .tenant-switcher-container { font-size: 11px; display: flex; align-items: center; gap: 6px; }
    .tenant-select { background: #3c3c3c; color: #ccc; border: 1px solid #444; font-size: 11px; padding: 1px 4px; border-radius: 2px; }
    .tenant-select:focus { outline: 1px solid var(--vscode-accent); border-color: transparent; }
    
    .user-identity { font-size: 11px; opacity: 0.9; display: flex; align-items: center; gap: 8px; border-left: 1px solid rgba(255,255,255,0.1); padding-left: 10px; }
    .x-small { font-size: 9px; text-transform: uppercase; letter-spacing: 0.5px; }
    .text-accent { color: var(--vscode-accent); }
    .logout-btn { background: transparent; border: none; color: #fff; padding: 0 5px; opacity: 0.8; }
    .logout-btn:hover { opacity: 1; color: #fff; }

    .mobile-backdrop {
        position: fixed;
        top: 40px;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 998;
    }
</style>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private ApiService ApiService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private ToastService _toastService { get; set; } = default!;

    private IEnumerable<Association>? _userTenants;
    private int _currentTenantId;
    private int _currentAssociationId;
    private string? _currentRole;
    private bool _isMobileMenuOpen;
    private bool ContextLoaded => _userTenants != null;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        Navigation.LocationChanged += HandleLocationChanged;
        await LoadTenants();
    }

    private void ToggleMobileMenu() => _isMobileMenuOpen = !_isMobileMenuOpen;

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _isMobileMenuOpen = false;
        StateHasChanged();
    }

    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        await InvokeAsync(async () => {
            await LoadTenants();
            StateHasChanged();
        });
    }

    private async Task LoadTenants()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var tenantClaim = user.FindFirst("TenantId")?.Value;
            if (int.TryParse(tenantClaim, out int tid))
            {
                _currentTenantId = tid;
            }

            var assocClaim = user.FindFirst("AssociationId")?.Value;
            if (int.TryParse(assocClaim, out int aid))
            {
                _currentAssociationId = aid;
            }

            var allRoleClaims = user.FindAll(System.Security.Claims.ClaimTypes.Role)
                .Select(c => c.Value).ToList();
            if (!allRoleClaims.Any())
            {
                allRoleClaims = user.FindAll("Role").Select(c => c.Value).ToList();
            }
            if (!allRoleClaims.Any())
            {
                allRoleClaims = user.FindAll("http://schemas.microsoft.com/ws/2008/06/identity/claims/role").Select(c => c.Value).ToList();
            }

            var highestRole = allRoleClaims
                .SelectMany(r => r.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                .OrderByDescending(r => AppRole.GetLevel(r))
                .FirstOrDefault();
            
            if (_currentRole != highestRole && highestRole != null)
            {
                _currentRole = highestRole;
            }
            
            try 
            {
                _userTenants = await ApiService.GetAsync<IEnumerable<Association>>("associations/my-tenants");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading tenants: {ex.Message}");
                _userTenants = Enumerable.Empty<Association>();
            }
        }
        else
        {
            _userTenants = null;
            _currentRole = null;
        }
    }

    private string GetDisplayRole(string? role)
    {
        if (string.IsNullOrEmpty(role)) return "Guest";
        if (role == AppRole.SystemAdmin) return "Platform Admin";
        
        // Convert camelCase to Space Separated
        return System.Text.RegularExpressions.Regex.Replace(role, "([a-z])([A-Z])", "$1 $2");
    }


    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/logout");
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
