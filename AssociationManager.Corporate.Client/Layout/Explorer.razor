@using Microsoft.AspNetCore.Components.Routing
@using AssociationManager.Corporate.Client.Services
@inject IAppAuthorizationService AuthService

<AuthorizeView Context="rootAuthContext">
    <div class="vscode-explorer">
        <div class="vscode-explorer-header">Corporate Explorer</div>
        
        <div class="vscode-tree-group">
            <div class="vscode-tree-item py-1 text-muted" style="font-size: 11px; font-weight: 600; text-transform: uppercase;">
                Corporate Level
            </div>
            <NavLink href="" Match="NavLinkMatch.All" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-grid-1x2 text-secondary"></i>
                <span>Overview</span>
            </NavLink>
            
            <AuthorizeView Policy="RequireCorporate">
                <NavLink href="associations" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-buildings text-primary"></i>
                    <span>Associations</span>
                </NavLink>
            </AuthorizeView>
            
            <AuthorizeView Policy="RequirePlanManagement">
                <NavLink href="subscriptions" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-shield-check text-success"></i>
                    <span>Subscription Plans</span>
                </NavLink>
                <NavLink href="platform-billing" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-receipt text-warning"></i>
                    <span>Platform Billing</span>
                </NavLink>
            </AuthorizeView>
 
            <AuthorizeView Policy="RequireUserManagement">
                <NavLink href="users?scope=tenant" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-person-lines-fill text-danger"></i>
                    <span>Global Users</span>
                </NavLink>
            </AuthorizeView>

            <AuthorizeView Policy="RequirePlatformAdmin">
                <NavLink href="billing-accounts" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-wallet2 text-accent"></i>
                    <span>Billing Accounts</span>
                </NavLink>
                <NavLink href="razorpay-settings" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-shield-lock text-info"></i>
                    <span>Razorpay Settings</span>
                </NavLink>
                <NavLink href="admin/content-manager" class="vscode-tree-item text-decoration-none">
                    <i class="bi bi-file-earmark-richtext text-primary"></i>
                    <span>Content Manager</span>
                </NavLink>
            </AuthorizeView>

            <div class="vscode-tree-item py-1 text-muted mt-3" style="font-size: 11px; font-weight: 600; text-transform: uppercase;">
                Support
            </div>
            <NavLink href="p/about-us" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-info-circle text-primary"></i>
                <span>About Us</span>
            </NavLink>
            <NavLink href="contact-us" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-envelope text-success"></i>
                <span>Contact Us</span>
            </NavLink>
            <NavLink href="p/rules-regulations" class="vscode-tree-item text-decoration-none">
                <i class="bi bi-shield-check text-warning"></i>
                <span>Rules & Regulations</span>
            </NavLink>
        </div>
    </div>
</AuthorizeView>
