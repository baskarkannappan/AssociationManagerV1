@page "/contact-us"
@using AssociationManager.Shared.Models
@using AssociationManager.Corporate.Client.Services
@inject ApiService ApiService

<div class="contact-container animate__animated animate__fadeIn">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 p-md-5">
                    <h2 class="mb-3 text-primary fw-bold"><i class="bi bi-envelope-paper-fill me-2"></i>Post a Message to Us</h2>
                    <p class="text-muted mb-4 fs-5">Have a query or need assistance? Fill out the form below and our platform support team will get back to you.</p>

                    <EditForm Model="@_query" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Your Name</label>
                                <InputText @bind-Value="_query.Name" class="form-control form-control-lg border-2" placeholder="Full Name" />
                                <ValidationMessage For="@(() => _query.Name)" class="text-danger small" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Email Address</label>
                                <InputText @bind-Value="_query.Email" class="form-control form-control-lg border-2" placeholder="name@example.com" />
                                <ValidationMessage For="@(() => _query.Email)" class="text-danger small" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Subject</label>
                            <InputText @bind-Value="_query.Subject" class="form-control form-control-lg border-2" placeholder="What is this regarding?" />
                            <ValidationMessage For="@(() => _query.Subject)" class="text-danger small" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Your Message</label>
                            <InputTextArea @bind-Value="_query.MessageBody" class="form-control form-control-lg border-2" rows="6" placeholder="Describe your query in detail..." />
                            <ValidationMessage For="@(() => _query.MessageBody)" class="text-danger small" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold shadow-sm" disabled="@_isSubmitting">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    <span>SUBMITTING...</span>
                                }
                                else
                                {
                                    <i class="bi bi-send-fill me-2"></i>
                                    <span>SUBMIT QUERY</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card bg-dark text-white border-0 h-100 shadow-sm">
                <div class="card-body p-4 p-md-5 d-flex flex-column">
                    <h3 class="mb-4 fw-bold">Platform Support</h3>
                    <div class="contact-details flex-grow-1">
                        @if (_loadingDetails)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div class="spinner-border spinner-border-sm text-light" role="status"></div>
                                <span class="text-light-50">Loading contact info...</span>
                            </div>
                        }
                        else if (_content != null)
                        {
                            <div class="rich-contact-info">
                                @((MarkupString)_content.HtmlContent)
                            </div>
                        }
                        else
                        {
                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-primary bg-opacity-25 rounded-circle p-3 me-3">
                                        <i class="bi bi-geo-alt-fill text-primary fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="text-white-50 small">Our Office</div>
                                        <div class="fw-medium">123 Business Square, Silicon Valley</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <div class="bg-success bg-opacity-25 rounded-circle p-3 me-3">
                                        <i class="bi bi-telephone-fill text-success fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="text-white-50 small">Phone</div>
                                        <div class="fw-medium">+1 (555) 123-4567</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div class="bg-info bg-opacity-25 rounded-circle p-3 me-3">
                                        <i class="bi bi-headset text-info fs-4"></i>
                                    </div>
                                    <div>
                                        <div class="text-white-50 small">Support Email</div>
                                        <div class="fw-medium">support@associationmgr.com</div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <div class="mt-4 pt-4 border-top border-secondary">
                        <h5 class="mb-3">Our Promise</h5>
                        <p class="text-white-50 small">We aim to respond to all technical queries within 24 business hours. For urgent billing issues, please include your Tenant ID.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private SupportQuery _query = new();
    private StaticContent? _content;
    private bool _isSubmitting = false;
    private bool _loadingDetails = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadContactDetails();
    }

    private async Task LoadContactDetails()
    {
        _loadingDetails = true;
        try
        {
            var data = await ApiService.GetAsync<StaticContent>("publiccontent/contact-us-details");
            if (data != null) _content = data;
        }
        catch { /* Fallback to defaults */ }
        finally { _loadingDetails = false; }
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        try
        {
            var success = await ApiService.PostAsync("publiccontent/query", _query);
            if (success)
            {
                _query = new SupportQuery();
            }
        }
        catch { }
        finally
        {
            _isSubmitting = false;
        }
    }
}

<style>
    .contact-container {
        max-width: 1100px;
        margin: 3rem auto;
        padding: 0 1.5rem;
    }
    .form-control:focus {
        border-color: var(--bs-primary);
        box-shadow: 0 0 0 0.25rem rgba(var(--bs-primary-rgb), 0.15);
    }
    .rich-contact-info {
        color: rgba(255,255,255,0.8);
        line-height: 1.6;
    }
    .text-white-50 { color: rgba(255,255,255,0.5) !important; }
</style>
