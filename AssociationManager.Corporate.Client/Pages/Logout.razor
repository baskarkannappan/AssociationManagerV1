@page "/logout"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject NavigationManager Navigation

<div class="vh-100 d-flex align-items-center justify-content-center bg-login">
    <div class="login-mesh"></div>
    
    <div class="glass-panel text-center shadow-lg animate-scale-in p-5" style="max-width: 440px; width: 90%; position: relative; z-index: 10; border-radius: 12px; background: rgba(30, 41, 59, 0.7); border: 1px solid rgba(255, 255, 255, 0.1);">
        <div class="mb-4">
            <div class="d-inline-flex align-items-center justify-content-center p-3 rounded-circle mb-3 shadow-lg" 
                 style="background: rgba(34, 197, 94, 0.2); border: 1px solid rgba(34, 197, 94, 0.4); width: 80px; height: 80px;">
                <i class="bi bi-check2-circle text-success" style="font-size: 2.5rem;"></i>
            </div>
            <h2 class="fw-bold mb-3 text-white">Successfully Logged Out</h2>
            <p class="text-secondary mb-4">You have securely signed out of your corporate session.</p>
        </div>

        <button class="btn btn-primary w-100 py-2 rounded-3 fw-medium shadow-sm transition-all text-white border-0" 
                style="background: linear-gradient(135deg, #6366f1, #4f46e5);" 
                @onclick='() => Navigation.NavigateTo("/login")'>
            Return to Login
        </button>
    </div>
</div>

<style>
    .bg-login { background: #020617; overflow: hidden; position: relative; }
    .login-mesh {
        position: absolute; inset: 0;
        background-image: 
            radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%),
            radial-gradient(at 100% 0%, rgba(168, 85, 247, 0.15) 0px, transparent 50%);
        opacity: 0.6;
    }
    .animate-scale-in { animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
    @@keyframes scaleIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99, 102, 241, 0.4) !important; filter: brightness(1.1); }
</style>
