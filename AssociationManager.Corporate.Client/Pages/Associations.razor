@page "/associations"
@attribute [Authorize(Roles = $"{AppRole.PlatformAdmin},{AppRole.CorporateManager},{AppRole.SubscriptionManager},{AppRole.CorporateAuditor}")]
@using AssociationManager.Shared.Enums
@using AssociationManager.Corporate.Client.Services
@using AssociationManager.Shared.Models
@inject ApiService ApiService
@inject ToastService _toastService
@inject RealtimeService RealtimeService

<AuthorizeView Context="authContext">
    <Authorized>
        <div class="vscode-page-header border-bottom">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-diagram-3-fill text-muted" style="font-size: 14px;"></i>
                <span class="fw-medium">Associations</span>
            </div>
            <AuthorizeView Roles="@AppRole.PlatformAdmin">
                <button class="btn-vscode" @onclick="() => _showCreateForm = !_showCreateForm">
                    <i class="bi @(_showCreateForm ? "bi-dash" : "bi-plus")"></i>
                    @(_showCreateForm ? "Discard" : "New Association")
                </button>
            </AuthorizeView>
        </div>

        <div class="p-3">
            @if (_showCreateForm)
            {
                <div class="compact-card mb-3 border-top-0">
                    <div class="fw-bold mb-2 small text-uppercase text-muted">Initialize New Association</div>
                    <div class="row g-2 compact-form">
                        <div class="col-md-5">
                            <label>Name</label>
                            <input @bind="newAssociation.Name" class="form-control" placeholder="Legal Name" />
                        </div>
                        <div class="col-md-5">
                            <label>Description</label>
                            <input @bind="newAssociation.Description" class="form-control" placeholder="Optional details..." />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button @onclick="CreateAssociation" class="btn-vscode w-100 justify-content-center">
                                Create
                            </button>
                        </div>
                    </div>
                </div>
            }

            @if (associations == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border spinner-border-sm text-muted mb-2" role="status"></div>
                    <p class="text-muted small">Loading portfolio...</p>
                </div>
            }
            else
            {
                <div class="border bg-white p-2">
                    <Grid @ref="grid" TItem="Association"
                          Class="table table-hover table-bordered table-striped compact-table"
                          DataProvider="AssociationsDataProvider"
                          Responsive="true"
                          AllowPaging="true"
                          PageSize="10"
                          AllowSorting="true">

                        <GridColumn TItem="Association" HeaderText="ID" PropertyName="AssociationId" SortKeySelector="item => item.AssociationId">
                            <span class="text-muted font-monospace" style="font-size: 11px;">#@context.AssociationId</span>
                        </GridColumn>

                        <GridColumn TItem="Association" HeaderText="Association Name" PropertyName="Name" SortKeySelector="item => item.Name">
                            <div class="fw-medium">@context.Name</div>
                            <div class="text-muted" style="font-size: 11px;">@context.Description</div>
                        </GridColumn>

                        <GridColumn TItem="Association" HeaderText="Subscription Plan" PropertyName="PlanName" SortKeySelector="item => item.PlanName">
                            <span class="badge @(context.PlanName == null ? "bg-secondary-subtle text-secondary" : "bg-info-subtle text-info") border border-info-subtle">
                                @(context.PlanName ?? "Starter")
                            </span>
                        </GridColumn>

                        <GridColumn TItem="Association" HeaderText="Created" PropertyName="CreatedDate" SortKeySelector="item => item.CreatedDate">
                            @context.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd")
                        </GridColumn>

                        <GridColumn TItem="Association" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
                            <AuthorizeView Roles="PlatformAdmin,CorporateManager,SubscriptionManager" Context="innerAuth">
                                <Authorized>
                                    <a href="/subscriptions" class="btn btn-link btn-sm text-accent p-0 me-2" title="Manage Platform Tariff">
                                        <i class="bi bi-credit-card-2-front"></i>
                                    </a>
                                </Authorized>
                            </AuthorizeView>
                            <AuthorizeView Roles="PlatformAdmin,CorporateManager" Context="innerDeleteAuth">
                                <Authorized>
                                    <button @onclick="() => DeleteAssociation(context.AssociationId)" class="btn btn-link btn-sm text-muted p-0 hover-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                        </GridColumn>

                    </Grid>
                </div>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Authorizing session...</p>
        </div>
    </NotAuthorized>
</AuthorizeView>

<style>
    .btn-icon-slate { width: 32px; height: 32px; border: none; background: transparent; color: #94a3b8; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center; }
    .btn-icon-slate:hover { background: #f1f5f9; color: #475569; }
    .btn-icon-slate.hover-danger:hover { background: #fee2e2; color: #ef4444; }
    .bg-slate-50 { background-color: #f8fafc; }
</style>

@code {
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    private Grid<Association> grid = default!;
    private List<Association>? associations;
    private Association newAssociation = new();
    private bool _showCreateForm = false;

    protected override async Task OnInitializedAsync()
    {
        RealtimeService.OnNotificationReceived += HandleNotification;
        await RealtimeService.StartAsync();
        await LoadAssociations();
    }

    private async Task<GridDataProviderResult<Association>> AssociationsDataProvider(GridDataProviderRequest<Association> request)
    {
        if (associations == null) await LoadAssociations();
        return request.ApplyTo(associations ?? new List<Association>());
    }

    private async Task LoadAssociations()
    {
        try 
        {
            associations = await ApiService.GetAsync<List<Association>>("associations");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
             Console.WriteLine("Unauthorized access to associations. Redirecting...");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading associations: {ex.Message}");
        }
    }

    private async Task CreateAssociation()
    {
        if (string.IsNullOrWhiteSpace(newAssociation.Name)) return;
        var success = await ApiService.PostAsync("associations", newAssociation);
        if (success)
        {
            _toastService.Notify(new(ToastType.Success, "Association created successfully."));
            newAssociation = new();
            _showCreateForm = false;
            associations = null; // Clear so DataProvider reloads
            await grid.RefreshDataAsync();
        }
        else
        {
            _toastService.Notify(new(ToastType.Danger, "Failed to create association."));
        }
    }

    private async Task DeleteAssociation(int id)
    {
        var success = await ApiService.DeleteAsync($"associations/{id}");
        if (success)
        {
            _toastService.Notify(new(ToastType.Warning, "Association removed."));
            associations = null; // Clear so DataProvider reloads
            await grid.RefreshDataAsync();
        }
    }

    private void HandleNotification(string message)
    {
        Console.WriteLine($"Notification: {message}");
        InvokeAsync(StateHasChanged);
    }
}
