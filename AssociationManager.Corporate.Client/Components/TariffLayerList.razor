@using AssociationManager.Shared.Models
@using AssociationManager.Shared.Enums

<Grid TItem="TariffLayer"
      Class="table table-hover table-bordered table-striped compact-table"
      DataProvider="TariffLayersDataProvider"
      Responsive="true"
      AllowPaging="true"
      PageSize="10"
      AllowSorting="true">

    <GridColumn TItem="TariffLayer" HeaderText="Layer Name" PropertyName="Name" SortKeySelector="item => item.Name">
        <span class="fw-medium">@context.Name</span>
    </GridColumn>

    <GridColumn TItem="TariffLayer" HeaderText="Calculation" PropertyName="CalculationType" SortKeySelector="item => item.CalculationType">
        <span class="badge bg-light text-dark font-monospace" style="font-size: 10px;">@context.CalculationType</span>
    </GridColumn>

    <GridColumn TItem="TariffLayer" HeaderText="Base Rate" PropertyName="BaseRate" SortKeySelector="item => item.BaseRate">
        <span class="fw-semibold">₹@context.BaseRate</span>
    </GridColumn>

    <GridColumn TItem="TariffLayer" HeaderText="Frequency" PropertyName="Frequency" SortKeySelector="item => item.Frequency">
        @context.Frequency
    </GridColumn>

    <GridColumn TItem="TariffLayer" HeaderText="Category" PropertyName="AccountingCategory" SortKeySelector="item => item.AccountingCategory">
        <span class="text-muted small">@context.AccountingCategory</span>
    </GridColumn>

    <GridColumn TItem="TariffLayer" HeaderText="Actions" HeaderClass="text-end" Class="text-end">
        <button class="btn btn-sm btn-link p-0 text-muted hover-danger" @onclick="() => OnDelete.InvokeAsync(context.TariffLayerId)">
            <i class="bi bi-trash"></i>
        </button>
    </GridColumn>
</Grid>

<style>
    .compact-table th { font-size: 11px; text-transform: uppercase; color: #64748b; letter-spacing: 0.025em; border-top: none; }
    .compact-table td { font-size: 13px; padding: 8px 4px; }
    .hover-danger:hover { color: #dc3545 !important; }
</style>

@code {
    [Parameter] public IEnumerable<TariffLayer> Layers { get; set; } = Enumerable.Empty<TariffLayer>();
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private async Task<GridDataProviderResult<TariffLayer>> TariffLayersDataProvider(GridDataProviderRequest<TariffLayer> request)
    {
        return await Task.FromResult(request.ApplyTo(Layers ?? new List<TariffLayer>()));
    }
}
